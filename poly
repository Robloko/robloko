-- Track if currently giving
isAutoGiving = false

-- Update status
function updateStatus()
    local totalAmount, stackCount = countTotalPotions()
    local targetPlayer = Players:FindFirstChild(TARGET_PLAYER_NAME)
    local targetOnline = targetPlayer and "✓ Online" or "✗ Offline"

    statusLabel.Text = string.format("Potions: %d stacks (%d) | %s", stackCount, totalAmount, targetOnline)
end

-- Give All button click (Now a toggle to start/stop the loop)
giveAllButton.MouseButton1Click:Connect(function()
    if isAutoGiving then
        -- Stop the loop
        isAutoGiving = false
        giveAllButton.Text = "STOPPING..."
        giveAllButton.BackgroundColor3 = Color3.fromRGB(100, 100, 0)
    else
        -- Start the loop
        isAutoGiving = true
        giveAllButton.Text = "STOP GIVING"
        giveAllButton.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        
        -- Run the loop in a coroutine so the UI doesn't freeze
        coroutine.wrap(startAutoGiveLoop)()
    end
end)

-- Inspect button click
inspectButton.MouseButton1Click:Connect(function()
    inspectFoodInventory()
    updateStatus()
end)

-- Auto-update status every 5 seconds
coroutine.wrap(function()
    while true do
        updateStatus()
        task.wait(5)
    end
end)()

updateStatus()

