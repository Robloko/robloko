-- ==================================================================
-- POLYMORPH POTION GIVER SCRIPT
-- Finds all pet_polymorph_potion items in food inventory and gives to 2FinnPets
-- Continuously loops until all potions are given
-- ==================================================================
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

local DEBUG_MODE = true
local TARGET_PLAYER_NAME = "2FinnPets"
local POTION_ID = "pet_polymorph_potion"
local GIVE_DELAY = 9 -- seconds between each give (rate limit safety)
local RETRY_DELAY = 15 -- seconds to wait before retrying on failure

-- Debug print
local function debugPrint(msg)
    if DEBUG_MODE then
        print("[PolyPotionGiver] " .. msg)
    end
end

-- ==================================================================
-- FOOD INVENTORY SCANNER
-- ==================================================================

-- Function to scan food inventory and find all pet_polymorph_potion entries
local function findAllPolymorphPotions()
    local potions = {}

    local success, errorMsg = pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        local playerData = clientData.get_data()[player.Name]

        if playerData and playerData.inventory and playerData.inventory.food then
            for uniqueId, itemData in pairs(playerData.inventory.food) do
                if itemData.id == POTION_ID then
                    local amount = itemData.amount or itemData.properties and itemData.properties.stack_count or 1
                    table.insert(potions, {
                        uid = uniqueId,
                        id = itemData.id,
                        amount = amount
                    })
                end
            end
        end
    end)

    if not success then
        debugPrint("Error scanning food inventory: " .. tostring(errorMsg))
        return {}
    end

    return potions
end

-- Function to count total polymorph potions
local function countTotalPotions()
    local potions = findAllPolymorphPotions()
    local total = 0
    for _, potion in ipairs(potions) do
        total = total + potion.amount
    end
    return total, #potions
end

-- Function to print the entire food inventory (for inspection)
local function inspectFoodInventory()
    debugPrint("=== FOOD INVENTORY INSPECTION ===")

    local success, errorMsg = pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        local playerData = clientData.get_data()[player.Name]

        if playerData and playerData.inventory and playerData.inventory.food then
            local foodCount = 0
            for uniqueId, itemData in pairs(playerData.inventory.food) do
                foodCount = foodCount + 1
                local id = itemData.id or "unknown"
                local amount = itemData.amount or (itemData.properties and itemData.properties.stack_count) or 1
                local isPotion = (id == POTION_ID) and " ★ POLYMORPH" or ""
                debugPrint(string.format("  [%s] ID: %s | Amount: %d%s", tostring(uniqueId), id, amount, isPotion))
            end

            if foodCount == 0 then
                debugPrint("  Food inventory is empty!")
            else
                debugPrint("Total food items: " .. foodCount)
            end
        else
            debugPrint("No food inventory found!")
        end
    end)

    if not success then
        debugPrint("Error inspecting food inventory: " .. tostring(errorMsg))
    end

    debugPrint("=================================")
end

-- ==================================================================
-- GIVE POTIONS TO TARGET PLAYER (LOOP UNTIL EMPTY)
-- ==================================================================

-- Function to give a single potion stack to target player
local function givePotionToPlayer(targetPlayer, potionUid)
    if not targetPlayer or not potionUid then
        return false
    end

    local args = { targetPlayer, potionUid }
    local success, result = pcall(function()
        return ReplicatedStorage:WaitForChild("API"):WaitForChild("TradeAPI/GiveItem"):InvokeServer(unpack(args))
    end)

    if success then
        debugPrint("Successfully gave polymorph potion stack to " .. targetPlayer.Name)
        return true
    else
        debugPrint("Failed to give polymorph potion: " .. tostring(result))
        return false
    end
end

-- Main loop function: continuously gives ALL pet_polymorph_potion stacks to 2FinnPets until none are left
local function startAutoGiveLoop()
    debugPrint("Starting continuous polymorph potion giving loop...")
    
    while isAutoGiving do
        -- Check if target is in game
        local targetPlayer = Players:FindFirstChild(TARGET_PLAYER_NAME)
        if not targetPlayer then
            debugPrint("Target player '" .. TARGET_PLAYER_NAME .. "' is NOT in the server. Waiting 10 seconds...")
            task.wait(10)
            continue -- Loop again to check if they joined
        end

        -- Check for potions
        local potions = findAllPolymorphPotions()

        if #potions == 0 then
            debugPrint("No more pet_polymorph_potion items found! Loop complete.")
            break -- Exit the loop naturally because we are out of potions
        end

        -- Grab the first available stack
        local potion = potions[1]
        debugPrint(string.format("Attempting to give potion stack (uid: %s, amount: %d)...", tostring(potion.uid), potion.amount))

        local success = givePotionToPlayer(targetPlayer, potion.uid)

        if success then
            debugPrint("Give successful. Waiting " .. GIVE_DELAY .. " seconds for cooldown...")
            task.wait(GIVE_DELAY)
        else
            debugPrint("Give failed. Waiting " .. RETRY_DELAY .. " seconds before retrying...")
            task.wait(RETRY_DELAY)
        end
    end

    -- Loop ended (either finished or stopped by user)
    isAutoGiving = false
    giveAllButton.Text = "GIVE ALL POTIONS"
    giveAllButton.BackgroundColor3 = Color3.fromRGB(150, 0, 200)
    updateStatus()
    
    debugPrint("Auto-give loop terminated.")
end

