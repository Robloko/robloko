local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local function fireClickAction()
    -- Safely navigate to the folder
    local focusPetApp = PlayerGui:FindFirstChild("FocusPetApp")
    if not focusPetApp then return false end
    
    local chooseAilment = focusPetApp:FindFirstChild("ChooseAilment")
    if not chooseAilment then return false end
    
    local choices = chooseAilment:FindFirstChild("Choices")
    if not choices then return false end
    
    -- Get the children table
    local children = choices:GetChildren()
    
    -- Safety check: Make sure there are actually at least 3 children before trying to grab [3]
    if #children < 3 then return false end
    
    local targetChild = children[3]
    
    -- Continue navigating down from the 3rd child
    local container = targetChild:FindFirstChild("Container")
    if not container then return false end
    
    local content = container:FindFirstChild("Content")
    if not content then return false end
    
    local clickAction = content:FindFirstChild("ClickAction")
    
    -- If found and visible, firesignal it
    if clickAction and clickAction.Visible then
        -- Using pcall around each firesignal just in case the specific event doesn't exist on that custom button
        pcall(function() firesignal(clickAction.MouseButton1Down) end)
        task.wait(0.05)
        pcall(function() firesignal(clickAction.MouseButton1Up) end)
        pcall(function() firesignal(clickAction.MouseButton1Click) end)
        
        print("✅ Successfully fired signal on ClickAction!")
        return true
    end
    
    return false
end

-- Loop that constantly checks if the UI has popped up
while task.wait(0.5) do
    local success, clicked = pcall(fireClickAction)
    
    if success and clicked then
        -- break -- Remove the two dashes (--) before 'break' if you only want it to click ONCE and then stop the script.
    end
end
