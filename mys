local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local function clickAilmentButton()
    -- Step 1: Safely navigate down to the "Choices" folder
    local focusPetApp = PlayerGui:FindFirstChild("FocusPetApp")
    if not focusPetApp then return end
    
    local chooseAilment = focusPetApp:FindFirstChild("ChooseAilment")
    if not chooseAilment then return end
    
    local choices = chooseAilment:FindFirstChild("Choices")
    if not choices then return end

    -- Step 2: Get the children and check if there are at least 3
    local children = choices:GetChildren()
    if #children >= 3 then
        local thirdChild = children[3] -- Grabs the 3rd item in the folder
        
        -- Step 3: Safely navigate from the 3rd child down to ClickAction
        local container = thirdChild:FindFirstChild("Container")
        if container then
            local content = container:FindFirstChild("Content")
            if content then
                local clickAction = content:FindFirstChild("ClickAction")
                
                -- Step 4: Validate and Click
                if clickAction and clickAction.Visible and clickAction.Active and clickAction:IsA("GuiButton") then
                    
                    if firesignal then
                        firesignal(clickAction.MouseButton1Down)
                        task.wait(0.05)
                        firesignal(clickAction.MouseButton1Up)
                        firesignal(clickAction.MouseButton1Click)
                        print("✅ Successfully clicked the 3rd Ailment choice!")
                    else
                        clickAction.MouseButton1Click:Fire()
                        print("✅ Successfully clicked the 3rd Ailment choice (Fallback)!")
                    end
                    
                    task.wait(2) -- 2 second cooldown to prevent spam clicking
                end
            end
        end
    end
end

-- Main loop to constantly check for the button
while task.wait(0.5) do
    pcall(clickAilmentButton)
end
