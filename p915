-- Function to find the target accessory
local function findTargetAccessory()
    local accessoryId = nil
    local success, err = pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        local playerData = clientData.get_data()[player.Name]
        if playerData and playerData.inventory and playerData.inventory.pet_accessories then
            for uid, accData in pairs(playerData.inventory.pet_accessories) do
                -- Handle if it's a table or just a string value
                local id = type(accData) == "table" and accData.id or tostring(accData)
                if id == TARGET_ACCESSORY then
                    accessoryId = uid
                    break
                end
            end
        end
    end)
    return accessoryId
end

-- Function to give the accessory to a player
local function giveAccessoryToPlayer(targetPlayer, accUniqueId)
    local args = { targetPlayer, accUniqueId }
    local success, result = pcall(function()
        return ReplicatedStorage:WaitForChild("API"):WaitForChild("TradeAPI/GiveItem"):InvokeServer(unpack(args))
    end)
    return success
end

-- Main Accessory Giver loop
local function startAccessoryGiveaway()
    while AccessoryGiveawayMode do
        local targetPlayer = findFirstAvailablePlayer()
        if not targetPlayer then
            debugPrint("No available target players. Waiting...", "AccGiveaway")
            task.wait(10)
            continue
        end

        local accId = findTargetAccessory()
        if not accId then
            debugPrint("Target accessory (" .. TARGET_ACCESSORY .. ") not found. Stopping...", "AccGiveaway")
            AccessoryGiveawayMode = false
            break
        end

        if giveAccessoryToPlayer(targetPlayer, accId) then
            debugPrint("Gave " .. TARGET_ACCESSORY .. " to " .. targetPlayer.Name, "AccGiveaway")
            task.wait(9)
        else
            debugPrint("Failed to give accessory. Retrying...", "AccGiveaway")
            task.wait(3)
        end
    end
end

-- Function to toggle accessory giver mode
