    if AccessoryGiveawayMode then
        debugPrint("Accessory Giveaway STARTED - Looking for " .. TARGET_ACCESSORY, "AccGiveaway")
        accessoryGiveawayCoroutine = coroutine.wrap(startAccessoryGiveaway)()
    else
        debugPrint("Accessory Giveaway STOPPED", "AccGiveaway")
        accessoryGiveawayCoroutine = nil
    end
end

