-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualInputManager = game:GetService("VirtualInputManager")

-- Player
local player = Players.LocalPlayer
local targetSandwich = "schospital_refresh_2023_cafeteria_sandwich"

-- Function to click at specific coordinates
local function clickAt(x, y)
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
    task.wait(0.05) -- Small delay for realistic click
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
    return true
end

-- Function to inspect food inventory and find the unique ID of the sandwich
local function inspectFoodInventory()
    local foods = {}
    local sandwichUniqueId = nil
    
    local success, errorMsg = pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        local playerData = clientData.get_data()[player.Name]

        -- Check for food in inventory
        if playerData and playerData.inventory and playerData.inventory.food then
            for foodId, foodData in pairs(playerData.inventory.food) do
                if foodData.id then
                    table.insert(foods, {
                        id = foodId, -- This is the unique instance ID
                        name = foodData.id, -- This is the item type name
                        amount = foodData.amount or 1
                    })
                    
                    -- Check if this is the sandwich we are looking for
                    if foodData.id == targetSandwich then
                        sandwichUniqueId = foodId -- Save the unique instance ID for trading
                    end
                end
            end
        end
    end)

    if not success then
        print("Error reading food inventory: " .. tostring(errorMsg))
        return nil
    end

    -- Print the inventory
    if #foods == 0 then
        print("No food found in your inventory!")
    else
        print("=== AVAILABLE FOOD IN INVENTORY ===")
        for i, food in ipairs(foods) do
            print(string.format("%d. %s (Unique ID: %s) - Amount: %d", i, food.name, food.id, food.amount))
        end
        print("Total food items: " .. #foods)
        print("===================================")
    end

    return sandwichUniqueId
end

-- Function to buy the sandwich
local function buySandwich()
    print("Sandwich not found! Attempting to buy one...")
    local args = {
        "food",
        targetSandwich,
        {
            buy_count = 1
        }
    }
    
    local success, err = pcall(function()
        ReplicatedStorage:WaitForChild("API"):WaitForChild("ShopAPI/BuyItem"):InvokeServer(unpack(args))
    end)
    
    if success then
        print("Successfully bought the sandwich.")
    else
        print("Failed to buy sandwich: " .. tostring(err))
    end
    
    -- Wait a moment for the server to register the purchase and update inventory
    task.wait(1.5)
end

-- Function to exchange sandwich for sheep duck using the unique ID
local function exchangeForSheepDuck(sandwichId)
    if not sandwichId then
        print("Cannot exchange: No sandwich ID found.")
        return
    end

    print("Attempting to exchange sandwich (Unique ID: " .. sandwichId .. ") for sheep duck...")
    local character = player.Character or player.CharacterAdded:Wait()
    
    local args = {
        "dagi_npc",
        "UseBlock",
        {
            r_1 = sandwichId -- Uses the dynamic unique ID grabbed from the inventory
        },
        character
    }
    
    local success, err = pcall(function()
        ReplicatedStorage:WaitForChild("API"):WaitForChild("HousingAPI/ActivateInteriorFurniture"):InvokeServer(unpack(args))
    end)
    
    if success then
        print("Exchange command sent successfully!")
    else
        print("Failed to exchange: " .. tostring(err))
    end
end

-- == Main Execution Loop == 
task.spawn(function()
    while true do
        print("=== STARTING NEW CYCLE ===")
        
        -- Initial 5 second delay before clicking starts
        task.wait(5)

        -- Click sequence
        print("Clicking at 444, 480")
        clickAt(444, 480)
        task.wait(2)

        print("Clicking at 333, 313")
        clickAt(333, 313)
        task.wait(2)

        print("Clicking at 415, 161")
        clickAt(415, 161)
        task.wait(2)

        print("Clicking at 500, 373")
        clickAt(500, 373)
        print("Finished clicking sequence.")

        -- 1. Inspect inventory and check for the sandwich's unique ID
        local sandwichId = inspectFoodInventory()

        -- 2. Buy the sandwich if we don't have it, then re-inspect to get the new ID
        if not sandwichId then
            buySandwich()
            sandwichId = inspectFoodInventory()
        end

        -- 3. Attempt the exchange using the specific sandwich's unique ID
        if sandwichId then
            print("Sandwich found! Proceeding to exchange...")
            exchangeForSheepDuck(sandwichId)
        else
            print("Failed to obtain a sandwich ID for the trade.")
        end

        -- 4. Team API Spawn
        pcall(function()
            ReplicatedStorage.API["TeamAPI/Spawn"]:InvokeServer()
        end)
        
        print("=== CYCLE COMPLETE. WAITING 1 HOUR... ===")
        -- Wait 1 hour (3600 seconds) before repeating
        task.wait(3600) 
    end
end)
