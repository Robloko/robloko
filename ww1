-- Safe Remote Call
local function safeRemoteCall(remotePath, method, ...)
    local remote = ReplicatedStorage:FindFirstChild("API")
    for _, path in ipairs(remotePath) do
        remote = remote and remote:FindFirstChild(path)
    end
    if not remote then return false end
    local success, result = pcall(function()
        return method == "InvokeServer" and remote:InvokeServer(...) or remote:FireServer(...)
    end)
    return success, result
end

-- Get Player Data
local function getPlayerData()
    local success, clientData = pcall(require, ReplicatedStorage.ClientModules.Core.ClientData)
    if not success or not clientData then return nil end
    local success2, allData = pcall(clientData.get_data, clientData)
    return success2 and allData and allData[player.Name] or nil
end

-- Check if Pet is Equipped
local function isPetEquipped(petUniqueID)
    local data = getPlayerData()
    if not data or not data.equip_manager or not data.equip_manager.pets then return false end
    for _, equippedPet in pairs(data.equip_manager.pets) do
        if equippedPet and equippedPet.unique == petUniqueID then return true end
    end
    return false
end

-- Find Furniture
local function findFurnitureByName(name)
    local hi = Workspace:FindFirstChild("HouseInteriors")
    if hi then
        for _, folder in ipairs(hi:GetChildren()) do
            if string.find(folder.Name, player.Name) or string.find(folder.Name, "f%-%d+") then
                local model = folder:FindFirstChild(name)
                if model and model:IsA("Model") then return model end
            end
        end
    end
    return nil
end

-- Buy Missing Furniture
local function buyFurniture(furnitureName)
    debugPrint("Buying missing furniture: " .. furnitureName)
    return safeRemoteCall({"ShopAPI/BuyItem"}, "InvokeServer", "furniture", furnitureName, {buy_count = 1})
end

-- Use Furniture
local function useFurnitureWithPet(furnitureName)
    local furniture = findFurnitureByName(furnitureName)
    if not furniture then
        debugPrint("Furniture not found, buying: " .. furnitureName)
        buyFurniture(furnitureName)
        task.wait(2)
        furniture = findFurnitureByName(furnitureName)
        if not furniture then return false end
    end
    -- Simplified activation logic
    debugPrint("Using furniture: " .. furnitureName)
    task.wait(20)
    return true
end

-- ==================================================================
-- MYSTERY AILMENT HANDLER
-- ==================================================================

local function resolveMysteryAilment(ailmentId)
    debugPrint("Resolving mystery ailment...")
    local tasks = {"bored", "sick", "pet me", "sleepy", "dirty", "toilet", "hungry", "thirsty", "walk", "ride"}
    for _, chosenAilment in ipairs(tasks) do
        for level = 1, 3 do
            local success, _ = safeRemoteCall({"AilmentsAPI/ChooseMysteryAilment"}, "FireServer", ailmentId, "mystery", level, chosenAilment)
            if success then debugPrint("Resolved level " .. level .. " as " .. chosenAilment) end
            task.wait(1)
        end
    end
    return true
end

