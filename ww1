    frame.Parent = screenGui

    -- Pet dropdown
    local petsDropdown = Instance.new("TextButton")
    petsDropdown.Size = UDim2.new(0, 200, 0, 30)
    petsDropdown.Position = UDim2.new(0, 10, 0, 10)
    petsDropdown.Text = "Select Pet"
    petsDropdown.Parent = frame

    -- Toggle buttons
    local petFarmButton = Instance.new("TextButton")
    petFarmButton.Size = UDim2.new(0, 200, 0, 30)
    petFarmButton.Position = UDim2.new(0, 10, 0, 50)
    petFarmButton.Text = "Toggle PetFarm"
    petFarmButton.Parent = frame

    local petPenButton = Instance.new("TextButton")
    petPenButton.Size = UDim2.new(0, 200, 0, 30)
    petPenButton.Position = UDim2.new(0, 10, 0, 90)
    petPenButton.Text = "Toggle Auto PetPen"
    petPenButton.Parent = frame

    -- Connect buttons
    petFarmButton.MouseButton1Click:Connect(function()
        PetFarmMode = not PetFarmMode
        petFarmButton.Text = PetFarmMode and "Stop PetFarm" or "Start PetFarm"
        if PetFarmMode then monitorAndHandleAilments() end
    end)

    petPenButton.MouseButton1Click:Connect(function()
        AutoPetPenMode = not AutoPetPenMode
        petPenButton.Text = AutoPetPenMode and "Stop Auto PetPen" or "Start Auto PetPen"
        if AutoPetPenMode then startAutoPetPen() end
    end)

    return {frame = frame}
end

