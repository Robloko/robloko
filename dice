local player = game.Players.LocalPlayer
local inventory = -- Replace this with the actual inventory container, e.g., player:FindFirstChild("Inventory") or similar

-- Example: If dice are stored in ReplicatedStorage under a specific folder
local diceContainer = game:GetService("ReplicatedStorage"):FindFirstChild("dice") or
                      game:GetService("ReplicatedStorage"):FindFirstChild("caramel")

local diceCount = 0

-- Function to check if an item is a dice (by name)
local function isDice(item)
    return item.Name:lower():find("dice")
end

-- Iterate through the container and count dice
if diceContainer then
    for _, item in ipairs(diceContainer:GetChildren()) do
        if isDice(item) then
            diceCount = diceCount + 1
        end
    end
end

print("Number of dice found:", diceCount)
