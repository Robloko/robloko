-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Player
local player = Players.LocalPlayer

-- Function to inspect all inventory items
local function inspectInventory()
    print("🔍 INSPECTING FULL INVENTORY")
    print("============================")

    local success, data = pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        return clientData.get_data()[player.Name]
    end)

    if not success or not data then
        print("❌ Failed to get player data")
        return
    end

    if not data.inventory then
        print("❌ No inventory found")
        return
    end

    -- Iterate through all inventory categories (e.g., pets, dice, etc.)
    for category, items in pairs(data.inventory) do
        print("📦 Category: " .. category)
        print("-----------------------------")

        local itemCount = 0
        for itemUniqueID, itemData in pairs(items) do
            itemCount = itemCount + 1
        end

        print("📊 Total " .. category .. ": " .. itemCount)
        print("")

        -- Show first 10 items in this category
        local count = 0
        for itemUniqueID, itemData in pairs(items) do
            count = count + 1
            if count > 10 then
                print("... and " .. (itemCount - 10) .. " more " .. category)
                break
            end

            print("🔹 " .. (itemData.id or "Unknown ID"))
            print("   Unique ID: " .. itemUniqueID)
            if itemData.properties then
                print("   Age: " .. (itemData.properties.age or "?"))
                print("   XP: " .. (itemData.properties.xp or "?"))
            end
            print("   ---")
        end
    end
end

-- Run the function
inspectInventory()
