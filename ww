-- Debug function
local function debugPrint(message)
    if DEBUG_MODE then
        print("[PetFarm] " .. os.date("%H:%M:%S") .. " " .. tostring(message))
    end
end

-- Safe Remote Call
local function safeRemoteCall(remotePath, method, ...)
    local args = {...}
    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("API")
    if not remote then
        debugPrint("API not found in ReplicatedStorage!")
        return false, "API not found"
    end

    for _, path in ipairs(remotePath) do
        remote = remote:FindFirstChild(path)
        if not remote then
            debugPrint("Remote path not found: " .. path)
            return false, "Remote path not found"
        end
    end

    if method == "InvokeServer" then
        local success, result = pcall(function()
            return remote:InvokeServer(unpack(args))
        end)
        if not success then
            debugPrint("InvokeServer error: " .. tostring(result))
        end
        return success, result
    elseif method == "FireServer" then
        local success, result = pcall(function()
            remote:FireServer(unpack(args))
        end)
        if not success then
            debugPrint("FireServer error: " .. tostring(result))
        end
        return success, result
    else
        return false, "Invalid method"
    end
end

-- Get player data safely
local function getPlayerData()
    local success, clientData = pcall(require, ReplicatedStorage.ClientModules.Core.ClientData)
    if not success or not clientData then
        debugPrint("Failed to require ClientData!")
        return nil
    end
    local success2, allData = pcall(clientData.get_data, clientData)
    if not success2 or not allData or not allData[player.Name] then
        debugPrint("Failed to get player data!")
        return nil
    end
    return allData[player.Name]
end

-- Get current money and potions
local function getCurrentMoneyAndPotions()
    local playerData = getPlayerData()
    if not playerData then
        return 0, 0
    end
    local money = playerData.money or 0
    local potions = 0
    if playerData.inventory and playerData.inventory.food then
        for _, foodData in pairs(playerData.inventory.food) do
            if foodData.id and string.find(string.lower(foodData.id), "potion") then
                potions = potions + (foodData.amount or 1)
            end
        end
    end
    return money, potions
end

-- Update session earnings
local function updateSessionEarnings()
    local currentMoney, currentPotions = getCurrentMoneyAndPotions()
    if lastMoneyAmount == 0 then
        lastMoneyAmount = currentMoney
    end
    if lastPotionAmount == 0 then
        lastPotionAmount = currentPotions
    end
    sessionBucksEarned = currentMoney - lastMoneyAmount
    sessionPotionsEarned = currentPotions - lastPotionAmount
    return currentMoney, currentPotions
end

-- Check if pet is equipped
local function isPetEquipped(petUniqueID)
    local playerData = getPlayerData()
    if not playerData or not playerData.equip_manager or not playerData.equip_manager.pets then
        debugPrint("Cannot check equip status: equip_manager not found")
        return false
    end
    for _, equippedPet in pairs(playerData.equip_manager.pets) do
        if equippedPet and equippedPet.unique == petUniqueID then
            return true
        end
    end
    return false
end

-- Equip pet safely
local function equipPet(petUniqueID)
    if not petUniqueID then
        debugPrint("Cannot equip pet: petUniqueID is nil!")
        return false
    end

    debugPrint("Attempting to equip pet with ID: " .. tostring(petUniqueID))

    local args = {
        petUniqueID,
        {
            use_sound_delay = true,
            equip_as_last = false
        }
    }

    local success, result = safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", unpack(args))

    if not success then
        debugPrint("Failed to equip pet: " .. tostring(result))
        return false
    end

    debugPrint("Successfully equipped pet: " .. tostring(petUniqueID))
    return true
end

-- Find Dog or Cat in workspace (by name)
local function findDogOrCatInWorkspace()
    local petsFolder = workspace:FindFirstChild("Pets")
    if petsFolder then
        for _, pet in ipairs(petsFolder:GetChildren()) do
            if pet:IsA("Model") then
                local petName = pet.Name
                if petName == "Dog" or petName == "Cat" then
                    debugPrint("✅ Found in workspace: " .. petName)
                    return pet
                end
            end
        end
    end
    
    -- Also search entire workspace
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local petName = obj.Name
            if petName == "Dog" or petName == "Cat" then
                debugPrint("✅ Found in workspace: " .. petName .. " at " .. obj:GetFullName())
                return obj
            end
        end
    end
    
    return nil
end

-- Wait for Dog/Cat to appear in workspace
local function waitForDogOrCatInWorkspace(timeout)
    timeout = timeout or 20
    local startTime = os.time()
    
    debugPrint("Waiting for Dog or Cat to appear in Workspace.Pets...")
    
    while os.time() - startTime < timeout do
        local pet = findDogOrCatInWorkspace()
        if pet then
            debugPrint("✅ Dog/Cat appeared after " .. (os.time() - startTime) .. " seconds!")
            return pet
        end
        
        if (os.time() - startTime) % 5 == 0 and (os.time() - startTime) > 0 then
            local petsFolder = workspace:FindFirstChild("Pets")
            if petsFolder then
                local petNames = {}
                for _, p in ipairs(petsFolder:GetChildren()) do
                    table.insert(petNames, p.Name)
                end
                debugPrint("Current pets in workspace: " .. table.concat(petNames, ", "))
            end
        end
        
        task.wait(1)
    end
    
    debugPrint("❌ Dog/Cat did not appear within " .. timeout .. " seconds!")
    return nil
end

-- Find Dog or Cat pet in inventory
local function findDogOrCatInInventory()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        debugPrint("No pets found in inventory!")
        return nil
    end

    -- First try to find Dog
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id then
            local petName = string.lower(petData.id)
            if petName == "dog" or string.find(petName, "dog") then
                debugPrint("Found DOG in inventory: " .. petData.id .. " (ID: " .. uniqueId .. ")")
                currentPetName = petData.id
                return uniqueId, petData.id
            end
        end
    end
    
    -- Then try to find Cat
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id then
            local petName = string.lower(petData.id)
            if petName == "cat" or string.find(petName, "cat") then
                debugPrint("Found CAT in inventory: " .. petData.id .. " (ID: " .. uniqueId .. ")")
                currentPetName = petData.id
                return uniqueId, petData.id
            end
        end
    end

    -- If no Dog or Cat found, use first available pet
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id then
            debugPrint("No Dog/Cat found, using: " .. petData.id)
            currentPetName = petData.id
            return uniqueId, petData.id
        end
    end

    debugPrint("No pets found in inventory!")
    return nil
end

-- Ensure Dog/Cat is equipped and present
local function ensureDogOrCatEquipped(timeout)
    timeout = timeout or 20
    
    -- Find Dog or Cat in inventory
    local petID, petName = findDogOrCatInInventory()
    if not petID then
        debugPrint("❌ No Dog or Cat found in inventory!")
        return false
    end
    
    debugPrint("Found pet: " .. petName .. " (ID: " .. petID .. ")")
    petFarmPetID = petID
    lastValidPetID = petID

    -- Check if already equipped
    if not isPetEquipped(petID) then
        debugPrint("Equipping " .. petName .. "...")
        local success = equipPet(petID)
        if not success then
            debugPrint("❌ Failed to equip pet!")
            return false
        end
        task.wait(3)
    else
        debugPrint("✅ " .. petName .. " is already equipped!")
    end
    
    -- Wait for Dog/Cat to appear in workspace
    local petObject = waitForDogOrCatInWorkspace(timeout)
    if petObject then
        debugPrint("✅ " .. petName .. " is now in workspace and ready!")
        return true
    else
        debugPrint("⚠️ " .. petName .. " equipped but not found in workspace!")
        debugPrint("Continuing anyway...")
        return true
    end
end

-- Get all pet IDs from inventory
local function getAllPetIDsFromInventory()
    local neonAged6 = {}
    local neonUnder6 = {}
    local others = {}

    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        debugPrint("No pets found in inventory!")
        return {}
    end

    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if not petData or not petData.id or not petData.properties then
            continue
        end

        local petName = string.lower(petData.id)
        if string.find(petName, "practice_dog") or string.find(petName, "dog") or string.find(petName, "cat") then
            continue
        end

        if petData.properties.neon and (petData.properties.age or 0) == 6 then
            table.insert(neonAged6, uniqueId)
        elseif petData.properties.neon and (petData.properties.age or 0) < 6 then
            table.insert(neonUnder6, uniqueId)
        else
            table.insert(others, uniqueId)
        end
    end

    local allPets = {}
    for _, petID in ipairs(neonAged6) do
        table.insert(allPets, petID)
    end
    for _, petID in ipairs(neonUnder6) do
        table.insert(allPets, petID)
    end
    for _, petID in ipairs(others) do
        table.insert(allPets, petID)
    end

    return allPets
end

-- Add all pets to trade
local function addAllPetsToTrade()
    local petIDs = getAllPetIDsFromInventory()
    if #petIDs == 0 then
        debugPrint("No pets found to add to trade")
