-- Debug function
local function debugPrint(message)
    if not DEBUG_MODE then return end
    local timestamp = os.date("[%H:%M:%S]")
    print(timestamp .. " " .. message)
end

-- Safe pcall wrapper
local function safeCall(func, ...)
    local args = {...}
    local success, result = pcall(function() return func(unpack(args)) end)
    if not success then
        debugPrint("Error in safeCall: " .. tostring(result))
    end
    return success, result
end

-- Safe Remote Call
local function safeRemoteCall(remotePath, method, ...)
    local args = {...}
    local remote = ReplicatedStorage:FindFirstChild("API", true)
    if not remote then
        debugPrint("API not found!")
        return false, "API not found"
    end
    for _, path in ipairs(remotePath:split("/")) do
        remote = remote:FindFirstChild(path)
        if not remote then
            debugPrint("Remote path not found: " .. path)
            return false, "Remote path not found"
        end
    end
    if method == "FireServer" then
        return safeCall(function() remote:FireServer(unpack(args)) end)
    elseif method == "InvokeServer" then
        return safeCall(function() return remote:InvokeServer(unpack(args)) end)
    else
        return false, "Invalid method"
    end
end

