        if not PetID then
            AutoPotionMode = false
            break
        end
        
        local playerData = getPlayerData()
        if not playerData then
            AutoPotionMode = false
            break
        end
        
        local currentPetAge = 0
        for _, petData in pairs(playerData.inventory.pets) do
            if petData.unique == PetID then
                currentPetAge = petData.properties.age or 0
