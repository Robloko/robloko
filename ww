    if char and char.Parent and char:FindFirstChild("HumanoidRootPart") then
        return char
    end
    debugPrint("Respawning character...")
    safeRemoteCall({"TeamAPI/Spawn"}, "InvokeServer")
    task.wait(5)
    return player.Character
end

-- Find player's pet in workspace
local function findPlayerPetInWorkspace()
    local petsFolder = workspace:FindFirstChild("Pets")
    if not petsFolder then
        return nil
    end
    
    for _, pet in ipairs(petsFolder:GetChildren()) do
        if pet:IsA("Model") then
            -- Check by Owner attribute
            local owner = pet:FindFirstChild("Owner")
            if owner and owner.Value == player then
                return pet
            end
            -- Check by name match (Dog or Cat)
            local petName = pet.Name
            if petName == "Dog" or petName == "Cat" then
                return pet
            end
        end
    end
    return nil
end

