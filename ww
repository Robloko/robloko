-- TRADING FUNCTIONS
-- ==================================================================

local function getAllPetIDsFromInventory()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return {}
    end
    
    local allPets = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id then
            local petName = string.lower(petData.id)
            -- Exclude practice_dog from trading too
            if not string.find(petName, "practice_dog") then
                table.insert(allPets, uniqueId)
            end
        end
    end
    return allPets
end

local function addAllPetsToTrade()
    local petIDs = getAllPetIDsFromInventory()
    if #petIDs == 0 then
        debugPrint("No pets to add")
        return
    end
    
    local maxPets = math.min(#petIDs, 18)
    debugPrint("Adding " .. maxPets .. " pets")
    
    for i = 1, maxPets do
        safeRemoteCall({"TradeAPI/AddItemToOffer"}, "FireServer", petIDs[i])
        task.wait(0.2)
    end
end

local function sendTradeRequest(targetPlayerName)
    if targetPlayerName == "" then
        return
    end
    
    local targetPlayer = Players:FindFirstChild(targetPlayerName)
    if not targetPlayer then
        debugPrint("Player not found")
        return
    end
    
    safeRemoteCall({"TradeAPI/SendTradeRequest"}, "FireServer", targetPlayer)
end

local function acceptAndConfirmTrade(targetPlayer)
    local success = safeRemoteCall({"TradeAPI/AcceptOrDeclineTradeRequest"}, "InvokeServer", targetPlayer, true)
    if success then
        task.wait(5)
        safeRemoteCall({"TradeAPI/AcceptNegotiation"}, "FireServer")
        task.wait(9)
        safeRemoteCall({"TradeAPI/ConfirmTrade"}, "FireServer")
        return true
    end
    return false
end

local function scanAndAcceptAllTrades()
    for _, targetPlayer in ipairs(Players:GetPlayers()) do
        if targetPlayer ~= player and AutoAcceptMode then
            acceptAndConfirmTrade(targetPlayer)
            task.wait(0.1)
        end
    end
end

local function startAutoAcceptTrades()
    while AutoAcceptMode do
        scanAndAcceptAllTrades()
        task.wait(9)
    end
end

local function toggleAutoAcceptMode()
    AutoAcceptMode = not AutoAcceptMode
    if AutoAcceptMode then
        debugPrint("Auto Accept: ENABLED")
        autoAcceptCoroutine = coroutine.wrap(startAutoAcceptTrades)()
    else
        debugPrint("Auto Accept: DISABLED")
        autoAcceptCoroutine = nil
    end
end

