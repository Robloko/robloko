end

-- Safe Remote Call
local function safeRemoteCall(remotePath, method, ...)
    local args = {...}
    local remote = ReplicatedStorage:FindFirstChild("API")
    if not remote then
        debugPrint("API not found in ReplicatedStorage!")
        return false, "API not found"
    end
    for _, path in ipairs(remotePath:split("/")) do
        remote = remote:FindFirstChild(path)
        if not remote then
            debugPrint("Remote path not found: " .. path)
            return false, "Remote path not found"
        end
    end
    if method == "FireServer" then
        local success, result = pcall(function() remote:FireServer(unpack(args)) end)
        if not success then debugPrint("FireServer error: " .. tostring(result)) end
        return success, result
    elseif method == "InvokeServer" then
        local success, result = pcall(function() return remote:InvokeServer(unpack(args)) end)
        if not success then debugPrint("InvokeServer error: " .. tostring(result)) end
        return success, result
    else
        return false, "Invalid method"
    end
end

-- Get player data safely
local function getPlayerData()
    local success, clientData = pcall(require, ReplicatedStorage.ClientModules.Core.ClientData)
    if not success or not clientData then
        debugPrint("Failed to require ClientData!")
        return nil
    end
    local success2, allData = pcall(clientData.get_data, clientData)
    if not success2 or not allData or not allData[player.Name] then
        debugPrint("Failed to get player data!")
        return nil
    end
    return allData[player.Name]
end

-- Get current money and potions
local function getCurrentMoneyAndPotions()
    local playerData = getPlayerData()
    if not playerData then return 0, 0 end
    local money = playerData.money or 0
    local potions = 0
    if playerData.inventory and playerData.inventory.food then
        for _, foodData in pairs(playerData.inventory.food) do
            if foodData.id and string.find(string.lower(foodData.id), "potion") then
                potions = potions + (foodData.amount or 1)
            end
        end
    end
    return money, potions
end

-- Update session earnings
local function updateSessionEarnings()
    local currentMoney, currentPotions = getCurrentMoneyAndPotions()
    if lastMoneyAmount == 0 then lastMoneyAmount = currentMoney end
    if lastPotionAmount == 0 then lastPotionAmount = currentPotions end
    sessionBucksEarned = currentMoney - lastMoneyAmount
    sessionPotionsEarned = currentPotions - lastPotionAmount
    return currentMoney, currentPotions
end

-- Check if pet is equipped
local function isPetEquipped(petUniqueID)
    local playerData = getPlayerData()
    if not playerData or not playerData.equip_manager or not playerData.equip_manager.pets then
        debugPrint("Cannot check equip status: equip_manager not found")
        return false
    end
    for _, equippedPet in pairs(playerData.equip_manager.pets) do
        if equippedPet and equippedPet.unique == petUniqueID then
            return true
        end
    end
    return false
end

-- Equip pet safely
local function equipPet(petUniqueID)
    if not petUniqueID then return false end
    local success, result = safeRemoteCall({"ToolAPI", "Equip"}, "InvokeServer", petUniqueID, {
        use_sound_delay = true,
        equip_as_last = false
    })
    if not success then
        debugPrint("Failed to equip pet: " .. tostring(result))
        return false
    end
    return true
end

-- Ensure pet is equipped
local function ensurePetEquipped(petUniqueID, timeout)
    timeout = timeout or 15
    if not petUniqueID then return false end
    if isPetEquipped(petUniqueID) then return true end
    local success = equipPet(petUniqueID)
    if not success then return false end
    local startTime = os.time()
    while os.time() - startTime < timeout do
        if isPetEquipped(petUniqueID) then
            return true
        end
        task.wait(0.5)
    end
    return false
end

-- Update pets dropdown
local function updatePetsDropdown(dropdownFrame, dropdownButton, dropdownListFrame)
    local List = {}
    local currentSelection = dropdownButton.Text
    local wasSelected = false
    local previousPetsShow = PetsShow
    PetsShow = {}

    -- Clear existing dropdown options
    for _, child in ipairs(dropdownListFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    -- Get pets data
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        debugPrint("No pets found in inventory!")
        dropdownButton.Text = "No Pets Found"
        return
    end

    -- Build pets list
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and petData.properties then
            local petName = tostring(petData.id)
            local petAge = petData.properties.age or 0
            local neonStatus = petData.properties.neon and " (Neon)" or ""
            local key = string.format("%s (Age: %d)%s", petName, petAge, neonStatus)
            PetsShow[key] = {
                unique = uniqueId,
                id = petData.id,
                properties = petData.properties
            }
            table.insert(List, key)
            if key == currentSelection then wasSelected = true end
        end
    end

    -- Sort list
    table.sort(List)

    -- Update dropdown button text
    if #List > 0 then
        dropdownButton.Text = wasSelected and currentSelection or ("Select a Pet (" .. #List .. ")")
    else
        dropdownButton.Text = "No Pets Found"
    end

    -- Create dropdown options
    for i, petKey in ipairs(List) do
        local optionButton = Instance.new("TextButton")
        optionButton.Size = UDim2.new(1, 0, 0, 20)
        optionButton.Position = UDim2.new(0, 0, 0, (i-1)*20)
        optionButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        optionButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        optionButton.Text = petKey
        optionButton.Font = Enum.Font.SourceSans
        optionButton.TextSize = 12
        optionButton.Parent = dropdownListFrame

        optionButton.MouseButton1Click:Connect(function()
            dropdownButton.Text = petKey
            dropdownListFrame.Visible = false
            local selectedPet = PetsShow[petKey]
            if selectedPet then
                petFarmPetID = selectedPet.unique
                lastValidPetID = selectedPet.unique
                debugPrint("Selected pet: " .. petKey)
                equipPet(selectedPet.unique)
            end
        end)
    end

    -- Update canvas size
    dropdownListFrame.CanvasSize = UDim2.new(0, 0, 0, #List * 20)
end

