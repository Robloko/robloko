local function getPetPenSnapshot()
    local playerData = getPlayerData()
    if not playerData or not playerData.idle_progression_manager or not playerData.idle_progression_manager.active_pets then
        return {}
    end
    
    local snapshot = {}
    for uniqueId, _ in pairs(playerData.idle_progression_manager.active_pets) do
        local pet = playerData.inventory.pets[uniqueId]
        if pet then
            table.insert(snapshot, {
                name = pet.id,
                age = pet.properties.age or 0,
                neon = pet.properties.neon or false,
                unique_id = uniqueId
            })
        end
    end
    return snapshot
end

local function purgeNonPriorityGarbage()
    debugPrint("Purging PetPen garbage...")
    local playerData = getPlayerData()
    if not playerData or not playerData.idle_progression_manager or not playerData.idle_progression_manager.active_pets then
        return 0
    end
    
    local removed = 0
    for uniqueId, _ in pairs(playerData.idle_progression_manager.active_pets) do
        local pet = playerData.inventory.pets[uniqueId]
        if pet and pet.id and pet.properties then
            local cleanName = string.lower(pet.id)
            local isNeon = pet.properties.neon
            if not isNeon and not prioritySet[cleanName] then
                debugPrint("Removing: " .. pet.id)
                safeRemoteCall({"IdleProgressionAPI/RemovePet"}, "FireServer", uniqueId)
                removed = removed + 1
                task.wait(0.7)
            end
        end
    end
    return removed
end

local function addPriorityPets(snapshot)
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return 0
    end
    
    local slotsOpen = 4 - #snapshot
    if slotsOpen <= 0 then
        return 0
    end
    
    local added = 0
    local addedSet = {}
    
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData.properties.neon and added < slotsOpen and not addedSet[uniqueId] then
            safeRemoteCall({"IdleProgressionAPI/AddPet"}, "FireServer", uniqueId)
            debugPrint("Added NEON: " .. petData.id)
            added = added + 1
            addedSet[uniqueId] = true
            task.wait(0.6)
        end
    end
    
    for _, eggName in ipairs(priorityEggs) do
        for uniqueId, petData in pairs(playerData.inventory.pets) do
            if petData.id == eggName and added < slotsOpen and not addedSet[uniqueId] then
                safeRemoteCall({"IdleProgressionAPI/AddPet"}, "FireServer", uniqueId)
                debugPrint("Added PRIORITY: " .. petData.id)
                added = added + 1
                addedSet[uniqueId] = true
                task.wait(0.6)
            end
        end
    end
    
    return added
end

local function startAutoPetPen()
    while AutoPetPenMode do
        debugPrint("=== AUTO PETPEN CYCLE ===")
        
        purgeNonPriorityGarbage()
        local snapshot = getPetPenSnapshot()
        
        for _, pet in ipairs(snapshot) do
            if pet.age >= 6 then
                debugPrint("Removing aged: " .. pet.name)
                safeRemoteCall({"IdleProgressionAPI/RemovePet"}, "FireServer", pet.unique_id)
                task.wait(0.7)
            end
        end
        
        task.wait(2)
        snapshot = getPetPenSnapshot()
        addPriorityPets(snapshot)
        
        if os.time() - lastPetPenCommitTime >= 300 then
            safeRemoteCall({"IdleProgressionAPI/CommitAllProgression"}, "FireServer")
            debugPrint("Committed rewards")
            lastPetPenCommitTime = os.time()
        end
        
        task.wait(60)
    end
end

local function toggleAutoPetPenMode()
    AutoPetPenMode = not AutoPetPenMode
    if AutoPetPenMode then
        debugPrint("Auto PetPen: ENABLED")
        lastPetPenCommitTime = os.time()
        autoPetPenCoroutine = coroutine.wrap(startAutoPetPen)()
    else
        debugPrint("Auto PetPen: DISABLED")
        autoPetPenCoroutine = nil
    end
end

