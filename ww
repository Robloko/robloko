local function updatePetsDropdown(dropdownButton, dropdownListFrame)
    -- Clear existing options
    for _, child in ipairs(dropdownListFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        dropdownButton.Text = "No Pets Found"
        return
    end
    
    local List = {}
    PetsShow = {}
    
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and petData.properties then
            local petName = string.lower(petData.id)
            -- EXCLUDE practice_dog from dropdown
            if not string.find(petName, "practice_dog") then
                local displayName = tostring(petData.id)
                local petAge = petData.properties.age or 0
                local neonStatus = petData.properties.neon and " 🔥NEON" or ""
                local key = string.format("%s (Age: %d)%s", displayName, petAge, neonStatus)
                
                PetsShow[key] = {
                    unique = uniqueId,
                    id = petData.id,
                    age = petAge,
                    neon = petData.properties.neon,
                    properties = petData.properties
                }
                table.insert(List, key)
            end
        end
    end
    
    table.sort(List)
    
    if #List > 0 then
        dropdownButton.Text = "Select a Pet (" .. #List .. ")"
    else
        dropdownButton.Text = "No Pets Found"
    end
    
    -- Create dropdown options
    for i, petKey in ipairs(List) do
