-- IMPROVED: Find furniture by name with better detection
local function findFurnitureByName(name)
    debugPrint("Searching for furniture: " .. name)
    local hi = workspace:FindFirstChild("HouseInteriors")
    if not hi then
        debugPrint("HouseInteriors not found!")
        return nil
    end
    
    -- Search through all house folders
    for _, folder in ipairs(hi:GetChildren()) do
        -- Check if this is YOUR house folder
        if string.find(folder.Name, player.Name) or string.find(folder.Name, "f%-%d+") then
            -- Search for the furniture model
            local model = folder:FindFirstChild(name)
            if model and model:IsA("Model") then
                debugPrint("✅ Found " .. name .. " in YOUR house: " .. folder.Name)
                return model
            end
            
            -- Also search case-insensitive
            for _, child in ipairs(folder:GetChildren()) do
                if child:IsA("Model") and string.lower(child.Name) == string.lower(name) then
                    debugPrint("✅ Found " .. child.Name .. " (case-insensitive) in YOUR house")
                    return child
                end
            end
        end
    end
    
    -- Fallback: Search entire workspace
    local model = workspace:FindFirstChild(name, true)
    if model and model:IsA("Model") then
        debugPrint("✅ Found " .. name .. " in workspace (fallback)")
        return model
    end
    
    debugPrint("❌ Furniture not found: " .. name)
    return nil
end

-- IMPROVED: Activate furniture with proper CFrame
local function activateFurniture(furnitureName, pet)
    local furnitureModel = findFurnitureByName(furnitureName)
    if not furnitureModel then
        debugPrint("❌ Cannot activate furniture: " .. furnitureName .. " - not found")
        return false
    end
    
    -- Get the furniture's CFrame
    local furnitureCFrame = furnitureModel:GetPivot()
    local folderName = furnitureModel.Parent.Name
    
    -- Find a usable part for activation
    local usePart = nil
    local useBlocks = furnitureModel:FindFirstChild("UseBlocks")
    if useBlocks then
        usePart = useBlocks:FindFirstChild("UseBlock") or useBlocks:FindFirstChild("Seat1")
    end
    if not usePart then
        usePart = furnitureModel:FindFirstChild("UseBlock") or furnitureModel:FindFirstChild("Seat1")
    end
    if not usePart then
        usePart = furnitureModel:FindFirstChildWhichIsA("BasePart")
    end
    
    local partName = usePart and usePart.Name or "UseBlock"
    local activationCFrame = usePart and usePart.CFrame or furnitureCFrame
    
    local args = {
        player,
        folderName,
        partName,
        {
            cframe = activationCFrame
        },
        pet
    }
    
    debugPrint("🎯 Activating " .. furnitureName .. " in folder: " .. folderName)
    local success, result = safeRemoteCall({"HousingAPI/ActivateFurniture"}, "InvokeServer", unpack(args))
    
    if success then
        debugPrint("✅ Successfully activated: " .. furnitureName)
        return true
    else
        debugPrint("❌ Failed to activate: " .. furnitureName .. " - " .. tostring(result))
        return false
    end
end

