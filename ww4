    safeRemoteCall({"PetObjectAPI/CreatePetObject"}, "InvokeServer", "__Enum_PetObjectCreatorType_2", {
        additional_consume_uniques = {}, pet_unique = PetID, unique_id = potionID
    })
    task.wait(2)
    safeRemoteCall({"ToolAPI/Unequip"}, "InvokeServer", potionID)
    return true
end

local function startAutoPotionFeeding()
    while AutoPotionMode do
        if not PetID then AutoPotionMode = false break end
        usePetAgePotion()
        task.wait(5)
    end
end

local function toggleAutoPotionMode()
    AutoPotionMode = not AutoPotionMode
    if AutoPotionMode then
        autoPotionCoroutine = coroutine.wrap(startAutoPotionFeeding)()
    end
end

