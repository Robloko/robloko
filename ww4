local function updatePetsDropdown(dropdownButton, dropdownListFrame)
    for _, child in ipairs(dropdownListFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end

    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        dropdownButton.Text = "No Pets Found"
        return
    end

    local List = {}
    PetsShow = {}

    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and petData.properties then
            local petName = string.lower(petData.id)
            if not string.find(petName, "practice_dog") then
                local displayName = tostring(petData.id)
                local petAge = petData.properties.age or 0
                local neonStatus = petData.properties.neon and " 🔥NEON" or ""
                
                local petType = "other"
                if string.find(petName, "starter_egg") then
                    petType = "starter_egg"
                elseif string.find(petName, "dog") then
                    petType = "dog"
                elseif string.find(petName, "cat") then
                    petType = "cat"
                end
                
                local typeIcon = getPetTypeIcon(petType)
                local key = string.format("%s %s (Age: %d)%s", typeIcon, displayName, petAge, neonStatus)

                PetsShow[key] = {
                    unique = uniqueId,
                    id = petData.id,
                    age = petAge,
                    neon = petData.properties.neon,
                    petType = petType
                }
                table.insert(List, key)
            end
        end
    end

    table.sort(List, function(a, b)
        local aData = PetsShow[a]
        local bData = PetsShow[b]
        if not aData or not bData then return false end
        
        local function getPriority(pet)
            if pet.petType == "starter_egg" then return 1 end
            if pet.petType == "dog" then return 2 end
            if pet.petType == "cat" then return 3 end
            return 4
        end
        
        local aP = getPriority(aData)
        local bP = getPriority(bData)
        
        if aP ~= bP then return aP < bP end
        return aData.age > bData.age
    end)

    if #List > 0 then
        -- Show current selection or total count
        if PetID and selectedPetName then
            local typeIcon = getPetTypeIcon(selectedPetType)
            dropdownButton.Text = typeIcon .. " " .. selectedPetName .. " (Age: " .. (PetsShow[List[1]] and PetsShow[List[1]].age or "?") .. ")"
        else
            dropdownButton.Text = "Select Pet (" .. #List .. " total)"
        end
    else
        dropdownButton.Text = "No Pets Found"
    end

    for i, petKey in ipairs(List) do
        local optionButton = Instance.new("TextButton")
        optionButton.Size = UDim2.new(1, 0, 0, 22)
        optionButton.Position = UDim2.new(0, 0, 0, (i - 1) * 22)
        
        local selectedPet = PetsShow[petKey]
        -- Highlight current selection
        if selectedPet and PetID and selectedPet.unique == PetID then
            optionButton.BackgroundColor3 = Color3.fromRGB(0, 100, 0) -- Green = currently selected
        elseif selectedPet and selectedPet.petType == "starter_egg" then
            optionButton.BackgroundColor3 = Color3.fromRGB(80, 60, 20) -- Gold = starter_egg
        else
            optionButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        end
        optionButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        optionButton.Text = petKey .. (selectedPet and PetID and selectedPet.unique == PetID and " ◄" or "")
        optionButton.Font = Enum.Font.SourceSans
        optionButton.TextSize = 11
        optionButton.TextXAlignment = Enum.TextXAlignment.Left
        optionButton.Parent = dropdownListFrame

        optionButton.MouseButton1Click:Connect(function()
            dropdownButton.Text = petKey
            dropdownListFrame.Visible = false
            local selectedPet = PetsShow[petKey]
            if selectedPet and selectedPet.unique then
                PetID = selectedPet.unique
                selectedPetName = selectedPet.id
                selectedPetType = selectedPet.petType
                selectedPetOriginalID = selectedPet.id
                debugPrint("Manually selected: " .. selectedPet.id .. " (Type: " .. selectedPet.petType .. ", Age: " .. selectedPet.age .. ")")
                equipSelectedPet(PetID)
                updateSelectedPetDisplay()
            end
        end)
    end

    dropdownListFrame.CanvasSize = UDim2.new(0, 0, 0, #List * 22)
end

