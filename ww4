    return safeRemoteCall({"ShopAPI/BuyItem"}, "InvokeServer", "food", "healing_apple", {buy_count = 1})
end

local function findHealingApple()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.food then
        return nil
    end
    for foodId, foodData in pairs(playerData.inventory.food) do
        if foodData.id and string.lower(foodData.id) == "healing_apple" then
            return foodId
        end
    end
    return nil
end

local function useHealingApple(foodID)
    if not foodID or not PetID then
        return false
    end

    debugPrint("Using healing apple...")

    safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", foodID, {
        use_sound_delay = true,
        equip_as_last = false
    })
    task.wait(2)

    safeRemoteCall({"ToolAPI/ServerUseTool"}, "FireServer", foodID, "START")
    task.wait(1)

    safeRemoteCall({"PetObjectAPI/CreatePetObject"}, "InvokeServer", "__Enum_PetObjectCreatorType_2", {
        additional_consume_uniques = {},
        pet_unique = PetID,
        unique_id = foodID
    })
    task.wait(9)

    safeRemoteCall({"ToolAPI/Unequip"}, "InvokeServer", foodID)
    return true
end

local function handleSickAilment()
    debugPrint("💊 SICK AILMENT DETECTED!")

    local healingAppleID = findHealingApple()
    if not healingAppleID then
        debugPrint("No healing apple, purchasing...")
        local success = buyHealingApple()
        if not success then
            return false
        end
        task.wait(2)
        healingAppleID = findHealingApple()
        if not healingAppleID then
            return false
        end
    end

    return useHealingApple(healingAppleID)
end

