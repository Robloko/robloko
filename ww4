-- INVENTORY MONITOR - Auto switch when pet hatched/traded
-- ==================================================================

local function clearPetSelection()
    PetID = nil
    selectedPetName = nil
    selectedPetType = nil
    currentSelectedPetKey = nil
    if ui and ui.petsDropdownButton then
        ui.petsDropdownButton.Text = "No Pets Found"
        ui.petsDropdownButton.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        ui.petsDropdownButton.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
    if ui and ui.statusLabel then
        ui.statusLabel.Text = "Status: ❌ No pets in inventory!"
        ui.statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
    PetFarmMode = false
    if ui and ui.petFarmButton then
        ui.petFarmButton.Text = "🥚 START PETFARM (Egg First!)"
        ui.petFarmButton.BackgroundColor3 = Color3.fromRGB(180, 140, 0)
        ui.petFarmButton.TextColor3 = Color3.fromRGB(0, 0, 0)
    end
end

local function monitorPetInventory()
    debugPrint("🔍 Inventory monitor started (checks every 5s)...")
    
    while true do
        task.wait(5)

        -- Case 1: We have a pet selected - check if it still exists
        if PetID then
            if not isPetStillInInventory(PetID) then
                local oldName = selectedPetName or "Unknown"
                local oldType = selectedPetType or "unknown"
                
                debugPrint("========================================")
                debugPrint("⚠️ PET REMOVED FROM INVENTORY!")
                debugPrint("   Old: " .. oldName .. " (Type: " .. oldType .. ")")
                debugPrint("========================================")

                -- Wait a moment for hatched pet to appear in inventory
                task.wait(3)

                -- Find next best pet
                local nextPet = findBestPet()

                if nextPet then
                    local icon = getPetTypeIcon(nextPet.petType)
                    debugPrint("🔄 Auto-switching to: " .. icon .. " " .. nextPet.id)
                    
                    selectPet(nextPet)
                    
                    if ui and ui.statusLabel then
                        ui.statusLabel.Text = "Status: 🔄 Switched - " .. icon .. " " .. nextPet.id
                        ui.statusLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
                    end

                    -- If PetFarm was running, keep it running with new pet
                    -- The ailment monitor already uses PetID which we just updated
                    debugPrint("✅ PetFarm continues with new pet!")
                else
                    debugPrint("❌ No pets left to auto-select!")
                    clearPetSelection()
                end
            end

        -- Case 2: No pet selected - try to find one (new pet from trade/hatch)
        else
            local nextPet = findBestPet()
            if nextPet then
                debugPrint("🆕 Found new pet in inventory: " .. nextPet.id)
                selectPet(nextPet)

                if ui and ui.statusLabel then
                    local icon = getPetTypeIcon(nextPet.petType)
                    ui.statusLabel.Text = "Status: 🆕 Found - " .. icon .. " " .. nextPet.id
                    ui.statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                end

                -- Auto-start PetFarm if not running
                if not PetFarmMode then
                    PetFarmMode = true
                    petFarmCoroutine = coroutine.wrap(startPetFarm)()
                    if ui and ui.petFarmButton then
                        ui.petFarmButton.Text = "🛑 STOP PETFARM"
                        ui.petFarmButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
                        ui.petFarmButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                    end
                end
            end
        end
    end
end

