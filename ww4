local function getPetTypeIcon(petType)
    if petType == "starter_egg" then return "🥚"
    elseif petType == "dog" then return "🐕"
    elseif petType == "cat" then return "🐈"
    else return "📦" end
end

local function detectPetType(petId)
    local name = string.lower(tostring(petId))
    if string.find(name, "starter_egg") then return "starter_egg"
    elseif string.find(name, "dog") then return "dog"
    elseif string.find(name, "cat") then return "cat"
    else return "other" end
end

local function buildPetKey(petId, petAge, isNeon)
    local petType = detectPetType(petId)
    local icon = getPetTypeIcon(petType)
    local neon = isNeon and " 🔥NEON" or ""
    return string.format("%s %s (Age: %d)%s", icon, petId, petAge, neon)
end

-- ==================================================================
-- INVENTORY CHECKS
-- ==================================================================

local function isPetStillInInventory(petUniqueID)
    if not petUniqueID then return false end
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then return false end
    return playerData.inventory.pets[petUniqueID] ~= nil
end

local function getAllValidPets()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then return {} end
    local validPets = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and petData.properties then
            local petName = string.lower(petData.id)
            if not string.find(petName, "practice_dog") then
                table.insert(validPets, {
                    unique = uniqueId,
                    id = petData.id,
                    age = petData.properties.age or 0,
                    neon = petData.properties.neon or false,
                    petType = detectPetType(petData.id)
                })
            end
        end
    end
    table.sort(validPets, function(a, b)
        local function p(t) if t == "starter_egg" then return 1 elseif t == "dog" then return 2 elseif t == "cat" then return 3 end return 4 end
        local ap, bp = p(a.petType), p(b.petType)
        if ap ~= bp then return ap < bp end
        return a.age > b.age
    end)
    return validPets
end

local function findBestPet()
    debugPrint("Searching for best pet (Starter_Egg > Dog > Cat)...")
    local validPets = getAllValidPets()
    local starterEggPet, dogPet, catPet = nil, nil, nil
    for _, pet in ipairs(validPets) do
        if pet.petType == "starter_egg" and (not starterEggPet or pet.age > starterEggPet.age) then starterEggPet = pet
        elseif pet.petType == "dog" and (not dogPet or pet.age > dogPet.age) then dogPet = pet
        elseif pet.petType == "cat" and (not catPet or pet.age > catPet.age) then catPet = pet end
    end
    local picked = starterEggPet or dogPet or catPet or validPets[1]
    if picked then
        debugPrint("Picked: " .. picked.id .. " (Age: " .. picked.age .. ", Type: " .. picked.petType .. ")")
    else
        debugPrint("No valid pets found!")
    end
    return picked
end

local function equipSelectedPet(petUniqueID)
    if not petUniqueID then return false end
    if isPetEquipped(petUniqueID) then return true end
    local success = safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", petUniqueID, { use_sound_delay = true, equip_as_last = false })
    if success then task.wait(3) end
    return success
end

