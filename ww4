local function extractFurnitureData(model, folderName)
    local activationParts = {"UseBlock", "Seat1"}
    local folderId = string.match(folderName, "f%-%d+") or folderName

    for _, partName in ipairs(activationParts) do
        local useBlocksFolder = model:FindFirstChild("UseBlocks")
        if useBlocksFolder then
            local part = useBlocksFolder:FindFirstChild(partName)
            if part and part:IsA("BasePart") then
                return {
                    folderId = folderId,
                    partName = partName,
                    position = part.Position,
                    cframe = part.CFrame,
                    model = model
                }
            end
        end

        local part = model:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            return {
                folderId = folderId,
                partName = partName,
                position = part.Position,
                cframe = part.CFrame,
                model = model
            }
        end
    end

    for _, part in ipairs(model:GetDescendants()) do
        if part:IsA("BasePart") then
            return {
                folderId = folderId,
                partName = part.Name,
                position = part.Position,
                cframe = part.CFrame,
                model = model
            }
        end
    end

    return nil
end

local function findFurnitureByName(name)
    local hi = workspace:FindFirstChild("HouseInteriors")
    if hi then
        for _, folder in ipairs(hi:GetChildren()) do
            if string.find(folder.Name, player.Name) or string.find(folder.Name, "f%-%d+") then
                local model = folder:FindFirstChild(name)
                if model and model:IsA("Model") then
                    return extractFurnitureData(model, folder.Name)
                end
            end
        end
    end

    local model = workspace:FindFirstChild(name, true)
    if model and model:IsA("Model") then
        local folderId = model.Parent and string.match(model.Parent.Name, "f%-%d+") or "unknown"
        return extractFurnitureData(model, folderId)
    end

    return nil
end

local function checkAndBuyFurniture(furnitureName)
    local buyInfo = FURNITURE_BUY_INFO[furnitureName]
    if not buyInfo then
        return false
    end

    local existingFurniture = findFurnitureByName(furnitureName)
    if existingFurniture then
        return true
    end

    debugPrint("⚠️ Furniture missing: " .. furnitureName .. " - Purchasing...")
    local args = {
        {
            {
                kind = buyInfo.kind,
                properties = {
                    cframe = buyInfo.cframe
                }
            }
        }
    }

    local success, result = pcall(function()
        return ReplicatedStorage:WaitForChild("API"):WaitForChild("HousingAPI/BuyFurnitures"):InvokeServer(unpack(args))
    end)

    if success then
        task.wait(3)
        local verifyFurniture = findFurnitureByName(furnitureName)
        if verifyFurniture then
            return true
        else
            for attempt = 1, 5 do
                task.wait(2)
                verifyFurniture = findFurnitureByName(furnitureName)
                if verifyFurniture then
                    return true
                end
            end
        end
    end
    return false
end

local function checkAndBuyAllMissingFurniture()
    debugPrint("Checking for ALL missing furniture...")
    local missingList = {}

    for furnitureName, buyInfo in pairs(FURNITURE_BUY_INFO) do
        local existing = findFurnitureByName(furnitureName)
        if not existing then
            table.insert(missingList, {
                kind = buyInfo.kind,
                properties = {
                    cframe = buyInfo.cframe
                }
            })
        end
    end

    if #missingList > 0 then
        safeRemoteCall({"HousingAPI/BuyFurnitures"}, "InvokeServer", missingList)
        task.wait(5)
    end
end

local function activateFurniture(furnitureName, pet)
    local furnitureData = findFurnitureByName(furnitureName)
    if not furnitureData then
        return false
    end

    local char = ensureCharacterSpawned()
    if not char then
        return false
    end

    local args = {
        player,
        furnitureData.folderId,
        furnitureData.partName,
        {
            cframe = furnitureData.cframe
        },
        pet
    }

    local success, result = safeRemoteCall({"HousingAPI/ActivateFurniture"}, "InvokeServer", unpack(args))
    return success
end

local function useFurnitureWithPet(furnitureName)
    local furnitureData = findFurnitureByName(furnitureName)
    if not furnitureData then
        local bought = checkAndBuyFurniture(furnitureName)
        if not bought then
            return false
        end
        furnitureData = findFurnitureByName(furnitureName)
        if not furnitureData then
            return false
        end
    end

    task.wait(1)

    local petObject = nil
    for attempt = 1, 5 do
        petObject = findPlayerPetInWorkspace()
        if petObject then
            break
        end
        task.wait(2)
    end

    if petObject then
        local success = activateFurniture(furnitureName, petObject)
        if success then
            task.wait(20)
            return true
        end
    end
    return false
end

