local function findPetAgePotion()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.food then
        return nil
    end

    for foodId, foodData in pairs(playerData.inventory.food) do
        if foodData.id and string.lower(foodData.id) == "pet_age_potion" then
            return foodId
        end
    end
    return nil
end

local function usePetAgePotion()
    if not PetID then
        return false
    end

    local playerData = getPlayerData()
    if not playerData then
        return false
    end

    local currentPetAge = 0
    for _, petData in pairs(playerData.inventory.pets) do
        if petData.unique == PetID then
            currentPetAge = petData.properties.age or 0
            break
        end
    end

    if currentPetAge >= 6 then
        return false
    end

    local potionID = findPetAgePotion()
    if not potionID then
        debugPrint("No pet_age_potion found")
        return false
    end

    debugPrint("Using pet_age_potion...")

    safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", potionID, {
        use_sound_delay = true,
        equip_as_last = false
    })
    task.wait(1)

    safeRemoteCall({"ToolAPI/ServerUseTool"}, "FireServer", potionID, "START")
    task.wait(1)

    safeRemoteCall({"PetObjectAPI/CreatePetObject"}, "InvokeServer", "__Enum_PetObjectCreatorType_2", {
        additional_consume_uniques = {},
        pet_unique = PetID,
        unique_id = potionID
    })
    task.wait(2)

    safeRemoteCall({"ToolAPI/Unequip"}, "InvokeServer", potionID)
    debugPrint("Successfully used pet_age_potion")
    return true
end

local function startAutoPotionFeeding()
    while AutoPotionMode do
        if not PetID then
            AutoPotionMode = false
            break
        end

        local playerData = getPlayerData()
        if not playerData then
            AutoPotionMode = false
            break
        end

        local currentPetAge = 0
        for _, petData in pairs(playerData.inventory.pets) do
            if petData.unique == PetID then
                currentPetAge = petData.properties.age or 0
                break
            end
        end

        if currentPetAge >= 6 then
            debugPrint("Pet reached age 6, stopping auto potion")
            AutoPotionMode = false
            break
        end

        usePetAgePotion()
        task.wait(5)
    end
end

local function toggleAutoPotionMode()
    AutoPotionMode = not AutoPotionMode
    if AutoPotionMode then
        debugPrint("Auto Potion: ENABLED")
        autoPotionCoroutine = coroutine.wrap(startAutoPotionFeeding)()
    else
        debugPrint("Auto Potion: DISABLED")
        autoPotionCoroutine = nil
    end
end

