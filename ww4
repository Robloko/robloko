local function getPetTypeIcon(petType)
    if petType == "starter_egg" then return "🥚"
    elseif petType == "dog" then return "🐕"
    elseif petType == "cat" then return "🐈"
    else return "📦" end
end

local function determinePetType(petId)
    local name = string.lower(petId or "")
    if string.find(name, "starter_egg") then return "starter_egg" end
    if string.find(name, "dog") then return "dog" end
    if string.find(name, "cat") then return "cat" end
    return "other"
end

local function getAllValidPets()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return {}
    end

    local validPets = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and petData.properties then
            local petName = string.lower(petData.id)
            if not string.find(petName, "practice_dog") then
                table.insert(validPets, {
                    unique = uniqueId,
                    id = petData.id,
                    age = petData.properties.age or 0,
                    neon = petData.properties.neon or false,
                    name = petData.id,
                    petType = determinePetType(petData.id)
                })
            end
        end
    end

    table.sort(validPets, function(a, b)
        local function getPriority(pet)
            if pet.petType == "starter_egg" then return 1 end
            if pet.petType == "dog" then return 2 end
            if pet.petType == "cat" then return 3 end
            return 4
        end
        
        local aP = getPriority(a)
        local bP = getPriority(b)
        
        if aP ~= bP then return aP < bP end
        return a.age > b.age
    end)

    return validPets
end

local function findStarterEggInInventory()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return nil
    end

    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and string.find(string.lower(petData.id), "starter_egg") then
            return {
                unique = uniqueId,
                id = petData.id,
                age = petData.properties.age or 0,
                neon = petData.properties.neon or false,
                petType = "starter_egg"
            }
        end
    end
    return nil
end

local function findBestPet()
    debugPrint("========================================")
    debugPrint("🔍 SEARCHING FOR BEST PET")
    debugPrint("🥚 Priority 1: Starter Egg")
    debugPrint("🐕 Priority 2: Dog (no practice_dog)")
    debugPrint("🐈 Priority 3: Cat")
    debugPrint("========================================")

    local validPets = getAllValidPets()

    local starterEggPet = nil
    local dogPet = nil
    local catPet = nil

    for _, pet in ipairs(validPets) do
        if pet.petType == "starter_egg" then
            if not starterEggPet or pet.age > starterEggPet.age then
                starterEggPet = pet
            end
            debugPrint("🥚 Found: " .. pet.id .. " (Age: " .. pet.age .. ")")
        elseif pet.petType == "dog" then
            if not dogPet or pet.age > dogPet.age then
                dogPet = pet
            end
            debugPrint("🐕 Found: " .. pet.id .. " (Age: " .. pet.age .. ")")
        elseif pet.petType == "cat" then
            if not catPet or pet.age > catPet.age then
                catPet = pet
            end
            debugPrint("🐈 Found: " .. pet.id .. " (Age: " .. pet.age .. ")")
        end
    end

    local selectedPet = starterEggPet or dogPet or catPet or validPets[1]

    if selectedPet then
        debugPrint("========================================")
        debugPrint("✅ SELECTED: " .. getPetTypeIcon(selectedPet.petType) .. " " .. selectedPet.id)
        debugPrint("   ID: " .. selectedPet.unique)
        debugPrint("   Age: " .. selectedPet.age)
        debugPrint("========================================")
    else
        debugPrint("❌ No valid pets found!")
    end

    return selectedPet
end

local function equipSelectedPet(petUniqueID)
    if not petUniqueID then
        return false
    end

    if isPetEquipped(petUniqueID) then
        return true
    end

    local success, err = safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", petUniqueID, {
        use_sound_delay = true,
        equip_as_last = false
    })

    if success then
        task.wait(3)
        return true
    else
