-- MYSTERY AILMENT (BRUTE-FORCE)
-- ==================================================================

local function resolveMysteryAilment()
    debugPrint("========================================")
    debugPrint("❓ MYSTERY AILMENT DETECTED!")
    debugPrint("========================================")

    local petUniqueID = getEquippedPetID()
    if not petUniqueID then
        debugPrint("❌ No equipped pet found!")
        return false
    end

    debugPrint("Equipped Pet ID: " .. petUniqueID)

    local allAilmentTypes = {
        "sleepy", "hungry", "thirsty", "dirty", "bored",
        "toilet", "play", "walk", "ride", "sick", "pet_me"
    }

    local remote = ReplicatedStorage:FindFirstChild("API")
    if not remote then
        debugPrint("❌ API not found!")
        return false
    end
    remote = remote:FindFirstChild("AilmentsAPI/ChooseMysteryAilment")
    if not remote then
        debugPrint("❌ ChooseMysteryAilment remote not found!")
        return false
    end

    for level = 1, 3 do
        debugPrint("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
        debugPrint("LEVEL " .. level .. " - Trying all " .. #allAilmentTypes .. " ailments...")
        debugPrint("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

        for i, ailmentType in ipairs(allAilmentTypes) do
            if not PetFarmMode then
                debugPrint("PetFarm stopped, aborting mystery resolution")
                return false
            end

            debugPrint("[" .. level .. "/" .. 3 .. "] [" .. i .. "/" .. #allAilmentTypes .. "] Trying: " .. ailmentType)

            local args = {
                petUniqueID,
                "mystery",
                level,
                ailmentType
            }

            local success, err = pcall(function()
                remote:FireServer(unpack(args))
            end)

            if success then
                debugPrint("  ✅ Fired: " .. ailmentType)
            else
                debugPrint("  ❌ Failed: " .. ailmentType .. " - " .. tostring(err))
            end

            task.wait(2)
        end

        debugPrint("Level " .. level .. " complete!")
    end

    debugPrint("========================================")
    debugPrint("✅ MYSTERY BRUTE-FORCE COMPLETE!")
    debugPrint("========================================")
    
    return true
end

