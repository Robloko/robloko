-- ==================================================================
-- AUTO START
-- ==================================================================
local function autoStart()
    debugPrint("Auto-starting...")
    if ui then ui.statusLabel.Text = "Status: Checking furniture..." end

    checkAndBuyAllMissingFurniture()

    if ui then ui.statusLabel.Text = "Status: Searching for pet..." end
    task.wait(2)

    local selectedPet = findBestPet()
    if not selectedPet then
        if ui then
            ui.statusLabel.Text = "Status: ❌ No pets found!"
            ui.statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
        return
    end

    PetID = selectedPet.unique
    selectedPetName = selectedPet.id
    selectedPetType = selectedPet.petType
    selectedPetOriginalID = selectedPet.id

    if ui then ui.statusLabel.Text = "Status: Equipping..." end

    if equipSelectedPet(selectedPet.unique) then
        updateSelectedPetDisplay()

        if not AutoPetPenMode then
            toggleAutoPetPenMode()
            if ui and ui.autoPetPenButton then
                ui.autoPetPenButton.Text = "Auto PetPen [ON]"
                ui.autoPetPenButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
            end
        end

        if not PetFarmMode then
            togglePetFarmMode()
            if ui and ui.petFarmButton then
                ui.petFarmButton.Text = "🛑 STOP PETFARM"
                ui.petFarmButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
                ui.petFarmButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end

        updateSelectedPetDisplay()
        debugPrint("✅ PetFarm running: " .. selectedPet.id)
    else
        if ui then
            ui.statusLabel.Text = "Status: ❌ Failed to equip!"
            ui.statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
        updateSelectedPetDisplay()
    end
end

