local function handlePetMeAilment()
    debugPrint("========================================")
    debugPrint("✋ PET ME AILMENT DETECTED!")
    debugPrint("========================================")

    local myPetID = PetID or getEquippedPetID()
    if not myPetID then
        debugPrint("❌ No Pet ID found for progression!")
        return false
    end

    local isStarterEgg = false
    local isCat = false
    local playerData = getPlayerData()
    
    -- Check from inventory data
    if playerData and playerData.inventory and playerData.inventory.pets and playerData.inventory.pets[myPetID] then
        local petName = playerData.inventory.pets[myPetID].id or ""
        if string.find(string.lower(petName), "starter_egg") then
            isStarterEgg = true
        elseif string.find(string.lower(petName), "cat") then
            isCat = true
        end
    end
    
    -- Check from selectedPetType (more reliable)
    if selectedPetType == "starter_egg" then
        isStarterEgg = true
        isCat = false
    elseif selectedPetType == "cat" then
        isCat = true
        isStarterEgg = false
    end

    -- Also check what's actually in workspace
    local workspacePet = findPlayerPetInWorkspace()
    if workspacePet then
        local wsName = workspacePet.Name
        if wsName == "Starter Egg" then
            isStarterEgg = true
            isCat = false
        elseif wsName == "Cat" then
            isCat = true
            isStarterEgg = false
        elseif wsName == "Dog" then
            isStarterEgg = false
            isCat = false
        end
    end

    local petModel
    local animName
    
    if isStarterEgg then
        petModel = workspace:WaitForChild("Pets"):WaitForChild("Starter Egg")
        animName = "EggIdle"
        debugPrint("Detected: STARTER EGG 🥚")
    elseif isCat then
        petModel = workspace:WaitForChild("Pets"):WaitForChild("Cat")
        animName = "CatIdle"
        debugPrint("Detected: CAT 🐈")
    else
        petModel = workspace:WaitForChild("Pets"):WaitForChild("Dog")
        animName = "DogIdle"
        debugPrint("Detected: DOG 🐕")
    end

    -- STEP 1: Focus Pet
    local args = { petModel }
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("AdoptAPI/FocusPet"):FireServer(unpack(args))
    task.wait(0.5)

    -- STEP 2: ReplicateActivePerformances (LookAt)
    args = {
        petModel,
        {
            FocusPet = true,
            LookAtObject = true,
            Petting = true
        }
    }
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicateActivePerformances"):FireServer(unpack(args))
    task.wait(0.5)

    -- STEP 3: ReplicatePerformanceModifiers (Idle Anim)
    args = {
        petModel,
        {
            anim_fade_time = 0.2,
            local_anim_speed = 1,
            dont_allow_sit_states = true,
            pause_ailment_chat_bubbles = true,
            local_anim_name = animName,
            dont_allow_remote_interaction = true
        }
    }
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicatePerformanceModifiers"):FireServer(unpack(args))
    task.wait(0.5)

    -- STEP 4: ReplicateActiveReactions
    args = { petModel, {} }
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicateActiveReactions"):FireServer(unpack(args))
    task.wait(0.5)

    -- STEP 5: ProgressPetMeAilment
    args = { myPetID }
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("AilmentsAPI/ProgressPetMeAilment"):FireServer(unpack(args))
    task.wait(0.5)

    -- STEP 6: ReplicateActivePerformances (Petting)
    args = {
        petModel,
        {
            FocusPet = true,
            Petting = true
        }
    }
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicateActivePerformances"):FireServer(unpack(args))
    task.wait(0.5)

    -- STEP 7: Unfocus Pet
    args = { petModel }
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("AdoptAPI/UnfocusPet"):FireServer(unpack(args))

    debugPrint("========================================")
    debugPrint("✅ PET ME 7-STEP SEQUENCE COMPLETE!")
    debugPrint("========================================")
    return true
end

