local function extractFurnitureData(model, folderName)
    if not model or not model:IsA("Model") then return nil end
    local activationParts = {"UseBlock", "Seat1"}
    local folderId = string.match(folderName, "f%-%d+") or folderName

    for _, partName in ipairs(activationParts) do
        local useBlocksFolder = model:FindFirstChild("UseBlocks")
        if useBlocksFolder then
            local part = useBlocksFolder:FindFirstChild(partName)
            if part and part:IsA("BasePart") then
                return {
                    folderId = folderId,
                    partName = partName,
                    position = part.Position,
                    cframe = part.CFrame,
                    model = model
                }
            end
        end
        local part = model:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            return {
                folderId = folderId,
                partName = partName,
                position = part.Position,
                cframe = part.CFrame,
                model = model
            }
        end
    end

    for _, part in ipairs(model:GetDescendants()) do
        if part and part:IsA("BasePart") then
            return {
                folderId = folderId,
                partName = part.Name,
                position = part.Position,
                cframe = part.CFrame,
                model = model
            }
        end
    end
    return nil
end

local function findFurnitureByName(name)
    local hi = workspace:FindFirstChild("HouseInteriors")
    if hi then
        for _, folder in ipairs(hi:GetChildren()) do
            if folder and folder.Name and (string.find(folder.Name, player.Name) or string.find(folder.Name, "f%-%d+")) then
                local model = folder:FindFirstChild(name)
                if model and model:IsA("Model") then
                    return extractFurnitureData(model, folder.Name)
                end
            end
        end
    end
    return nil
end

local function checkAndBuyFurniture(furnitureName)
    local buyInfo = FURNITURE_BUY_INFO[furnitureName]
    if not buyInfo then
        debugPrint("No buy info for: " .. tostring(furnitureName))
        return false
    end

    local existingFurniture = findFurnitureByName(furnitureName)
    if existingFurniture then
        return true
    end

    debugPrint("Buying: " .. furnitureName)
    
    -- Buy ONE item at a time (safe format)
    local args = {
        {
            kind = buyInfo.kind,
            properties = {
                cframe = buyInfo.cframe
            }
        }
    }

    local success, result = safeRemoteCall({"HousingAPI/BuyFurnitures"}, "InvokeServer", args)
    if success then
        task.wait(3)
        local verifyFurniture = findFurnitureByName(furnitureName)
        if verifyFurniture then
            debugPrint("✅ Bought: " .. furnitureName)
            return true
        end
    else
        debugPrint("❌ Buy failed: " .. furnitureName .. " - " .. tostring(result))
    end
    return false
end

local function checkAndBuyAllMissingFurniture()
    debugPrint("Checking furniture...")
    for furnitureName, _ in pairs(FURNITURE_BUY_INFO) do
        local existing = findFurnitureByName(furnitureName)
        if not existing then
            checkAndBuyFurniture(furnitureName)
            task.wait(1)
        end
    end
    debugPrint("Furniture check complete")
end

local function activateFurniture(furnitureName, pet)
    local furnitureData = findFurnitureByName(furnitureName)
    if not furnitureData then return false end

    local char = ensureCharacterSpawned()
    if not char then return false end

    return safeRemoteCall({"HousingAPI/ActivateFurniture"}, "InvokeServer",
        player,
        furnitureData.folderId,
        furnitureData.partName,
        { cframe = furnitureData.cframe },
        pet
    )
end

local function useFurnitureWithPet(furnitureName)
    debugPrint("Using furniture: " .. furnitureName)

    local furnitureData = findFurnitureByName(furnitureName)
    if not furnitureData then
        if not checkAndBuyFurniture(furnitureName) then
            return false
        end
        furnitureData = findFurnitureByName(furnitureName)
        if not furnitureData then
            return false
        end
    end

    task.wait(1)

    local petObject = nil
    for attempt = 1, 5 do
        petObject = findPlayerPetInWorkspace()
        if petObject then break end
        task.wait(2)
    end

    if petObject then
        local success = activateFurniture(furnitureName, petObject)
        if success then
            task.wait(20)
            return true
        end
    end
    return false
end

