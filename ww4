    if not petId or type(petId) ~= "string" then return "other" end
    local lower = string.lower(petId)
    if string.find(lower, "starter_egg") then return "starter_egg" end
    if string.find(lower, "dog") then return "dog" end
    if string.find(lower, "cat") then return "cat" end
    return "other"
end

local function getAllValidPets()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return {}
    end

    local validPets = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and type(petData) == "table" and petData.id and petData.properties then
            local petName = string.lower(petData.id)
            if not string.find(petName, "practice_dog") then
                table.insert(validPets, {
                    unique = uniqueId,
                    id = petData.id,
                    age = petData.properties.age or 0,
                    neon = petData.properties.neon or false,
                    petType = getPetType(petData.id)
                })
            end
        end
    end

    table.sort(validPets, function(a, b)
        local function getPriority(p)
            if p.petType == "starter_egg" then return 1 end
            if p.petType == "dog" then return 2 end
            if p.petType == "cat" then return 3 end
            return 4
        end
        local aP, bP = getPriority(a), getPriority(b)
        if aP ~= bP then return aP < bP end
        return a.age > b.age
    end)

    return validPets
end

local function findBestPet()
    debugPrint("Searching for best pet...")
    local validPets = getAllValidPets()

    local starterEggPet = nil
    local dogPet = nil
    local catPet = nil

    for _, pet in ipairs(validPets) do
        if pet.petType == "starter_egg" and (not starterEggPet or pet.age > starterEggPet.age) then
            starterEggPet = pet
        elseif pet.petType == "dog" and (not dogPet or pet.age > dogPet.age) then
            dogPet = pet
        elseif pet.petType == "cat" and (not catPet or pet.age > catPet.age) then
            catPet = pet
        end
    end

    local selectedPet = starterEggPet or dogPet or catPet or validPets[1]

    if selectedPet then
        debugPrint("✅ Selected: " .. selectedPet.id .. " (" .. selectedPet.petType .. ")")
    else
        debugPrint("❌ No valid pets found")
    end

    return selectedPet
end

