local function handlePetMeAilment()
    local myPetID = PetID or getEquippedPetID()
    if not myPetID then return false end
    local isStarterEgg = false
    local isCat = false
    local playerData = getPlayerData()
    if playerData and playerData.inventory and playerData.inventory.pets and playerData.inventory.pets[myPetID] then
        local petName = playerData.inventory.pets[myPetID].id or ""
        if string.find(string.lower(petName), "starter_egg") then isStarterEgg = true
        elseif string.find(string.lower(petName), "cat") then isCat = true end
    end
    if selectedPetType == "starter_egg" then isStarterEgg = true; isCat = false
    elseif selectedPetType == "cat" then isCat = true; isStarterEgg = false end
    local petModel, animName
    if isStarterEgg then petModel = workspace:WaitForChild("Pets"):WaitForChild("Starter Egg"); animName = "EggIdle"
    elseif isCat then petModel = workspace:WaitForChild("Pets"):WaitForChild("Cat"); animName = "CatIdle"
    else petModel = workspace:WaitForChild("Pets"):WaitForChild("Dog"); animName = "DogIdle" end
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("AdoptAPI/FocusPet"):FireServer(petModel)
    task.wait(0.5)
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicateActivePerformances"):FireServer(petModel, { FocusPet = true, LookAtObject = true, Petting = true })
    task.wait(0.5)
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicatePerformanceModifiers"):FireServer(petModel, { anim_fade_time = 0.2, local_anim_speed = 1, dont_allow_sit_states = true, pause_ailment_chat_bubbles = true, local_anim_name = animName, dont_allow_remote_interaction = true })
    task.wait(0.5)
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicateActiveReactions"):FireServer(petModel, {})
    task.wait(0.5)
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("AilmentsAPI/ProgressPetMeAilment"):FireServer(myPetID)
    task.wait(0.5)
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicateActivePerformances"):FireServer(petModel, { FocusPet = true, Petting = true })
    task.wait(0.5)
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("AdoptAPI/UnfocusPet"):FireServer(petModel)
    return true
end

