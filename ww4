local function updatePetsDropdown(dropdownButton, dropdownListFrame)
    for _, child in ipairs(dropdownListFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        dropdownButton.Text = "No Pets Found"
        return
    end

    local List = {}
    PetsShow = {}

    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and type(petData) == "table" and petData.id and petData.properties then
            local petName = string.lower(petData.id)
            if not string.find(petName, "practice_dog") then
                local petAge = petData.properties.age or 0
                local neonStatus = petData.properties.neon and " 🔥NEON" or ""
                local petType = getPetType(petData.id)
                local typeIcon = getPetTypeIcon(petType)
                local key = string.format("%s %s (Age: %d)%s", typeIcon, petData.id, petAge, neonStatus)
                PetsShow[key] = { unique = uniqueId, id = petData.id, age = petAge, neon = petData.properties.neon, petType = petType }
                table.insert(List, key)
            end
        end
    end

    table.sort(List, function(a, b)
        local aD, bD = PetsShow[a], PetsShow[b]
        if not aD or not bD then return false end
        local function p(pt)
            if pt == "starter_egg" then return 1 end
            if pt == "dog" then return 2 end
            if pt == "cat" then return 3 end
            return 4
        end
        local ap, bp = p(aD.petType), p(bD.petType)
        if ap ~= bp then return ap < bp end
        return aD.age > bD.age
    end)

    if PetID and selectedPetName then
        local icon = getPetTypeIcon(selectedPetType)
        dropdownButton.Text = icon .. " " .. selectedPetName
    elseif #List > 0 then
        dropdownButton.Text = "Select Pet (" .. #List .. ")"
    else
        dropdownButton.Text = "No Pets Found"
    end

    for i, petKey in ipairs(List) do
        local optionButton = Instance.new("TextButton")
        optionButton.Size = UDim2.new(1, 0, 0, 22)
        optionButton.Position = UDim2.new(0, 0, 0, (i - 1) * 22)

