-- ==================================================================
local function startAutoPetPen()
    while AutoPetPenMode do
        local playerData = getPlayerData()
        if playerData and playerData.idle_progression_manager and playerData.idle_progression_manager.active_pets then
            for uniqueId, _ in pairs(playerData.idle_progression_manager.active_pets) do
                local pet = playerData.inventory and playerData.inventory.pets and playerData.inventory.pets[uniqueId]
                if pet and pet.properties and pet.properties.age and pet.properties.age >= 6 then
                    safeRemoteCall({"IdleProgressionAPI/RemovePet"}, "FireServer", uniqueId)
                    task.wait(0.7)
                end
            end

            task.wait(2)

            local snapshot = {}
            if playerData.idle_progression_manager.active_pets then
                for uid, _ in pairs(playerData.idle_progression_manager.active_pets) do
                    table.insert(snapshot, uid)
                end
            end

            local slotsOpen = 4 - #snapshot
            if slotsOpen > 0 and playerData.inventory and playerData.inventory.pets then
                local added = 0
                for uniqueId, petData in pairs(playerData.inventory.pets) do
                    if added >= slotsOpen then break end
                    if petData.properties and petData.properties.neon then
                        safeRemoteCall({"IdleProgressionAPI/AddPet"}, "FireServer", uniqueId)
                        added = added + 1
                        task.wait(0.6)
                    end
                end
                for _, eggName in ipairs(priorityEggs) do
                    if added >= slotsOpen then break end
                    for uniqueId, petData in pairs(playerData.inventory.pets) do
                        if added >= slotsOpen then break end
                        if petData.id == eggName then
                            safeRemoteCall({"IdleProgressionAPI/AddPet"}, "FireServer", uniqueId)
                            added = added + 1
                            task.wait(0.6)
                        end
                    end
                end
            end
        end

        if os.time() - lastPetPenCommitTime >= 300 then
            safeRemoteCall({"IdleProgressionAPI/CommitAllProgression"}, "FireServer")
            lastPetPenCommitTime = os.time()
        end

        task.wait(60)
    end
end

local function toggleAutoPetPenMode()
    AutoPetPenMode = not AutoPetPenMode
    if AutoPetPenMode then
        lastPetPenCommitTime = os.time()
        autoPetPenCoroutine = coroutine.wrap(startAutoPetPen)()
    end
end

