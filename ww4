local function autoStart()
    debugPrint("========================================")
    debugPrint("🥚 AUTO-START: STARTER_EGG #1!")
    debugPrint("🐕 Dog #2 | 🐈 Cat #3")
    debugPrint("========================================")

    if ui then
        ui.statusLabel.Text = "Status: Checking furniture..."
        ui.statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    end

    checkAndBuyAllMissingFurniture()

    if ui then
        ui.statusLabel.Text = "Status: Finding best pet..."
        ui.statusLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
    end

    task.wait(3)

    local selectedPet = findBestPet()

    if selectedPet then
        local icon = getPetTypeIcon(selectedPet.petType)
        if ui then
            ui.statusLabel.Text = "Status: Selecting " .. icon .. " " .. selectedPet.id .. "..."
        end

        local success = selectAndEquipPet(selectedPet)

        if success then
            if ui then
                -- Update selected pet frame color based on type
                if selectedPet.petType == "starter_egg" then
                    ui.selectedPetFrame.BackgroundColor3 = Color3.fromRGB(60, 45, 0)
                    ui.selectedPetFrame.BackgroundColor3 = Color3.fromRGB(80, 60, 0)
                else
                    ui.selectedPetFrame.BackgroundColor3 = Color3.fromRGB(0, 40, 0)
                end
            end

            if not AutoPetPenMode then
                toggleAutoPetPenMode()
                if ui and ui.autoPetPenButton then
                    ui.autoPetPenButton.Text = "Auto PetPen [ON]"
                    ui.autoPetPenButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
                end
            end

            if not PetFarmMode then
                togglePetFarmMode()
                if ui and ui.petFarmButton then
                    ui.petFarmButton.Text = "🛑 STOP PETFARM"
                    ui.petFarmButton.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
                end
            end

            debugPrint("========================================")
            debugPrint("✅ PETFARM RUNNING!")
            debugPrint("   Pet: " .. icon .. " " .. selectedPet.id)
            debugPrint("   Type: " .. selectedPet.petType)
            debugPrint("   Age: " .. selectedPet.age)
            debugPrint("========================================")
        else
            if ui then
                ui.statusLabel.Text = "Status: ❌ Failed to equip!"
                ui.statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
            end
        end
    else
        if ui then
            ui.statusLabel.Text = "Status: ❌ No pets found!"
            ui.statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
    end
end

