local function extractFurnitureData(model, folderName)
    local activationParts = {"UseBlock", "Seat1"}
    local folderId = string.match(folderName, "f%-%d+") or folderName

    for _, partName in ipairs(activationParts) do
        local useBlocksFolder = model:FindFirstChild("UseBlocks")
        if useBlocksFolder then
            local part = useBlocksFolder:FindFirstChild(partName)
            if part and part:IsA("BasePart") then
                return {
                    folderId = folderId,
                    partName = partName,
                    position = part.Position,
                    cframe = part.CFrame,
                    model = model
                }
            end
        end

        local part = model:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            return {
                folderId = folderId,
                partName = partName,
                position = part.Position,
                cframe = part.CFrame,
                model = model
            }
        end
    end

    for _, part in ipairs(model:GetDescendants()) do
        if part:IsA("BasePart") then
            return {
                folderId = folderId,
                partName = part.Name,
                position = part.Position,
                cframe = part.CFrame,
                model = model
            }
        end
    end

    return nil
end

local function findFurnitureByName(name)
    debugPrint("Searching for furniture: " .. name)
    local hi = workspace:FindFirstChild("HouseInteriors")
    if hi then
        for _, folder in ipairs(hi:GetChildren()) do
            if string.find(folder.Name, player.Name) or string.find(folder.Name, "f%-%d+") then
                local model = folder:FindFirstChild(name)
                if model and model:IsA("Model") then
                    debugPrint("Found " .. name .. " in " .. folder.Name)
                    return extractFurnitureData(model, folder.Name)
                end
            end
        end
    end

    local model = workspace:FindFirstChild(name, true)
    if model and model:IsA("Model") then
        debugPrint("Found " .. name .. " in workspace (fallback)")
        local folderId = model.Parent and string.match(model.Parent.Name, "f%-%d+") or "unknown"
        return extractFurnitureData(model, folderId)
    end

    debugPrint("Furniture not found: " .. name)
    return nil
end

local function checkAndBuyFurniture(furnitureName)
    local buyInfo = FURNITURE_BUY_INFO[furnitureName]
    if not buyInfo then
        debugPrint("No buy info for furniture: " .. tostring(furnitureName))
        return false
    end

    local existingFurniture = findFurnitureByName(furnitureName)
    if existingFurniture then
        debugPrint("✅ Furniture already exists: " .. furnitureName)
        return true
    end

    debugPrint("⚠️ Furniture missing: " .. furnitureName .. " - Purchasing...")
    local args = {
        {
            {
                kind = buyInfo.kind,
                properties = {
                    cframe = buyInfo.cframe
                }
            }
        }
    }

    local success, result = pcall(function()
        return ReplicatedStorage:WaitForChild("API"):WaitForChild("HousingAPI/BuyFurnitures"):InvokeServer(unpack(args))
    end)

    if success then
        debugPrint("✅ Successfully purchased: " .. furnitureName)
        task.wait(3)

        local verifyFurniture = findFurnitureByName(furnitureName)
        if verifyFurniture then
            debugPrint("✅ Verified furniture placed: " .. furnitureName)
            return true
        else
            debugPrint("⚠️ Furniture purchased but not yet visible, waiting...")
            for attempt = 1, 5 do
                task.wait(2)
                verifyFurniture = findFurnitureByName(furnitureName)
                if verifyFurniture then
                    debugPrint("✅ Furniture appeared after wait: " .. furnitureName)
                    return true
                end
            end
            debugPrint("❌ Furniture still not found after purchase + wait")
            return false
        end
    else
        debugPrint("❌ Failed to buy furniture: " .. furnitureName .. " - " .. tostring(result))
        return false
    end
end

local function checkAndBuyAllMissingFurniture()
    debugPrint("Checking for ALL missing furniture at startup...")
    local missingList = {}

    for furnitureName, buyInfo in pairs(FURNITURE_BUY_INFO) do
        local existing = findFurnitureByName(furnitureName)
        if not existing then
            debugPrint("⚠️ Missing: " .. furnitureName)
            table.insert(missingList, {
                kind = buyInfo.kind,
                properties = {
                    cframe = buyInfo.cframe
                }
            })
        else
            debugPrint("✅ Found: " .. furnitureName)
        end
    end

    if #missingList > 0 then
        debugPrint("Buying " .. #missingList .. " missing furniture items...")
        local success, result = safeRemoteCall({"HousingAPI/BuyFurnitures"}, "InvokeServer", missingList)
        if success then
            debugPrint("✅ Successfully purchased all missing furniture")
            task.wait(5)
        else
            debugPrint("❌ Failed to buy furniture batch: " .. tostring(result))
            debugPrint("Trying one by one...")
            for _, item in ipairs(missingList) do
                local singleArgs = {item}
                local s2, r2 = safeRemoteCall({"HousingAPI/BuyFurnitures"}, "InvokeServer", singleArgs)
                if s2 then
                    debugPrint("✅ Bought: " .. item.kind)
                else
                    debugPrint("❌ Failed: " .. item.kind .. " - " .. tostring(r2))
                end
                task.wait(2)
            end
        end
    else
        debugPrint("✅ All furniture already present")
    end
end

local function activateFurniture(furnitureName, pet)
    local furnitureData = findFurnitureByName(furnitureName)
    if not furnitureData then
        debugPrint("Cannot activate furniture: " .. furnitureName .. " - not found")
        return false
    end

    local char = ensureCharacterSpawned()
    if not char then
        debugPrint("Cannot activate furniture: No character found")
        return false
    end

    local args = {
        player,
        furnitureData.folderId,
        furnitureData.partName,
        {
            cframe = furnitureData.cframe
        },
        pet
    }

    debugPrint("Activating " .. furnitureName .. " in folder " .. furnitureData.folderId)

    local success, result = safeRemoteCall({"HousingAPI/ActivateFurniture"}, "InvokeServer", unpack(args))

    if success then
        debugPrint("Successfully activated: " .. furnitureName)
        return true
    else
        debugPrint("Failed to activate: " .. furnitureName .. " - " .. tostring(result))
        return false
    end
end

local function useFurnitureWithPet(furnitureName)
    debugPrint("Using furniture: " .. furnitureName)

    local furnitureData = findFurnitureByName(furnitureName)
    if not furnitureData then
        debugPrint("⚠️ Furniture not found: " .. furnitureName .. " - Attempting to buy...")
        local bought = checkAndBuyFurniture(furnitureName)
        if not bought then
            debugPrint("❌ Could not buy furniture: " .. furnitureName .. " - SKIPPING")
            return false
        end
        furnitureData = findFurnitureByName(furnitureName)
        if not furnitureData then
            debugPrint("❌ Furniture still not found after buy attempt: " .. furnitureName .. " - SKIPPING")
            return false
        end
    end

    task.wait(1)

    local petObject = nil
    for attempt = 1, 5 do
        petObject = findPlayerPetInWorkspace()
        if petObject then
            break
        end
        debugPrint("Waiting for pet, attempt " .. attempt .. "/5")
        task.wait(2)
    end

    if petObject then
        debugPrint("Found pet: " .. petObject.Name)
        local success = activateFurniture(furnitureName, petObject)
        if success then
            debugPrint("Waiting 20 seconds for animation...")
            task.wait(20)
            return true
        end
    else
        debugPrint("No pet found in workspace")
    end
    return false
end

