local ui = nil

local function selectPet(petData)
    if not petData or not petData.unique then
        debugPrint("selectPet called with invalid data")
        return false
    end

    PetID = petData.unique
    selectedPetName = petData.id
    selectedPetType = petData.petType
    currentSelectedPetKey = buildPetKey(petData.id, petData.age, petData.neon)

    debugPrint("=== PET SELECTED ===")
    debugPrint("Name: " .. selectedPetName)
    debugPrint("ID: " .. PetID)
    debugPrint("Type: " .. selectedPetType)
    debugPrint("Key: " .. currentSelectedPetKey)

    if ui and ui.petsDropdownButton then
        ui.petsDropdownButton.Text = "✅ " .. currentSelectedPetKey
        ui.petsDropdownButton.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
        ui.petsDropdownButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    end

    if ui and ui.statusLabel then
        local icon = getPetTypeIcon(selectedPetType)
        ui.statusLabel.Text = "Status: Selected - " .. icon .. " " .. selectedPetName
    end

    return equipSelectedPet(PetID)
end

