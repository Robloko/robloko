local function usePetAgePotion()
    if not PetID then return false end
    local playerData = getPlayerData()
    if not playerData then return false end

    local currentPetAge = 0
    if playerData.inventory and playerData.inventory.pets and playerData.inventory.pets[PetID] then
        currentPetAge = playerData.inventory.pets[PetID].properties and playerData.inventory.pets[PetID].properties.age or 0
    end
    if currentPetAge >= 6 then return false end

    local potionID = findPetAgePotion()
    if not potionID then return false end

    safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", potionID, {use_sound_delay = true, equip_as_last = false})
    task.wait(1)
    safeRemoteCall({"ToolAPI/ServerUseTool"}, "FireServer", potionID, "START")
