        petFarmButton = petFarmButton, statusLabel = statusLabel,
        petsDropdownButton = petsDropdownButton, petsDropdownListFrame = petsDropdownListFrame
    }
end

-- ==================================================================
-- AUTO START
-- ==================================================================

local function autoStart()
    if ui then
        ui.statusLabel.Text = "Status: Checking furniture..."
        ui.statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    end

    checkAndBuyAllMissingFurniture()

    if ui then
        ui.statusLabel.Text = "Status: Searching for best pet..."
        ui.statusLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
    end

    task.wait(3)

    local selectedPet = findBestPet()

    if not selectedPet then
        debugPrint("❌ No valid pets found in inventory!")
        clearPetSelection()
        return
    end

    local equipOk = selectPet(selectedPet)

    if not equipOk then
        debugPrint("First equip failed, retrying...")
        task.wait(2)
        equipOk = equipSelectedPet(PetID)
    end

    if equipOk then
        debugPrint("✅ Pet equipped successfully!")
        if ui then
            local icon = getPetTypeIcon(selectedPetType)
            ui.statusLabel.Text = "Status: ✅ RUNNING - " .. icon .. " " .. selectedPetName
            ui.statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end

        if not AutoPetPenMode then
            toggleAutoPetPenMode()
            if ui and ui.autoPetPenButton then
                ui.autoPetPenButton.Text = "Auto PetPen [ON]"
                ui.autoPetPenButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
            end
        end

        if not PetFarmMode then
            togglePetFarmMode()
            if ui and ui.petFarmButton then
                ui.petFarmButton.Text = "🛑 STOP PETFARM"
                ui.petFarmButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
                ui.petFarmButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end

        -- Start the inventory monitor AFTER initial setup
        debugPrint("========================================")
        debugPrint("🔍 Starting inventory monitor...")
        debugPrint("   Will auto-switch when pet hatched!")
        debugPrint("   Priority: Egg > Dog > Cat")
        debugPrint("========================================")
        coroutine.wrap(monitorPetInventory)()

    else
        debugPrint("❌ Failed to equip pet after retry!")
        if ui then
            ui.statusLabel.Text = "Status: ❌ Failed to equip!"
            ui.statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
    end
end

