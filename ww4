local function updatePetsDropdown(dropdownButton, dropdownListFrame)
    for _, child in ipairs(dropdownListFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        if not PetID then
            dropdownButton.Text = "No Pets Found"
            dropdownButton.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            dropdownButton.TextColor3 = Color3.fromRGB(180, 180, 180)
        end
        return
    end

    local List = {}
    PetsShow = {}

    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and petData.properties then
            local petName = string.lower(petData.id)
            if not string.find(petName, "practice_dog") then
                local age = petData.properties.age or 0
                local neon = petData.properties.neon or false
                local key = buildPetKey(petData.id, age, neon)
                PetsShow[key] = {
                    unique = uniqueId,
                    id = petData.id,
                    age = age,
                    neon = neon,
                    petType = detectPetType(petData.id)
                }
                table.insert(List, key)
            end
        end
    end

    table.sort(List, function(a, b)
        local aData, bData = PetsShow[a], PetsShow[b]
        if not aData or not bData then return false end
        local function p(t) if t == "starter_egg" then return 1 elseif t == "dog" then return 2 elseif t == "cat" then return 3 end return 4 end
        local ap, bp = p(aData.petType), p(bData.petType)
        if ap ~= bp then return ap < bp end
        return aData.age > bData.age
    end)

    for i, petKey in ipairs(List) do
        local optionButton = Instance.new("TextButton")
        optionButton.Size = UDim2.new(1, 0, 0, 22)
        optionButton.Position = UDim2.new(0, 0, 0, (i - 1) * 22)
        optionButton.Font = Enum.Font.SourceSans
        optionButton.TextSize = 11
        optionButton.BorderSizePixel = 0
        optionButton.Parent = dropdownListFrame

        local petData = PetsShow[petKey]
        local isSelected = (PetID and petData and petData.unique == PetID)

        if isSelected then
            optionButton.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
            optionButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            optionButton.Text = "✅ " .. petKey
            optionButton.Font = Enum.Font.SourceSansBold
            local indicator = Instance.new("Frame")
            indicator.Size = UDim2.new(0, 3, 1, 0)
            indicator.Position = UDim2.new(0, 0, 0, 0)
            indicator.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
            indicator.BorderSizePixel = 0
            indicator.Parent = optionButton
        elseif petData and petData.petType == "starter_egg" then
            optionButton.BackgroundColor3 = Color3.fromRGB(80, 60, 20)
            optionButton.TextColor3 = Color3.fromRGB(255, 215, 0)
            optionButton.Text = petKey
        else
            optionButton.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
            optionButton.TextColor3 = Color3.fromRGB(200, 200, 200)
            optionButton.Text = petKey
        end

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 3)
        btnCorner.Parent = optionButton

        optionButton.MouseButton1Click:Connect(function()
            dropdownListFrame.Visible = false
            local selectedPet = PetsShow[petKey]
            if selectedPet then
                selectPet(selectedPet)
                updatePetsDropdown(dropdownButton, dropdownListFrame)
            end
        end)
    end

    dropdownListFrame.CanvasSize = UDim2.new(0, 0, 0, #List * 22)

    if PetID and currentSelectedPetKey then
        dropdownButton.Text = "✅ " .. currentSelectedPetKey
        dropdownButton.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
        dropdownButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    else
        dropdownButton.Text = "Select a Pet (" .. #List .. ")"
        dropdownButton.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        dropdownButton.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
end

