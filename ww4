    return safeRemoteCall({"HousingAPI/ActivateFurniture"}, "InvokeServer", player, furnitureData.folderId, furnitureData.partName, { cframe = furnitureData.cframe }, pet)
end

local function useFurnitureWithPet(furnitureName)
    if not findFurnitureByName(furnitureName) then
        if not checkAndBuyFurniture(furnitureName) then return false end
        if not findFurnitureByName(furnitureName) then return false end
    end
    task.wait(1)
    local petObject = nil
    for attempt = 1, 5 do
        petObject = findPlayerPetInWorkspace()
        if petObject then break end
        task.wait(2)
    end
    if petObject then
        if activateFurniture(furnitureName, petObject) then
