-- ==================================================================
-- SAFE REMOTE CALL (FIXED)
-- ==================================================================
local function safeRemoteCall(remotePath, method, ...)
    local args = {...}
    local apiModule = ReplicatedStorage:FindFirstChild("API")
    if not apiModule then
        return false, "API not found"
    end

    local remote = apiModule
    for _, path in ipairs(remotePath) do
        if not remote then
            return false, "Remote path failed at: " .. tostring(path)
        end
        remote = remote:FindFirstChild(path)
    end

    if not remote then
        return false, "Remote not found: " .. table.concat(remotePath, "/")
    end

    -- Validate remote type
    if method == "InvokeServer" then
        if not remote:IsA("RemoteFunction") then
            return false, "Not a RemoteFunction: " .. table.concat(remotePath, "/")
        end
        local success, result = pcall(function()
            if #args == 0 then
                return remote:InvokeServer()
            elseif #args == 1 then
                return remote:InvokeServer(args[1])
            else
                return remote:InvokeServer(unpack(args))
            end
        end)
        if not success then
            return false, "InvokeServer error: " .. tostring(result)
        end
        return true, result
    elseif method == "FireServer" then
        if not remote:IsA("RemoteEvent") then
            return false, "Not a RemoteEvent: " .. table.concat(remotePath, "/")
        end
        local success, err = pcall(function()
            if #args == 0 then
                remote:FireServer()
            elseif #args == 1 then
                remote:FireServer(args[1])
            else
                remote:FireServer(unpack(args))
            end
        end)
        if not success then
            return false, "FireServer error: " .. tostring(err)
        end
        return true, nil
    end
    return false, "Invalid method: " .. tostring(method)
end

-- ==================================================================
-- GET PLAYER DATA (SAFE)
-- ==================================================================
local function getPlayerData()
    local success, clientData = pcall(function()
        local module = ReplicatedStorage:FindFirstChild("ClientModules")
        if not module then return nil end
        local core = module:FindFirstChild("Core")
        if not core then return nil end
        local dataModule = core:FindFirstChild("ClientData")
        if not dataModule then return nil end
        return require(dataModule)
    end)
    if not success or not clientData then
        return nil
    end
    if type(clientData.get_data) ~= "function" then
        return nil
    end
    local success2, allData = pcall(clientData.get_data, clientData)
    if not success2 or not allData or type(allData) ~= "table" then
        return nil
    end
    local myData = allData[player.Name]
    if not myData or type(myData) ~= "table" then
        return nil
    end
    return myData
end

