-- ==================================================================
-- HATCH DETECTION - Detects when starter_egg hatches into cat/dog
-- ==================================================================

local function checkForPetHatch()
    if not PetID then
        return false
    end
    
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return false
    end
    
    local currentPetData = playerData.inventory.pets[PetID]
    
    -- Pet no longer exists in inventory (hatched and became something else?)
    if not currentPetData then
        debugPrint("========================================")
        debugPrint("🚨 PET NO LONGER IN INVENTORY!")
        debugPrint("   Was: " .. tostring(selectedPetOriginalID))
        debugPrint("========================================")
        return true
    end
    
    local currentPetID = currentPetData.id or ""
    
    -- Check if pet ID changed (starter_egg hatched into cat/dog)
    if selectedPetOriginalID and currentPetID ~= selectedPetOriginalID then
        debugPrint("========================================")
        debugPrint("🥚🔄 PET HATCHED!")
        debugPrint("   Was: " .. tostring(selectedPetOriginalID)
        debugPrint("   Now: " .. currentPetID)
        debugPrint("========================================")
        return true
    end
    
    return false
end

local function reSelectPetAfterHatch()
    debugPrint("========================================")
    debugPrint("🔄 RE-SELECTING PET AFTER HATCH...")
    debugPrint("========================================")
    
    -- Temporarily stop PetFarm
    local wasRunning = PetFarmMode
    PetFarmMode = false
    task.wait(2)
    
    -- Clear old selection
    PetID = nil
    selectedPetName = nil
    selectedPetType = nil
    selectedPetOriginalID = nil
    
    -- Find new best pet (starter_egg > dog > cat)
    local newPet = findBestPet()
    
    if newPet then
        PetID = newPet.unique
        selectedPetName = newPet.id
        selectedPetType = newPet.petType
        selectedPetOriginalID = newPet.id
        
        debugPrint("New pet selected: " .. newPet.id .. " (Type: " .. newPet.petType .. ")")
        
        -- Equip the new pet
        equipSelectedPet(newPet.unique)
        task.wait(3)
        
        -- Update UI
        updateSelectedPetDisplay()
        
        -- Restart PetFarm if it was running
        if wasRunning then
            debugPrint("Restarting PetFarm with new pet...")
            PetFarmMode = true
            petFarmCoroutine = coroutine.wrap(startPetFarm)()
            
            if ui and ui.petFarmButton then
                ui.petFarmButton.Text = "🛑 STOP PETFARM"
                ui.petFarmButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
                ui.petFarmButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
        
        debugPrint("========================================")
        debugPrint("✅ SUCCESSFULLY SWITCHED TO: " .. newPet.id)
        debugPrint("========================================")
    else
        debugPrint("❌ No valid pet found after hatch!")
        updateSelectedPetDisplay()
        
        if ui and ui.petFarmButton then
            ui.petFarmButton.Text = "🥚 START PETFARM (Egg First!)"
            ui.petFarmButton.BackgroundColor3 = Color3.fromRGB(180, 140, 0)
            ui.petFarmButton.TextColor3 = Color3.fromRGB(0, 0, 0)
        end
    end
end

-- ==================================================================
-- AILMENT MONITORING (with hatch detection)
-- ==================================================================

local function ensurePetEquipped(petUniqueID, timeout)
    timeout = timeout or 15
    if not petUniqueID then
        return false
    end

    if isPetEquipped(petUniqueID) then
        return true
    end

    debugPrint("Re-equipping pet...")
    local success = safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", petUniqueID, {
        use_sound_delay = true,
        equip_as_last = false
    })

    if success then
        task.wait(3)
        return true
    end
    return false
end

local function monitorAndHandleAilments()
    debugPrint("Starting ailment monitoring system...")
    local SCAN_INTERVAL = 10
    local lastEquipCheckTime = 0
    local EQUIP_CHECK_INTERVAL = 5

    while PetFarmMode do
        local currentTime = os.time()

        -- Keep pet equipped
        if currentTime - lastEquipCheckTime >= EQUIP_CHECK_INTERVAL then
            if PetID then
                if not isPetEquipped(PetID) then
                    debugPrint("Pet not equipped, re-equipping...")
                    ensurePetEquipped(PetID, 8)
                end
            end
            lastEquipCheckTime = currentTime
        end
        
        -- CHECK FOR HATCH (starter_egg -> cat/dog)
        if currentTime - lastHatchCheckTime >= HATCH_CHECK_INTERVAL then
            if checkForPetHatch() then
                -- Pet hatched! Re-select and continue
                reSelectPetAfterHatch()
                -- After re-select, continue the loop with new pet
                lastHatchCheckTime = currentTime
                task.wait(5)
            end
            lastHatchCheckTime = currentTime
        end

        local playerData = getPlayerData()

        if playerData and playerData.ailments_manager and playerData.ailments_manager.ailments then
            for ailmentId, ailmentData in pairs(playerData.ailments_manager.ailments) do
                if ailmentId == PetID then
                    for ailmentType, furnitureName in pairs(AILMENT_TASKS) do
                        if ailmentData[ailmentType] and type(ailmentData[ailmentType]) == "table" then
                            if not lastTaskTime[ailmentType] or (currentTime - lastTaskTime[ailmentType]) >= TASK_COOLDOWN then
                                if ailmentType == "pet_me" then
                                    debugPrint("✋ PET ME AILMENT DETECTED!")
                                    local success = handlePetMeAilment(PetID)
                                    if success then
                                        lastTaskTime[ailmentType] = currentTime
                                    end
                                elseif ailmentType == "mystery" then
                                    debugPrint("❓ MYSTERY AILMENT DETECTED!")
                                    local success = resolveMysteryAilment(ailmentId)
                                    if success then
                                        lastTaskTime[ailmentType] = currentTime
                                    end
                                elseif ailmentType == "play" then
                                    local success = handlePlayAilment()
                                    if success then lastTaskTime[ailmentType] = currentTime end
                                elseif ailmentType == "walk" then
                                    local success = handleWalkAilment()
                                    if success then lastTaskTime[ailmentType] = currentTime end
                                elseif ailmentType == "ride" then
                                    local success = handleRideAilment()
                                    if success then lastTaskTime[ailmentType] = currentTime end
                                elseif ailmentType == "sick" then
                                    local success = handleSickAilment()
                                    if success then lastTaskTime[ailmentType] = currentTime end
                                else
                                    debugPrint("🏠 Ailment '" .. ailmentType .. "' requires furniture: " .. furnitureName)
                                    local furnitureExists = findFurnitureByName(furnitureName)
                                    if not furnitureExists then
                                        debugPrint("⚠️ Missing furniture for ailment, buying: " .. furnitureName)
                                        checkAndBuyFurniture(furnitureName)
                                    end
                                    local success = useFurnitureWithPet(furnitureName)
                                    if success then lastTaskTime[ailmentType] = currentTime end
                                end
                                -- Update display after handling ailment
                                updateSelectedPetDisplay()
                                break
                            end
                        end
                    end
                end
            end
        end

        task.wait(SCAN_INTERVAL)
    end
end

local function startPetFarm()
    debugPrint("Starting PetFarm...")

    if not PetID then
        debugPrint("No pet selected!")
        PetFarmMode = false
        return
    end

    local char = ensureCharacterSpawned()
    if not char then
        debugPrint("No valid character!")
        PetFarmMode = false
        return
    end

    if not ensurePetEquipped(PetID, 15) then
        debugPrint("Failed to equip pet!")
        PetFarmMode = false
        return
    end

    monitorAndHandleAilments()
end

local function togglePetFarmMode()
    PetFarmMode = not PetFarmMode
    if PetFarmMode then
        if not PetID then
            debugPrint("No pet selected!")
            PetFarmMode = false
            return
        end
        debugPrint("PetFarm: ENABLED for " .. tostring(selectedPetName))
        petFarmCoroutine = coroutine.wrap(startPetFarm)()
    else
        debugPrint("PetFarm: DISABLED")
        petFarmCoroutine = nil
    end
    updateSelectedPetDisplay()
end

