local function handlePetMeAilment()
    debugPrint("✋ PET ME AILMENT!")
    local myPetID = PetID or getEquippedPetID()
    if not myPetID then return false end

    local isStarterEgg = (selectedPetType == "starter_egg")
    local isCat = (selectedPetType == "cat")

    local petModel
    local animName
    if isStarterEgg then
        petModel = workspace:FindFirstChild("Pets")
        if petModel then petModel = petModel:FindFirstChild("Starter Egg") end
        animName = "EggIdle"
    elseif isCat then
        petModel = workspace:FindFirstChild("Pets")
        if petModel then petModel = petModel:FindFirstChild("Cat") end
        animName = "CatIdle"
    else
        petModel = workspace:FindFirstChild("Pets")
        if petModel then petModel = petModel:FindFirstChild("Dog") end
        animName = "DogIdle"
    end

    if not petModel then
        debugPrint("❌ Pet model not found in workspace")
        return false
    end

    safeRemoteCall({"AdoptAPI/FocusPet"}, "FireServer", petModel)
    task.wait(0.5)

    safeRemoteCall({"PetAPI/ReplicateActivePerformances"}, "FireServer", petModel, {
        FocusPet = true, LookAtObject = true, Petting = true
    })
    task.wait(0.5)

    safeRemoteCall({"PetAPI/ReplicatePerformanceModifiers"}, "FireServer", petModel, {
        anim_fade_time = 0.2, local_anim_speed = 1,
        dont_allow_sit_states = true, pause_ailment_chat_bubbles = true,
        local_anim_name = animName, dont_allow_remote_interaction = true
    })
    task.wait(0.5)

    safeRemoteCall({"PetAPI/ReplicateActiveReactions"}, "FireServer", petModel, {})
    task.wait(0.5)

    safeRemoteCall({"AilmentsAPI/ProgressPetMeAilment"}, "FireServer", myPetID)
    task.wait(0.5)

    safeRemoteCall({"PetAPI/ReplicateActivePerformances"}, "FireServer", petModel, {
        FocusPet = true, Petting = true
    })
    task.wait(0.5)

    safeRemoteCall({"AdoptAPI/UnfocusPet"}, "FireServer", petModel)

    debugPrint("✅ Pet Me complete")
    return true
end

