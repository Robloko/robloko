-- Hatch detection: Check if starter egg hatched
local function checkForHatch()
    if isCheckingHatch then return end
    isCheckingHatch = true

    debugPrint("🔍 Checking for hatch...")

    -- Check if we were tracking a starter egg
    if lastKnownStarterEggID then
        local playerData = getPlayerData()
        if not playerData or not playerData.inventory or not playerData.inventory.pets then
            isCheckingHatch = false
            return
        end

        -- Check if the starter egg still exists
        local eggStillExists = playerData.inventory.pets[lastKnownStarterEggID] ~= nil

        if not eggStillExists then
            debugPrint("========================================")
            debugPrint("🥚✨ STARTER EGG HATCHED!")
            debugPrint("   Old Egg ID: " .. lastKnownStarterEggID)
            debugPrint("   Looking for new Dog or Cat...")
            debugPrint("========================================")

            lastKnownStarterEggID = nil

            -- Wait a moment for the hatched pet to register
            task.wait(2)

            -- Find the new dog or cat (prefer the one with lowest age = freshly hatched)
            local validPets = getAllValidPets()
            local freshDog = nil
            local freshCat = nil

            for _, pet in ipairs(validPets) do
                if pet.petType == "dog" and pet.age <= 1 then
                    if not freshDog or pet.age < freshDog.age then
                        freshDog = pet
                    end
                elseif pet.petType == "cat" and pet.age <= 1 then
                    if not freshCat or pet.age < freshCat.age then
                        freshCat = pet
                    end
                end
            end

            -- If no fresh pet found (age > 1), get any dog/cat
            if not freshDog and not freshCat then
                for _, pet in ipairs(validPets) do
                    if pet.petType == "dog" and not freshDog then
                        freshDog = pet
                    elseif pet.petType == "cat" and not freshCat then
                        freshCat = pet
                    end
                end
            end

            local newPet = freshDog or freshCat

            if newPet then
                debugPrint("✅ Found hatched pet: " .. getPetTypeIcon(newPet.petType) .. " " .. newPet.id)

                -- Update notification in UI
                if ui and ui.hatchNotification then
                    ui.hatchNotification.Text = "🥚✨ HATCHED! Now farming: " .. getPetTypeIcon(newPet.petType) .. " " .. newPet.id
                    ui.hatchNotification.Visible = true
                    ui.hatchNotification.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
                    task.wait(5)
                    ui.hatchNotification.Visible = false
                end

                -- Auto-select and equip the new pet
                selectAndEquipPet(newPet)

                debugPrint("========================================")
                debugPrint("✅ AUTO-SWITCHED TO HATCHED PET!")
                debugPrint("========================================")
            else
                debugPrint("⚠️ Could not find hatched Dog or Cat!")
                
                -- Try to find any starter_egg (maybe got a new one?)
                local newEgg = findStarterEggInInventory()
                if newEgg then
                    debugPrint("🥚 Found new Starter Egg, selecting it...")
                    selectAndEquipPet(newEgg)
                else
                    -- Fallback to best available pet
                    local bestPet = findBestPet()
                    if bestPet then
                        selectAndEquipPet(bestPet)
                    end
                end
            end
        end
    else
        -- Not tracking an egg, but check if a new starter egg appeared
        if selectedPetType and selectedPetType ~= "starter_egg" then
            local newEgg = findStarterEggInInventory()
            if newEgg and newEgg.unique ~= lastKnownStarterEggID then
                debugPrint("🥚 New Starter Egg detected! Switching...")
                
                if ui and ui.hatchNotification then
                    ui.hatchNotification.Text = "🥚 New Starter Egg found! Switching..."
                    ui.hatchNotification.Visible = true
                    ui.hatchNotification.BackgroundColor3 = Color3.fromRGB(100, 80, 0)
                    task.wait(3)
                    ui.hatchNotification.Visible = false
                end

                selectAndEquipPet(newEgg)
            end
        end
    end

    isCheckingHatch = false
end

-- Hatch detection loop
local function startHatchDetection()
    debugPrint("🥚 Hatch detection started...")
    while true do
        checkForHatch()
        task.wait(hatchCheckInterval)
    end
end

