local function getPetPenSnapshot()
    local playerData = getPlayerData()
    if not playerData or not playerData.idle_progression_manager or not playerData.idle_progression_manager.active_pets then
        return {}
    end

    local snapshot = {}
    for uniqueId, _ in pairs(playerData.idle_progression_manager.active_pets) do
        local pet = playerData.inventory.pets[uniqueId]
        if pet then
            table.insert(snapshot, {
                name = pet.id,
                age = pet.properties.age or 0,
                neon = pet.properties.neon or false,
                unique_id = uniqueId
            })
        end
    end
    return snapshot
end

local function purgeNonPriorityGarbage()
    debugPrint("Purging PetPen garbage...")
    local playerData = getPlayerData()
    if not playerData or not playerData.idle_progression_manager or not playerData.idle_progression_manager.active_pets then
        return 0
    end

    local removed = 0
    for uniqueId, _ in pairs(playerData.idle_progression_manager.active_pets) do
        local pet = playerData.inventory.pets[uniqueId]
        if pet and pet.id and pet.properties then
            local cleanName = string.lower(pet.id)
            local isNeon = pet.properties.neon
            if not isNeon and not prioritySet[cleanName] then
                debugPrint("Removing: " .. pet.id)
                safeRemoteCall({"IdleProgressionAPI/RemovePet"}, "FireServer", uniqueId)
                removed = removed + 1
                task.wait(0.7)
            end
        end
    end
    return removed
end

local function addPriorityPets(snapshot)
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return 0
    end

    local slotsOpen = 4 - #snapshot
    if slotsOpen <= 0 then
        return 0
    end

    local added = 0
    local addedSet = {}

    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData.properties.neon and added < slotsOpen and not addedSet[uniqueId] then
            safeRemoteCall({"IdleProgressionAPI/AddPet"}, "FireServer", uniqueId)
            debugPrint("Added NEON: " .. petData.id)
            added = added + 1
            addedSet[uniqueId] = true
            task.wait(0.6)
        end
    end

    for _, eggName in ipairs(priorityEggs) do
        for uniqueId, petData in pairs(playerData.inventory.pets) do
            if petData.id == eggName and added < slotsOpen and not addedSet[uniqueId] then
                safeRemoteCall({"IdleProgressionAPI/AddPet"}, "FireServer", uniqueId)
                debugPrint("Added PRIORITY: " .. petData.id)
                added = added + 1
                addedSet[uniqueId] = true
                task.wait(0.6)
            end
        end
    end

    return added
end

local function startAutoPetPen()
    while AutoPetPenMode do
        debugPrint("=== AUTO PETPEN CYCLE ===")

        purgeNonPriorityGarbage()
        local snapshot = getPetPenSnapshot()

        for _, pet in ipairs(snapshot) do
            if pet.age >= 6 then
                debugPrint("Removing aged: " .. pet.name)
                safeRemoteCall({"IdleProgressionAPI/RemovePet"}, "FireServer", pet.unique_id)
                task.wait(0.7)
            end
        end

        task.wait(2)
        snapshot = getPetPenSnapshot()
        addPriorityPets(snapshot)

        if os.time() - lastPetPenCommitTime >= 300 then
            safeRemoteCall({"IdleProgressionAPI/CommitAllProgression"}, "FireServer")
            debugPrint("Committed rewards")
            lastPetPenCommitTime = os.time()
        end

        task.wait(60)
    end
end

local function toggleAutoPetPenMode()
    AutoPetPenMode = not AutoPetPenMode
    if AutoPetPenMode then
        debugPrint("Auto PetPen: ENABLED")
        lastPetPenCommitTime = os.time()
        autoPetPenCoroutine = coroutine.wrap(startAutoPetPen)()
    else
        debugPrint("Auto PetPen: DISABLED")
        autoPetPenCoroutine = nil
    end
end

-- ==================================================================
-- PET SELECTION (STARTER_EGG #1, DOG #2, CAT #3)
-- ==================================================================

local function getAllValidPets()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return {}
    end

    local validPets = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and petData.properties then
            local petName = string.lower(petData.id)
            if not string.find(petName, "practice_dog") then
                local petType = "other"
                if string.find(petName, "starter_egg") then
                    petType = "starter_egg"
                elseif string.find(petName, "dog") then
                    petType = "dog"
                elseif string.find(petName, "cat") then
                    petType = "cat"
                end
                
                table.insert(validPets, {
                    unique = uniqueId,
                    id = petData.id,
                    age = petData.properties.age or 0,
                    neon = petData.properties.neon or false,
                    name = petData.id,
                    petType = petType
                })
            end
        end
    end

    table.sort(validPets, function(a, b)
        local function getPriority(pet)
            if pet.petType == "starter_egg" then return 1 end
            if pet.petType == "dog" then return 2 end
            if pet.petType == "cat" then return 3 end
            return 4
        end
        
        local aPriority = getPriority(a)
        local bPriority = getPriority(b)
        
        if aPriority ~= bPriority then
            return aPriority < bPriority
        end
        
        return a.age > b.age
    end)

    return validPets
end

local function getPetTypeIcon(petType)
    if petType == "starter_egg" then return "🥚"
    elseif petType == "dog" then return "🐕"
    elseif petType == "cat" then return "🐈"
    else return "📦" end
end

local function findBestPet()
    debugPrint("========================================")
    debugPrint("🥚 PRIORITY #1: STARTER_EGG")
    debugPrint("🐕 PRIORITY #2: DOG (no practice_dog)")
    debugPrint("🐈 PRIORITY #3: CAT")
    debugPrint("========================================")

    local validPets = getAllValidPets()

    local starterEggPet = nil
    local dogPet = nil
    local catPet = nil

    for _, pet in ipairs(validPets) do
        if pet.petType == "starter_egg" then
            if not starterEggPet or pet.age > starterEggPet.age then
                starterEggPet = pet
            end
            debugPrint("🥚 Found STARTER_EGG: " .. pet.id .. " (Age: " .. pet.age .. ")")
        elseif pet.petType == "dog" then
            if not dogPet or pet.age > dogPet.age then
                dogPet = pet
            end
            debugPrint("🐕 Found DOG: " .. pet.id .. " (Age: " .. pet.age .. ")")
        elseif pet.petType == "cat" then
            if not catPet or pet.age > catPet.age then
                catPet = pet
            end
            debugPrint("🐈 Found CAT: " .. pet.id .. " (Age: " .. pet.age .. ")")
        end
    end

    local selectedPet = starterEggPet or dogPet or catPet or validPets[1]

    if selectedPet then
        local typeIcon = getPetTypeIcon(selectedPet.petType)
        debugPrint("========================================")
        debugPrint("✅ SELECTED: " .. typeIcon .. " " .. selectedPet.id)
        debugPrint("   ID: " .. selectedPet.unique)
        debugPrint("   Age: " .. selectedPet.age)
        debugPrint("   Type: " .. selectedPet.petType)
        debugPrint("========================================")
        return selectedPet
    else
        debugPrint("❌ No valid pets found!")
        return nil
    end
end

local function equipSelectedPet(petUniqueID)
    if not petUniqueID then
        debugPrint("No pet ID provided!")
        return false
    end

    if isPetEquipped(petUniqueID) then
        debugPrint("Pet already equipped!")
        return true
    end

    debugPrint("Attempting to equip pet: " .. tostring(petUniqueID))
    local success, err = safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", petUniqueID, {
        use_sound_delay = true,
        equip_as_last = false
    })

    if success then
        debugPrint("✅ Pet equipped successfully!")
        task.wait(3)
        return true
    else
        debugPrint("❌ Failed to equip pet: " .. tostring(err))
        return false
    end
end

