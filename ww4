local SQUEAKY_BONE_ID = nil

local function getSqueakyBoneID()
    if SQUEAKY_BONE_ID then
        return SQUEAKY_BONE_ID
    end

    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.toys then
        return nil
    end

    for uniqueId, toyData in pairs(playerData.inventory.toys) do
        if toyData.id == "squeaky_bone_default" then
            SQUEAKY_BONE_ID = uniqueId
            debugPrint("Found squeaky_bone_default")
            return uniqueId
        end
    end
    return nil
end

local function performThrowToy()
    local toyID = getSqueakyBoneID()
    if not toyID then
        return false
    end

    currentToyID = toyID

    safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", toyID, {
        use_sound_delay = true,
        equip_as_last = false
    })
    task.wait(1.2)

    safeRemoteCall({"ToolAPI/ServerUseTool"}, "FireServer", toyID, "START")
    task.wait(1)

    safeRemoteCall({"PetObjectAPI/CreatePetObject"}, "InvokeServer", "__Enum_PetObjectCreatorType_1", {
        reaction_name = "ThrowToyReaction",
        unique_id = toyID
    })
    task.wait(1.1)

    safeRemoteCall({"ToolAPI/ServerUseTool"}, "FireServer", toyID, "END")
    return true
end

local function performThrowToySequence()
    debugPrint("Starting throw sequence (3x)...")
    local successfulThrows = 0

    for i = 1, 3 do
        if not PetFarmMode then
            return false
        end

        if performThrowToy() then
            successfulThrows = successfulThrows + 1
        end

        if i < 3 then
            for w = 1, 9 do
                if not PetFarmMode then
                    return false
                end
                task.wait(1)
            end
        end
    end

    return successfulThrows >= 2
end

local function handlePlayAilment()
    debugPrint("🎾 PLAY AILMENT DETECTED!")
    if not getSqueakyBoneID() then
        debugPrint("No squeaky bone found")
        return false
    end
    return performThrowToySequence()
end

