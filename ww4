local function checkForPetHatch()
    if not PetID or not selectedPetOriginalID then return false end

    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return false
    end

    local currentPetData = playerData.inventory.pets[PetID]
    if not currentPetData then
        debugPrint("🚨 Pet disappeared from inventory!")
        return true
    end

    local currentPetID = currentPetData.id or ""
    if currentPetID ~= selectedPetOriginalID then
        debugPrint("🥚🔄 HATCHED! Was: " .. tostring(selectedPetOriginalID) .. " Now: " .. currentPetID)
        return true
    end

    return false
end

local function reSelectPetAfterHatch()
    debugPrint("🔄 Re-selecting after hatch...")
    local wasRunning = PetFarmMode
    PetFarmMode = false
    task.wait(2)

    PetID = nil
    selectedPetName = nil
    selectedPetType = nil
    selectedPetOriginalID = nil

    local newPet = findBestPet()
    if newPet then
        PetID = newPet.unique
        selectedPetName = newPet.id
        selectedPetType = newPet.petType
        selectedPetOriginalID = newPet.id

        equipSelectedPet(newPet.unique)
        task.wait(3)

        updateSelectedPetDisplay()

        if wasRunning then
            PetFarmMode = true
            petFarmCoroutine = coroutine.wrap(function()
                local char = ensureCharacterSpawned()
                if char and ensurePetEquipped(PetID, 15) then
                    -- Re-enter monitoring
                    local SCAN_INTERVAL = 10
                    local lastEquipCheckTime = 0
                    local EQUIP_CHECK_INTERVAL = 5
                    while PetFarmMode do
                        local currentTime = os.time()
                        if currentTime - lastEquipCheckTime >= EQUIP_CHECK_INTERVAL then
                            if PetID and not isPetEquipped(PetID) then
                                ensurePetEquipped(PetID, 8)
                            end
                            lastEquipCheckTime = currentTime
                        end
                        if currentTime - lastHatchCheckTime >= HATCH_CHECK_INTERVAL then
                            if checkForPetHatch() then
                                reSelectPetAfterHatch()
                                return
                            end
                            lastHatchCheckTime = currentTime
                        end
                        local pd = getPlayerData()
                        if pd and pd.ailments_manager and pd.ailments_manager.ailments then
                            for ailmentId, ailmentData in pairs(pd.ailments_manager.ailments) do
                                if ailmentId == PetID and ailmentData and type(ailmentData) == "table" then
                                    for ailmentType, furnitureName in pairs(AILMENT_TASKS) do
                                        if ailmentData[ailmentType] and type(ailmentData[ailmentType]) == "table" then
                                            if not lastTaskTime[ailmentType] or (currentTime - lastTaskTime[ailmentType]) >= TASK_COOLDOWN then
                                                local success = false
                                                if ailmentType == "pet_me" then
                                                    success = handlePetMeAilment()
                                                elseif ailmentType == "mystery" then
                                                    success = resolveMysteryAilment()
                                                elseif ailmentType == "play" then
                                                    success = handlePlayAilment()
                                                elseif ailmentType == "walk" then
                                                    success = handleWalkAilment()
                                                elseif ailmentType == "ride" then
                                                    success = handleRideAilment()
                                                elseif ailmentType == "sick" then
                                                    success = handleSickAilment()
                                                else
                                                    local fe = findFurnitureByName(furnitureName)
                                                    if not fe then checkAndBuyFurniture(furnitureName) end
                                                    success = useFurnitureWithPet(furnitureName)
                                                end
                                                if success then lastTaskTime[ailmentType] = currentTime end
                                                updateSelectedPetDisplay()
                                                break
                                            end
                                        end
                                    end
                                end
                            end
                        end
                        task.wait(SCAN_INTERVAL)
                    end
                end
            end)()

            if ui and ui.petFarmButton then
                ui.petFarmButton.Text = "🛑 STOP PETFARM"
                ui.petFarmButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
                ui.petFarmButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end

        debugPrint("✅ Switched to: " .. newPet.id)
    else
        updateSelectedPetDisplay()
    end
end

