local function getPetPenSnapshot()
    local playerData = getPlayerData()
    if not playerData or not playerData.idle_progression_manager or not playerData.idle_progression_manager.active_pets then return {} end
    local snapshot = {}
    for uniqueId, _ in pairs(playerData.idle_progression_manager.active_pets) do
        local pet = playerData.inventory.pets[uniqueId]
        if pet then table.insert(snapshot, { name = pet.id, age = pet.properties.age or 0, neon = pet.properties.neon or false, unique_id = uniqueId }) end
    end
    return snapshot
end

local function purgeNonPriorityGarbage()
    local playerData = getPlayerData()
    if not playerData or not playerData.idle_progression_manager or not playerData.idle_progression_manager.active_pets then return 0 end
    local removed = 0
    for uniqueId, _ in pairs(playerData.idle_progression_manager.active_pets) do
        local pet = playerData.inventory.pets[uniqueId]
        if pet and pet.id and pet.properties then
            local isNeon = pet.properties.neon or false
            local cleanName = string.lower(pet.id)
            -- Hatched pets (like "dog" or "cat") are NOT in prioritySet, so they get purged!
            if not isNeon and not prioritySet[cleanName] then
                debugPrint("REMOVING TRASH/HATCHED PET: " .. pet.id)
                safeRemoteCall({"IdleProgressionAPI/RemovePet"}, "FireServer", uniqueId)
                removed = removed + 1; task.wait(0.7)
            end
        end
    end
    return removed
end

local function performNeonFusion()
    debugPrint("Checking for eligible Neon Fusion sets...")
    local fusionsPerformed = 0
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then return 0 end
    local ageSixPetsByType = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData.properties and (petData.properties.age or 0) == 6 and not (petData.properties.neon or false) and not (petData.properties.mega or false) then
            local petType = petData.id; if not ageSixPetsByType[petType] then ageSixPetsByType[petType] = {} end; table.insert(ageSixPetsByType[petType], uniqueId)
        end
    end
    for petType, pets in pairs(ageSixPetsByType) do
        while #pets >= 4 do
            debugPrint(string.format("Found 4+ age 6 pets of type: %s. Attempting Neon Fusion...", petType))
            local fusionSet = {}; for i = 1, 4 do table.insert(fusionSet, pets[1]); table.remove(pets, 1) end
            local success, err = pcall(function()
                local api = ReplicatedStorage:FindFirstChild("API"); if not api then return nil end
                local neonAPI = api:FindFirstChild("PetAPI/DoNeonFusion")
                if neonAPI then return neonAPI:InvokeServer(fusionSet) else local a = api:FindFirstChild("PetAPI/NeonFusion") or api:FindFirstChild("PetAPI/FuseNeon") or api:FindFirstChild("NeonAPI/Fuse"); if a then return a:InvokeServer(fusionSet) else warn("Could not find neon fusion API!"); return nil end end
            end)
            if success and err ~= nil then debugPrint(string.format("SUCCESS: Fused 4 %s into a Neon!", petType)); fusionsPerformed = fusionsPerformed + 1; task.wait(3) else debugPrint("FAILED Neon Fusion: " .. tostring(err)); for _, id in ipairs(fusionSet) do table.insert(pets, id) end; break end
        end
    end
    return fusionsPerformed
end

-- STRICT PRIORITY ADDITION
local function addPriorityPets(snapshot)
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then return 0 end
    local slotsOpen = 4 - #snapshot
    if slotsOpen <= 0 then return 0 end

    local inPen = {}
    for _, pet in ipairs(snapshot) do inPen[pet.unique_id] = true end

    local added = 0
    local addedSet = {}
    
    -- Priority 1: NEON pets (Under Age 6 ONLY)
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData.properties and petData.properties.neon and (petData.properties.age or 0) < 6 and not inPen[uniqueId] and added < slotsOpen and not addedSet[uniqueId] then
            safeRemoteCall({"IdleProgressionAPI/AddPet"}, "FireServer", uniqueId)
            debugPrint("Added NEON: " .. petData.id .. " (Age: " .. tostring(petData.properties.age or 0) .. ")"); added += 1; addedSet[uniqueId] = true; task.wait(0.6)
        end
    end
    
    -- Priority 2: Priority Eggs (Under Age 6 ONLY)
    for _, eggName in ipairs(priorityEggs) do
        for uniqueId, petData in pairs(playerData.inventory.pets) do
            if petData.id == eggName and (petData.properties.age or 0) < 6 and not inPen[uniqueId] and added < slotsOpen and not addedSet[uniqueId] then
                safeRemoteCall({"IdleProgressionAPI/AddPet"}, "FireServer", uniqueId)
                debugPrint("Added PRIORITY: " .. petData.id); added += 1; addedSet[uniqueId] = true; task.wait(0.6)
            end
        end
    end
    
    -- Priority 3: Auto-buy cracked eggs if STILL slots open
    -- (Removed the logic that added random hatched inventory pets back into the pen)
    while added < slotsOpen and AutoPetPenMode do
        debugPrint("No valid priority pets in inventory. Buying cracked_egg to fill slot...")
        local bought = pcall(function() ReplicatedStorage.API["ShopAPI/BuyItem"]:InvokeServer("pets", "cracked_egg", {buy_count = 1}) end)
        
        if bought then
            task.wait(3)
            local newData = getPlayerData()
            if newData and newData.inventory and newData.inventory.pets then
                local foundEgg = false
                for uniqueId, petData in pairs(newData.inventory.pets) do
                    if petData.id == "cracked_egg" and (petData.properties.age or 0) < 6 and not inPen[uniqueId] and not addedSet[uniqueId] then
                        safeRemoteCall({"IdleProgressionAPI/AddPet"}, "FireServer", uniqueId)
                        debugPrint("Added PURCHASED cracked_egg")
                        added += 1; addedSet[uniqueId] = true; inPen[uniqueId] = true; foundEgg = true; task.wait(0.6); break
                    end
                end
                if not foundEgg then debugPrint("Purchased cracked_egg but couldn't find it - stopping auto-buy"); break end
            end
        else
            debugPrint("Failed to buy cracked_egg (out of money?) - stopping auto-buy"); break
        end
    end
    
    debugPrint("Added " .. added .. " pets this cycle")
    return added
end

local function startAutoPetPen()
    debugPrint("Auto PetPen loop started!")
    lastPetPenCommitTime = os.time()
    while AutoPetPenMode do
        debugPrint("=== AUTO PETPEN CYCLE START ===")
        
        -- 0. Commit progression FIRST to update pet ages locally!
        pcall(function() ReplicatedStorage.API["IdleProgressionAPI/CommitAllProgression"]:FireServer() end)
        debugPrint("Committed progression to refresh age data")
        task.wait(4)
        
        -- 1. Check for Neon Fusion
        local fusionsPerformed = performNeonFusion()
        if fusionsPerformed > 0 then task.wait(5) end
        
        -- 2. Purge trash (Also purges hatched pets like Dogs/Cats)
        purgeNonPriorityGarbage()
        task.wait(2)
        
        -- 3. Remove aged pets (Pets >= Age 6 are useless in the pen)
        local snapshot = getPetPenSnapshot()
        for _, pet in ipairs(snapshot) do
            if pet.age >= 6 then
                debugPrint("Removing aged pet: " .. pet.name .. " (Age: " .. pet.age .. ")")
                pcall(function() ReplicatedStorage.API["IdleProgressionAPI/RemovePet"]:FireServer(pet.unique_id) end)
                task.wait(0.7)
            end
        end
        
        -- 4. Add best pets (Strictly Neons & Priority Eggs, buys cracked eggs if empty)
        task.wait(2)
        snapshot = getPetPenSnapshot()
        addPriorityPets(snapshot)
        
        debugPrint("=== AUTO PETPEN CYCLE COMPLETE ===")
        task.wait(60)
    end
end

local function toggleAutoPetPenMode()
    AutoPetPenMode = not AutoPetPenMode
    if AutoPetPenMode then lastPetPenCommitTime = os.time(); autoPetPenCoroutine = coroutine.wrap(startAutoPetPen)(); debugPrint("Auto PetPen ENABLED") else debugPrint("Auto PetPen DISABLED") end
end

