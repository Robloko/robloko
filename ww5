-- INVENTORY CHECKS
-- ==================================================================

local function isPetStillInInventory(u) if not u then return false end; local d = getPlayerData(); if not d or not d.inventory or not d.inventory.pets then return false end; return d.inventory.pets[u] ~= nil end
local function getAllValidPets()
    local playerData = getPlayerData(); if not playerData or not playerData.inventory or not playerData.inventory.pets then return {} end
    local v = {}; for u, p in pairs(playerData.inventory.pets) do if p and p.id and p.properties then local n = string.lower(p.id); if not string.find(n, "practice_dog") then table.insert(v, { unique = u, id = p.id, age = p.properties.age or 0, neon = p.properties.neon or false, petType = detectPetType(p.id) }) end end end
    table.sort(v, function(a, b) local function p(t) if t == "starter_egg" then return 1 elseif t == "dog" then return 2 elseif t == "cat" then return 3 end return 4 end; local ap, bp = p(a.petType), p(b.petType); if ap ~= bp then return ap < bp end; return a.age > b.age end); return v
end

-- ==================================================================
-- FIND BEST PET
-- ==================================================================

local function findBestPet()
    local v = getAllValidPets()
    if eggHasBeenHatched then debugPrint("🔍 Post-hatch mode: Dog/Cat ONLY..."); local d, c = nil, nil; for _, p in ipairs(v) do if p.petType == "dog" and (not d or p.age > d.age) then d = p elseif p.petType == "cat" and (not c or p.age > c.age) then c = p end end; local pk = d or c; return pk end
    debugPrint("🔍 Initial mode: Egg > Dog > Cat..."); local s, d, c = nil, nil, nil; for _, p in ipairs(v) do if p.petType == "starter_egg" and (not s or p.age > s.age) then s = p elseif p.petType == "dog" and (not d or p.age > d.age) then d = p elseif p.petType == "cat" and (not c or p.age > c.age) then c = p end end; return s or d or c or v[1]
end

local function equipSelectedPet(u) if not u then return false end; if isPetEquipped(u) then return true end; local s = safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", u, { use_sound_delay = true, equip_as_last = false }); if s then task.wait(3) end; return s end

