local function getPetTypeIcon(p) if p == "starter_egg" then return "🥚" elseif p == "dog" then return "🐕" elseif p == "cat" then return "🐈" else return "📦" end end
local function detectPetType(p) local n = string.lower(tostring(p)); if string.find(n, "starter_egg") then return "starter_egg" elseif string.find(n, "dog") then return "dog" elseif string.find(n, "cat") then return "cat" else return "other" end end
local function buildPetKey(p, a, n) local t = detectPetType(p); local i = getPetTypeIcon(t); local ne = n and " 🔥NEON" or ""; return string.format("%s %s (Age: %d)%s", i, p, a, ne) end

