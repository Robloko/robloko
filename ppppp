-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Player
local player = Players.LocalPlayer

-- Function to print all inventory categories
local function printInventoryCategories()
    print("🔍 INVENTORY CATEGORIES")
    print("=======================")
    
    -- Get player data
    local success, data = pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        return clientData.get_data()[player.Name]
    end)
    
    if not success or not data then
        print("❌ Failed to get player data")
        return
    end
    
    -- Check if inventory exists
    if not data.inventory then
        print("❌ No inventory found for player")
        return
    end
    
    -- Print all categories in inventory
    print("\n📦 INVENTORY CATEGORIES FOUND:")
    print("-------------------------------")
    
    local categoryCount = 0
    for categoryName, categoryData in pairs(data.inventory) do
        categoryCount = categoryCount + 1
        
        -- Determine the type and size of the category
        local dataType = typeof(categoryData)
        local itemCount = 0
        
        if dataType == "table" then
            for _ in pairs(categoryData) do
                itemCount = itemCount + 1
            end
        end
        
        print(string.format("  📁 %s:", categoryName))
        print(string.format("     Type: %s", dataType))
        print(string.format("     Items: %d", itemCount))
        
        -- If it's a category with items, show a sample
        if itemCount > 0 and dataType == "table" then
            local firstKey, firstValue = next(categoryData)
            if firstKey then
                print(string.format("     Sample key: %s", tostring(firstKey)))
                print(string.format("     Sample value type: %s", typeof(firstValue)))
            end
        end
        print("")
    end
    
    if categoryCount == 0 then
        print("  ❌ No categories found in inventory")
    else
        print("✅ Total categories: " .. categoryCount)
    end
    
    -- Return the categories for potential further use
    return data.inventory
end

-- Run the function
local inventory = printInventoryCategories()

-- Optional: If you want to see the raw structure
print("\n📋 RAW INVENTORY KEYS:")
print("======================")
if inventory then
    for key, _ in pairs(inventory) do
        print("  - " .. tostring(key))
    end
end
