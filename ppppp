-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Player
local player = Players.LocalPlayer

-- Simple function to inspect Sugarfest inventory
local function inspectSugarfest()
    print("🍬 INSPECTING SUGARFEST INVENTORY")
    print("==================================")
    
    local success, data = pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        return clientData.get_data()[player.Name]
    end)
    
    if not success or not data then
        print("❌ Failed to get player data")
        return
    end
    
    -- Check for Sugarfest data in different possible locations
    local sugarfestData = nil
    
    -- Try to find Sugarfest in inventory categories
    if data.inventory then
        -- Check for sugarfest category
        if data.inventory.sugarfest then
            sugarfestData = data.inventory.sugarfest
            print("📁 Found Sugarfest in inventory.sugarfest")
        -- Check if sugarfest items are in a different category
        elseif data.inventory.events and data.inventory.events.sugarfest then
            sugarfestData = data.inventory.events.sugarfest
            print("📁 Found Sugarfest in inventory.events.sugarfest")
        end
    end
    
    -- Also check in player data events table
    if not sugarfestData and data.events and data.events.sugarfest then
        sugarfestData = data.events.sugarfest
        print("📁 Found Sugarfest in data.events.sugarfest")
    end
    
    if not sugarfestData then
        print("❌ No Sugarfest data found in inventory")
        print("\n📋 Available inventory categories:")
        if data.inventory then
            for category, _ in pairs(data.inventory) do
                print("   - " .. category)
            end
        end
        return
    end
    
    -- Count and display Sugarfest items
    local itemCount = 0
    for _ in pairs(sugarfestData) do
        itemCount = itemCount + 1
    end
    
    print("📊 Total Sugarfest items: " .. itemCount)
    print("")
    
    if itemCount == 0 then
        print("No Sugarfest items found")
        return
    end
    
    -- Show all Sugarfest items with their details
    local count = 0
    for itemKey, itemData in pairs(sugarfestData) do
        count = count + 1
        
        print("🍭 Item #" .. count)
        print("   Key: " .. tostring(itemKey))
        
        -- Try to display item information based on structure
        if type(itemData) == "table" then
            if itemData.id then
                print("   ID: " .. itemData.id)
            end
            if itemData.type then
                print("   Type: " .. itemData.type)
            end
            if itemData.name then
                print("   Name: " .. itemData.name)
            end
            if itemData.amount then
                print("   Amount: " .. itemData.amount)
            end
            if itemData.claimed then
                print("   Claimed: " .. tostring(itemData.claimed))
            end
            
            -- Show any other properties
            local hasOtherProps = false
            for prop, value in pairs(itemData) do
                if prop ~= "id" and prop ~= "type" and prop ~= "name" and prop ~= "amount" and prop ~= "claimed" then
                    if not hasOtherProps then
                        print("   Other properties:")
                        hasOtherProps = true
                    end
                    print("      " .. prop .. ": " .. tostring(value))
                end
            end
        else
            print("   Value: " .. tostring(itemData))
        end
        print("   ---")
    end
    
    -- Also check for any Sugarfest-related progress/points
    if data.sugarfest_points or data.SugarfestPoints then
        print("\n🍬 Sugarfest Points:")
        print("   Points: " .. tostring(data.sugarfest_points or data.SugarfestPoints))
    end
    
    if data.sugarfest_level or data.SugarfestLevel then
        print("   Level: " .. tostring(data.sugarfest_level or data.SugarfestLevel))
    end
end

-- Run the function
inspectSugarfest()
