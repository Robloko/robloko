-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Player
local player = Players.LocalPlayer

-- Simple function to print all inventory categories
local function printInventoryCategories()
    print("📋 INVENTORY CATEGORIES")
    print("========================")
    
    local success, data = pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        return clientData.get_data()[player.Name]
    end)
    
    if not success or not data or not data.inventory then
        print("❌ Failed to get inventory data")
        return
    end
    
    local categories = {}
    for category, categoryData in pairs(data.inventory) do
        local itemCount = 0
        if type(categoryData) == "table" then
            for _ in pairs(categoryData) do
                itemCount = itemCount + 1
            end
        end
        table.insert(categories, {
            name = category,
            count = itemCount
        })
    end
    
    -- Sort categories alphabetically
    table.sort(categories, function(a, b) return a.name < b.name end)
    
    for _, cat in ipairs(categories) do
        print(string.format("   📁 %s: %d items", cat.name, cat.count))
    end
    
    print("\n📊 Total categories: " .. #categories)
end

-- Run the function
printInventoryCategories()
