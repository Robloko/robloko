-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Player
local player = Players.LocalPlayer

-- Function to find specific item by ID
local function findItemById(targetId)
    print("🔍 SEARCHING FOR ITEM: " .. targetId)
    print("======================================")
    
    local success, data = pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        return clientData.get_data()[player.Name]
    end)
    
    if not success or not data then
        print("❌ Failed to get player data")
        return
    end
    
    local foundItems = {}
    
    -- Search through all inventory categories
    if data.inventory then
        for category, categoryData in pairs(data.inventory) do
            if type(categoryData) == "table" then
                -- Check if the target ID exists directly in this category
                if categoryData[targetId] then
                    table.insert(foundItems, {
                        category = category,
                        id = targetId,
                        data = categoryData[targetId],
                        matchType = "exact_key"
                    })
                end
                
                -- Also search through items that might have this as their id field
                for itemKey, itemValue in pairs(categoryData) do
                    if type(itemValue) == "table" then
                        -- Check if item has an id field matching target
                        if itemValue.id == targetId then
                            table.insert(foundItems, {
                                category = category,
                                id = itemKey,
                                data = itemValue,
                                matchType = "id_field"
                            })
                        end
                        
                        -- Check other possible ID fields
                        if itemValue.itemId == targetId or 
                           itemValue.item_id == targetId or
                           itemValue.uniqueId == targetId or
                           itemValue.unique_id == targetId then
                            table.insert(foundItems, {
                                category = category,
                                id = itemKey,
                                data = itemValue,
                                matchType = "alternate_field"
                            })
                        end
                    end
                end
            end
        end
    end
    
    -- Also check in player data events
    if data.events then
        for eventName, eventData in pairs(data.events) do
            if type(eventData) == "table" then
                if eventData[targetId] then
                    table.insert(foundItems, {
                        category = "events." .. eventName,
                        id = targetId,
                        data = eventData[targetId],
                        matchType = "exact_key"
                    })
                end
            end
        end
    end
    
    -- Check in pets inventory specifically
    if data.inventory and data.inventory.pets then
        for petId, petData in pairs(data.inventory.pets) do
            if petId == targetId or (type(petData) == "table" and petData.id == targetId) then
                table.insert(foundItems, {
                    category = "inventory.pets",
                    id = petId,
                    data = petData,
                    matchType = "pet"
                })
            end
        end
    end
    
    -- Display results
    if #foundItems == 0 then
        print("❌ Item not found in inventory")
        
        -- Show sample of items to help debug
        print("\n📋 First 20 items in inventory:")
        local count = 0
        if data.inventory then
            for category, categoryData in pairs(data.inventory) do
                if type(categoryData) == "table" then
                    for itemKey, _ in pairs(categoryData) do
                        count = count + 1
                        if count <= 20 then
                            print(string.format("   [%s] %s", category, tostring(itemKey)))
                        end
                    end
                end
            end
        end
    else
        print("✅ Found " .. #foundItems .. " matches!")
        print("")
        
        for i, item in ipairs(foundItems) do
            print("📦 Match #" .. i)
            print("   Location: " .. item.category)
            print("   Match type: " .. item.matchType)
            print("   Item key: " .. tostring(item.id))
            
            if type(item.data) == "table" then
                print("   Item data:")
                for prop, value in pairs(item.data) do
                    if type(value) ~= "table" then
                        print("      " .. prop .. ": " .. tostring(value))
                    else
                        print("      " .. prop .. ": [table]")
                    end
                end
                
                -- Check if this is Sugar Dice
                if item.data.id and type(item.data.id) == "string" then
                    if item.data.id:find("sugar") and item.data.id:find("dice") then
                        print("   🎲 This appears to be a Sugar Dice!")
                    end
                end
            else
                print("   Value: " .. tostring(item.data))
            end
            print("   ---")
        end
    end
end

