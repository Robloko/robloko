-- Function to safely inspect any object
local function safeInspect(obj, name, depth)
    depth = depth or 0
    local indent = string.rep("  ", depth)
    
    local objType = typeof(obj)
    print(indent .. name .. " (" .. objType .. ")")
    
    if objType == "table" and depth < 2 then
        for key, value in pairs(obj) do
            safeInspect(value, "[" .. tostring(key) .. "]", depth + 1)
        end
    end
end

