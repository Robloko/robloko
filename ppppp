-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Player
local player = Players.LocalPlayer

-- Function to find Sugar Dice in inventory
local function findSugarDice()
    print("🎲 SEARCHING FOR SUGAR DICE")
    print("============================")
    
    local success, data = pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        return clientData.get_data()[player.Name]
    end)
    
    if not success or not data then
        print("❌ Failed to get player data")
        return
    end
    
    local diceFound = {}
    
    -- Search through all inventory categories
    if data.inventory then
        -- Search through each category in inventory
        for category, categoryData in pairs(data.inventory) do
            if type(categoryData) == "table" then
                -- Look for dice in this category
                for itemId, itemInfo in pairs(categoryData) do
                    -- Check various possible identifiers for Sugar Dice
                    local itemName = tostring(itemId):lower()
                    local itemId_lower = tostring(itemInfo and itemInfo.id or ""):lower()
                    
                    -- Look for sugar dice related names
                    if itemName:find("sugar") and itemName:find("dice") or
                       itemId_lower:find("sugar") and itemId_lower:find("dice") or
                       itemName == "sugardice" or
                       itemId_lower == "sugardice" or
                       itemName == "sugar_dice" or
                       itemId_lower == "sugar_dice" then
                        
                        table.insert(diceFound, {
                            category = category,
                            id = itemId,
                            data = itemInfo
                        })
                    end
                    
                    -- Also check if the item data has name field
                    if type(itemInfo) == "table" and itemInfo.name then
                        local name_lower = itemInfo.name:lower()
                        if name_lower:find("sugar") and name_lower:find("dice") then
                            table.insert(diceFound, {
                                category = category,
                                id = itemId,
                                data = itemInfo
                            })
                        end
                    end
                end
            end
        end
    end
    
    -- Also check in events table
    if data.events then
        for eventName, eventData in pairs(data.events) do
            if eventName:lower():find("sugar") and type(eventData) == "table" then
                for itemId, itemInfo in pairs(eventData) do
                    local itemId_lower = tostring(itemId):lower()
                    if itemId_lower:find("dice") then
                        table.insert(diceFound, {
                            category = "events." .. eventName,
                            id = itemId,
                            data = itemInfo
                        })
                    end
                end
            end
        end
    end
    
    -- Display results
    if #diceFound == 0 then
        print("❌ No Sugar Dice found in inventory")
        
        -- Show what categories were checked
        print("\n📋 Checked inventory categories:")
        if data.inventory then
            for category, _ in pairs(data.inventory) do
                print("   - " .. category)
            end
        end
        
        -- Try to list all items to help debug
        print("\n🔍 Listing all inventory items (first 20):")
        local itemCount = 0
        if data.inventory then
            for category, categoryData in pairs(data.inventory) do
                if type(categoryData) == "table" then
                    for itemId, _ in pairs(categoryData) do
                        itemCount = itemCount + 1
                        if itemCount <= 20 then
                            print("   [" .. category .. "] " .. tostring(itemId))
                        end
                    end
                end
            end
        end
    else
        print("✅ Found " .. #diceFound .. " Sugar Dice!")
        print("")
        
        -- Display each dice found
        for i, dice in ipairs(diceFound) do
            print("🎲 Sugar Dice #" .. i)
            print("   Location: " .. dice.category)
            print("   ID: " .. tostring(dice.id))
            
            if type(dice.data) == "table" then
                -- Show all properties of the dice
                print("   Properties:")
                for prop, value in pairs(dice.data) do
                    print("      " .. prop .. ": " .. tostring(value))
                end
            else
                print("   Value: " .. tostring(dice.data))
            end
            print("   ---")
        end
        
        -- Check for dice count/amount
        local totalDice = 0
        for _, dice in ipairs(diceFound) do
            if type(dice.data) == "table" and dice.data.amount then
                totalDice = totalDice + dice.data.amount
            elseif type(dice.data) == "table" and dice.data.count then
                totalDice = totalDice + dice.data.count
            else
                totalDice = totalDice + 1
            end
        end
        
        if totalDice > #diceFound then
            print("📊 Total dice count (including stacks): " .. totalDice)
        end
    end
end

-- Run the function
findSugarDice()
