-- Quick test to verify Dog detection
local player = game.Players.LocalPlayer

-- Check Workspace.Pets
local petsFolder = workspace:FindFirstChild("Pets")
if petsFolder then
    print("✅ Pets folder found!")
    for _, pet in ipairs(petsFolder:GetChildren()) do
        print("   Pet found: " .. pet.Name)
        print("   Full path: " .. pet:GetFullName())
        
        -- Check properties
        print("   Has Humanoid: " .. tostring(pet:FindFirstChild("Humanoid") ~= nil))
        print("   Has Owner: " .. tostring(pet:FindFirstChild("Owner") ~= nil))
    end
else
    print("❌ Pets folder not found!")
end

-- Try to find Dog anywhere
local dog = workspace:FindFirstChild("Dog", true)
if dog then
    print("✅ Found Dog at: " .. dog:GetFullName())
else
    print("❌ Dog not found in workspace")
end
