-- Simple Neon Fuser Script
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Function to fuse age 6 pets into neon
local function fuseNeonPets()
    print("Searching for age 6 pets to fuse...")
    
    -- Get player's pet inventory
    local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
    local playerData = clientData.get_data()[player.Name]
    
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        print("No pets found in inventory!")
        return
    end
    
    -- Group age 6 pets by their type
    local ageSixPets = {}
    
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        local age = petData.properties.age or 0
        local isNeon = petData.properties.neon or false
        local petType = petData.id
        
        -- Only collect non-neon pets at age 6
        if age == 6 and not isNeon then
            if not ageSixPets[petType] then
                ageSixPets[petType] = {}
            end
            table.insert(ageSixPets[petType], uniqueId)
        end
    end
    
    -- Fuse each group of 4
    local fused = 0
    for petType, petList in pairs(ageSixPets) do
        while #petList >= 4 do
            print(string.format("Fusing 4 %s into neon...", petType))
            
            -- Take first 4 pets
            local fusionSet = {}
            for i = 1, 4 do
                table.insert(fusionSet, petList[i])
            end
            
            -- Perform fusion
            local success, err = pcall(function()
                return ReplicatedStorage.API:FindFirstChild("PetAPI/DoNeonFusion"):InvokeServer(fusionSet)
            end)
            
            if success then
                print("Successfully created neon " .. petType .. "!")
                fused = fused + 1
                -- Remove fused pets from list
                for i = 1, 4 do
                    table.remove(petList, 1)
                end
                task.wait(2) -- Wait between fusions
            else
                print("Fusion failed: " .. tostring(err))
                break
            end
        end
    end
    
    if fused == 0 then
        print("No age 6 pets found to fuse. Need 4 of the same type at age 6!")
    else
        print(string.format("Completed %d neon fusion(s)!", fused))
    end
end

-- Run the fuser
fuseNeonPets()
