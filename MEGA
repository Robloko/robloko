-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Function to fuse 4 neon pets of the same type (age 6) into a mega pet
local function fuseNeonPetsToMega()
    -- Get player data
    local success, playerData = pcall(function()
        return require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[game.Players.LocalPlayer.Name]
    end)

    if not success or not playerData or not playerData.inventory or not playerData.inventory.pets then
        warn("Failed to get player data or pet inventory!")
        return false
    end

    -- Group neon pets by type and age 6
    local neonPetsByType = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData.properties and petData.properties.neon and (petData.properties.age or 0) == 6 then
            local petType = petData.id
            if not neonPetsByType[petType] then
                neonPetsByType[petType] = {}
            end
            table.insert(neonPetsByType[petType], uniqueId)
        end
    end

    -- Check for eligible sets (4 neon pets of the same type)
    for petType, petIds in pairs(neonPetsByType) do
        if #petIds >= 4 then
            print("Found 4+ neon pets of type: " .. petType .. ". Attempting Mega Fusion...")

            -- Take the first 4 pets of this type
            local fusionSet = {petIds[1], petIds[2], petIds[3], petIds[4]}

            -- Call the Mega Fusion API
            local fusionSuccess, fusionResult = pcall(function()
                return ReplicatedStorage.API["PetAPI/DoMegaFusion"]:InvokeServer(fusionSet)
            end)

            if fusionSuccess then
                print("SUCCESS: Fused 4 neon " .. petType .. " into a Mega pet!")
                return true
            else
                warn("FAILED to perform Mega Fusion: " .. tostring(fusionResult))
                return false
            end
        end
    end

    warn("No eligible Mega Fusion sets found (need 4 neon pets of the same type, age 6).")
    return false
end

-- Example usage:
fuseNeonPetsToMega()
