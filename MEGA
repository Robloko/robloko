-- Neon Pet Viewer + Auto Fuser
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local function fuseNeonPets()
    local data = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[player.Name]
    local neons = {}
    local age6Neons = {}
    
    -- First, find all neon pets
    for id, pet in pairs(data.inventory.pets) do
        if pet.properties.neon then
            local age = pet.properties.age or 0
            local petName = pet.id
            table.insert(neons, petName .. " (Age: " .. age .. ")")
            
            -- Track age 6 neons for fusing
            if age == 6 then
                if not age6Neons[petName] then
                    age6Neons[petName] = {}
                end
                table.insert(age6Neons[petName], id)
            end
        end
    end
    
    -- Show all neon pets
    print("=== NEON PETS IN INVENTORY ===")
    if #neons > 0 then
        for i, pet in ipairs(neons) do
            print(i .. ". " .. pet)
        end
        print("Total Neons: " .. #neons)
    else
        print("No neon pets found!")
    end
    
    -- Fuse age 6 neons into mega
    print("\n=== CHECKING FOR MEGA FUSIONS ===")
    local fused = 0
    
    for petType, petList in pairs(age6Neons) do
        while #petList >= 4 do
            print(string.format("Fusing 4 age 6 %s neons into MEGA...", petType))
            
            -- Take first 4 pets
            local fusionSet = {}
            for i = 1, 4 do
                table.insert(fusionSet, petList[i])
            end
            
            -- Perform fusion (using correct API endpoint for mega)
            local success, err = pcall(function()
                -- Try mega fusion endpoint
                local megaAPI = ReplicatedStorage.API:FindFirstChild("PetAPI/DoMegaFusion")
                if megaAPI then
                    return megaAPI:InvokeServer(fusionSet)
                else
                    -- Alternative: Try neon fusion again (might create mega if already neon)
                    return ReplicatedStorage.API:FindFirstChild("PetAPI/DoNeonFusion"):InvokeServer(fusionSet)
                end
            end)
            
            if success then
                print("✓ Successfully created MEGA " .. petType .. "!")
                fused = fused + 1
                -- Remove fused pets from list
                for i = 1, 4 do
                    table.remove(petList, 1)
                end
                task.wait(2)
            else
                print("✗ Fusion failed: " .. tostring(err))
                break
            end
        end
    end
    
    if fused > 0 then
        print(string.format("\n✓ Completed %d mega fusion(s)!", fused))
    else
        print("\nNo age 6 neons found to fuse. Need 4 of the same neon pet at age 6 to make mega!")
    end
    
    -- Show updated neon count
    task.wait(3)
    local newData = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[player.Name]
    local newNeonCount = 0
    for id, pet in pairs(newData.inventory.pets) do
        if pet.properties.neon and not pet.properties.mega then
            newNeonCount = newNeonCount + 1
        end
    end
    print("\n=== UPDATED INVENTORY ===")
    print("Remaining neons: " .. newNeonCount)
end

-- Run the fuser
fuseNeonPets()
