-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- LocalPlayer
local player = Players.LocalPlayer

-- Функция для выполнения Neon Fusion
local function performNeonFusion()
    -- Получаем данные игрока
    local success, playerData = pcall(function()
        return require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[player.Name]
    end)

    if not success or not playerData or not playerData.inventory or not playerData.inventory.pets then
        warn("Не удалось получить данные питомцев!")
        return 0
    end

    -- Группируем питомцев возраста 6+ по типу
    local ageSixPetsByType = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData.properties and petData.properties.age == 6 and not petData.properties.neon then
            local petType = petData.id
            if not ageSixPetsByType[petType] then
                ageSixPetsByType[petType] = {}
            end
            table.insert(ageSixPetsByType[petType], uniqueId)
        end
    end

    -- Количество выполненных слияний
    local fusionsPerformed = 0

    -- Проверяем каждый тип питомцев
    for petType, petIds in pairs(ageSixPetsByType) do
        -- Если есть 4+ питомца одного типа, сливаем их
        while #petIds >= 4 do
            print(`Найдено 4+ питомцев типа {petType}. Выполняем Neon Fusion...`)

            -- Берём первых 4 питомцев
            local fusionSet = {petIds[1], petIds[2], petIds[3], petIds[4]}

            -- Выполняем Neon Fusion
            local fusionSuccess, fusionError = pcall(function()
                return ReplicatedStorage.API.PetAPI.DoNeonFusion:InvokeServer(fusionSet)
            end)

            if fusionSuccess then
                print(`Успешно слито 4 питомцев типа {petType} в неонового!`)
                fusionsPerformed += 1

                -- Удаляем слитых питомцев из списка
                for i = 1, 4 do
                    table.remove(petIds, 1)
                end

                -- Ждём 3 секунды, чтобы сервер успел обработать слияние
                task.wait(3)
            else
                warn(`Не удалось выполнить Neon Fusion: {fusionError}`)
                break
            end
        end
    end

    if fusionsPerformed > 0 then
        print(`Neon Fusion завершён. Выполнено слияний: {fusionsPerformed}`)
    else
        print("Нет подходящих питомцев для Neon Fusion (нужно 4 питомца одного типа возраста 6+).")
    end

    return fusionsPerformed
end

-- Вызываем функцию каждые 10 секунд
while true do
    performNeonFusion()
    task.wait(10)
end
