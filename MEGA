-- Function to fuse 4 neon pets of the same type into a mega pet
local function performMegaFusion()
    debugPrint("Checking for eligible Mega Fusion sets...")
    local fusionsPerformed = 0

    pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        local playerData = clientData.get_data()[player.Name]

        if not playerData or not playerData.inventory or not playerData.inventory.pets then
            debugPrint("No pet inventory data found!")
            return 0
        end

        -- Step 1: Group all age 6 neon pets by their type
        local neonAgeSixPetsByType = {}
        for uniqueId, petData in pairs(playerData.inventory.pets) do
            if petData.properties and petData.properties.age == 6 and petData.properties.neon then
                local petType = petData.id
                if not neonAgeSixPetsByType[petType] then
                    neonAgeSixPetsByType[petType] = {}
                end
                table.insert(neonAgeSixPetsByType[petType], {
                    unique_id = uniqueId,
                    name = petType
                })
            end
        end

        -- Step 2: Check each pet type for 4+ neon pets and perform fusion
        for petType, pets in pairs(neonAgeSixPetsByType) do
            while #pets >= 4 do
                debugPrint(string.format("Found 4+ age 6 neon pets of type: %s. Attempting Mega Fusion...", petType))

                -- Step 3: Take the first 4 neon pets of this type
                local fusionSet = {}
                for i = 1, 4 do
                    table.insert(fusionSet, pets[i].unique_id)
                    debugPrint(" - Using neon pet: " .. pets[i].unique_id)
                end

                -- Step 4: Perform Mega Fusion (assuming the API is "PetAPI/DoMegaFusion")
                local success, err = pcall(function()
                    return ReplicatedStorage.API:FindFirstChild("PetAPI/DoMegaFusion"):InvokeServer(fusionSet)
                end)

                if success then
                    debugPrint(string.format("SUCCESS: Fused 4 neon %s into a Mega!", petType))
                    fusionsPerformed = fusionsPerformed + 1

                    -- Remove the fused pets from the array
                    for i = 1, 4 do
                        table.remove(pets, 1)
                    end

                    task.wait(3) -- Wait for server to process
                else
                    debugPrint("FAILED to perform Mega Fusion: " .. tostring(err))
                    break -- Stop trying this pet type if fusion fails
                end
            end
        end

        if fusionsPerformed > 0 then
            debugPrint(string.format("Mega Fusion completed: %d fusions performed", fusionsPerformed))
        else
            debugPrint("No eligible Mega Fusion sets found (need 4 neon pets of same type at age 6)")
        end
    end)

    return fusionsPerformed
end
