local function performNeonFusionForNeons()
    debugPrint("Checking for eligible Neon Fusion sets (Neon pets only)...")
    local fusionsPerformed = 0
    pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        local playerData = clientData.get_data()[player.Name]
        if not playerData or not playerData.inventory or not playerData.inventory.pets then
            debugPrint("No pet inventory data found!")
            return 0
        end

        -- Шаг 1: Группируем всех НЕОНОВЫХ питомцев возраста 6+ по их типу
        local neonPetsByType = {}
        for uniqueId, petData in pairs(playerData.inventory.pets) do
            if petData.properties and (petData.properties.age or 0) == 6 and petData.properties.neon then
                local petType = petData.id
                if not neonPetsByType[petType] then
                    neonPetsByType[petType] = {}
                end
                table.insert(neonPetsByType[petType], {
                    unique_id = uniqueId,
                    name = petType
                })
            end
        end

        -- Шаг 2: Проверяем каждый тип НЕОНОВЫХ питомцев на наличие 4+ особей и выполняем слияние
        for petType, pets in pairs(neonPetsByType) do
            while #pets >= 4 do
                debugPrint(string.format("Found 4+ age 6 NEON pets of type: %s. Attempting Fusion...", petType))

                -- Шаг 3: Берём первых 4 НЕОНОВЫХ питомца этого типа
                local fusionSet = {}
                for i = 1, 4 do
                    table.insert(fusionSet, pets[i].unique_id)
                    debugPrint(" - Using NEON pet: " .. pets[i].unique_id)
                end

                -- Шаг 4: Выполняем Fusion (предполагается, что для неоновых питомцев есть отдельный метод)
                -- Пример: если в игре есть метод для слияния неоновых питомцев, используйте его
                local success, err = pcall(function()
                    -- Замените "PetAPI/DoNeonFusion" на актуальный метод для слияния неоновых питомцев
                    return ReplicatedStorage.API:FindFirstChild("PetAPI/DoNeonFusion"):InvokeServer(fusionSet)
                end)

                if success then
                    debugPrint(string.format("SUCCESS: Fused 4 NEON %s into a higher rarity!", petType))
                    fusionsPerformed = fusionsPerformed + 1

                    -- Удаляем слитых питомцев из массива
                    for i = 1, 4 do
                        table.remove(pets, 1)
                    end

                    task.wait(3) -- Ждём, пока сервер обработает слияние
                else
                    debugPrint("FAILED to perform Fusion: " .. tostring(err))
                    break -- Прекращаем попытки для этого типа, если слияние не удалось
                end
            end
        end

        if fusionsPerformed > 0 then
            debugPrint(string.format("Fusion completed: %d fusions performed", fusionsPerformed))
        else
            debugPrint("No eligible Fusion sets found (need 4 NEON pets of same type at age 6)")
        end
    end)
    return fusionsPerformed
end
