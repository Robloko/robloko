-- Сервисы
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

-- Функция для поиска метода DoNeonFusion
local function findNeonFusionMethod()
    -- Проверяем в ReplicatedStorage.API
    local api = ReplicatedStorage:FindFirstChild("API")
    if api then
        local petAPI = api:FindFirstChild("PetAPI")
        if petAPI then
            local doNeonFusion = petAPI:FindFirstChild("DoNeonFusion")
            if doNeonFusion then
                return doNeonFusion
            end
        end
    end

    -- Проверяем в ReplicatedStorage.Remotes
    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if remotes then
        local doNeonFusion = remotes:FindFirstChild("DoNeonFusion")
        if doNeonFusion then
            return doNeonFusion
        end
    end

    -- Проверяем напрямую в ReplicatedStorage
    local doNeonFusion = ReplicatedStorage:FindFirstChild("DoNeonFusion")
    if doNeonFusion then
        return doNeonFusion
    end

    return nil
end

-- Функция для поиска и слияния неоновых питомцев
local function performNeonFusion()
    print("Ищем неоновых питомцев для слияния...")

    -- Находим метод DoNeonFusion
    local doNeonFusion = findNeonFusionMethod()
    if not doNeonFusion then
        print("Ошибка: метод DoNeonFusion не найден!")
        return
    end

    -- Получаем данные игрока
    local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
    local playerData = clientData.get_data()[player.Name]

    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        print("Ошибка: данные питомцев не найдены!")
        return
    end

    -- Группируем неоновых питомцев возраста 6+ по типу
    local neonPetsByType = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData.properties and petData.properties.age == 6 and petData.properties.neon then
            local petType = petData.id
            if not neonPetsByType[petType] then
                neonPetsByType[petType] = {}
            end
            table.insert(neonPetsByType[petType], uniqueId)
        end
    end

    -- Проверяем каждый тип на наличие 4+ питомцев
    for petType, petIds in pairs(neonPetsByType) do
        if #petIds >= 4 then
            print(string.format("Найдено 4+ неоновых питомца типа %s. Начинаем слияние...", petType))

            -- Берём первых 4 питомца
            local fusionSet = {petIds[1], petIds[2], petIds[3], petIds[4]}

            -- Выполняем слияние
            local success, err = pcall(function()
                return doNeonFusion:InvokeServer(fusionSet)
            end)

            if success then
                print(string.format("Успешно слито 4 неоновых питомца типа %s!", petType))
            else
                print("Ошибка при слиянии: " .. tostring(err))
            end
        end
    end
end

-- Запускаем функцию каждые 10 секунд
while true do
    performNeonFusion()
    task.wait(10)
end
