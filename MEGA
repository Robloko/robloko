local function performMegaNeonFusion()
    debugPrint("Checking for eligible Mega-Neon Fusion sets...")
    local fusionsPerformed = 0
    pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        local playerData = clientData.get_data()[player.Name]
        if not playerData or not playerData.inventory or not playerData.inventory.pets then
            debugPrint("No pet inventory data found!")
            return 0
        end

        -- Step 1: Group all neon pets by their type
        local neonPetsByType = {}
        for uniqueId, petData in pairs(playerData.inventory.pets) do
            if petData.properties and petData.properties.neon and not petData.properties.mega_neon then
                local petType = petData.id
                if not neonPetsByType[petType] then
                    neonPetsByType[petType] = {}
                end
                table.insert(neonPetsByType[petType], {
                    unique_id = uniqueId,
                    name = petType
                })
            end
        end

        -- Step 2: Check each neon pet type for 4+ pets and perform fusion
        for petType, pets in pairs(neonPetsByType) do
            while #pets >= 4 do
                debugPrint(string.format("Found 4+ neon pets of type: %s. Attempting Mega-Neon Fusion...", petType))
                -- Step 3: Take the first 4 neon pets of this type
                local fusionSet = {}
                for i = 1, 4 do
                    table.insert(fusionSet, pets[i].unique_id)
                    debugPrint(" - Using neon pet: " .. pets[i].unique_id)
                end

                -- Step 4: Perform Mega-Neon Fusion (replace with the correct API endpoint if needed)
                local success, err = pcall(function()
                    return ReplicatedStorage.API:FindFirstChild("PetAPI/DoMegaNeonFusion"):InvokeServer(fusionSet)
                end)

                if success then
                    debugPrint(string.format("SUCCESS: Fused 4 neon %s into a Mega-Neon!", petType))
                    fusionsPerformed = fusionsPerformed + 1

                    -- Remove the fused pets from the array
                    for i = 1, 4 do
                        table.remove(pets, 1)
                    end

                    task.wait(3) -- Wait for server to process
                else
                    debugPrint("FAILED to perform Mega-Neon Fusion: " .. tostring(err))
                    break -- Stop trying this pet type if fusion fails
                end
            end
        end

        if fusionsPerformed > 0 then
            debugPrint(string.format("Mega-Neon Fusion completed: %d fusions performed", fusionsPerformed))
        else
            debugPrint("No eligible Mega-Neon Fusion sets found (need 4 neon pets of same type)")
        end
    end)
    return fusionsPerformed
end
