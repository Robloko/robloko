local function focusAndAnimatePet(petModel, animName)
    if not petModel then return false end

    local success, err = pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("AdoptAPI/FocusPet"):FireServer(petModel)
    end)
    if not success then warn("Failed to focus pet: " .. tostring(err)) return false end

    local animArgs = {
        petModel,
        {
            local_anim_name = animName or "CatIdle",
            local_anim_speed = 1,
            dont_allow_sit_states = true,
            dont_allow_remote_interaction = true,
            anim_fade_time = 0.2
        }
    }
    local success, err = pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicatePerformanceModifiers"):FireServer(unpack(animArgs))
    end)
    if not success then warn("Failed to animate pet: " .. tostring(err)) return false end

    local perfArgs = {
        petModel,
        { FocusPet = true }
    }
    local success, err = pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicateActivePerformances"):FireServer(unpack(perfArgs))
    end)
    if not success then warn("Failed to replicate performance: " .. tostring(err)) return false end

    return true
end

local function resolveMysteryAilment(petUniqueId, ailmentType, level, chosenTask)
    local args = {
        petUniqueId,
        ailmentType or "mystery",
        level,
        chosenTask
    }
    local success, err = pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("AilmentsAPI/ChooseMysteryAilment"):FireServer(unpack(args))
    end)
    if not success then warn("Failed to resolve mystery ailment: " .. tostring(err)) return false end
    return true
end

local tasks = {"bored", "sick", "hungry", "thirsty", "dirty", "toilet", "play", "walk", "ride", "pet_me"}

local petModel = workspace:WaitForChild("Pets"):FindFirstChild("Cat") or workspace:WaitForChild("Pets"):FindFirstChild("Dog")
if not petModel then warn("No pet found!") return end

local animName = petModel.Name == "Cat" and "CatIdle" or "DogIdle"

for slot = 1, 3 do
    for _, task in ipairs(tasks) do
        focusAndAnimatePet(petModel, animName)
        resolveMysteryAilment("2_865e4c0726244ceb899048213fd44f3a", "mystery", slot, task)
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicateActivePerformances"):FireServer(Instance.new("Model"), {})
        end)
        task.wait(1)
    end
end
