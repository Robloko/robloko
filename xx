local function safeRemoteCall(remotePath, method, ...)
    local args = {...}
    local remote = ReplicatedStorage:FindFirstChild("ToolAPI")  -- Updated to look directly under ReplicatedStorage
    if not remote then
        debugPrint("ToolAPI not found in ReplicatedStorage!")
        return false, "ToolAPI not found"
    end

    for _, path in ipairs(remotePath) do
        remote = remote:FindFirstChild(path)
        if not remote then
            debugPrint("Remote path not found: " .. tostring(path))
            return false, "Remote path not found"
        end
    end

    if method == "FireServer" then
        local success, result = pcall(function()
            remote:FireServer(unpack(args))
        end)
        if not success then
            debugPrint("FireServer error: " .. tostring(result))
        end
        return success, result
    elseif method == "InvokeServer" then
        local success, result = pcall(function()
            return remote:InvokeServer(unpack(args))
        end)
        if not success then
            debugPrint("InvokeServer error: " .. tostring(result))
        end
        return success, result
    else
        return false, "Invalid method"
    end
end
