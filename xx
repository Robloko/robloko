local function equipPet(petUniqueID)
    if not petUniqueID then
        debugPrint("Cannot equip pet: petUniqueID is nil!")
        return false
    end

    debugPrint("Attempting to equip pet with ID: " .. tostring(petUniqueID))

    local args = {
        petUniqueID,
        {
            use_sound_delay = true,
            equip_as_last = false
        }
    }

    local success, result = safeRemoteCall("ToolAPI", {"Equip"}, "InvokeServer", unpack(args))

    if not success then
        debugPrint("Failed to equip pet: " .. tostring(result))
        return false
    end

    debugPrint("Successfully equipped pet: " .. tostring(petUniqueID))
    return true
end
