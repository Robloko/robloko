-- Ожидание загрузки игры
repeat task.wait() until game:IsLoaded()
repeat task.wait(0.1) until game.PlaceId ~= 0 and game.PlaceId ~= nil

-- Настройки по умолчанию
local FPS_LIMIT = 5
local ENABLED = false

-- Функция для отключения эффектов
local function disableEffects()
    local lighting = game:GetService("Lighting")
    lighting.GlobalShadows = false
    lighting.FogEnd = 9e9
    lighting.Brightness = 0

    for _, effect in pairs(lighting:GetChildren()) do
        if effect:IsA("BlurEffect") or effect:IsA("SunRaysEffect") or
           effect:IsA("ColorCorrectionEffect") or effect:IsA("BloomEffect") or
           effect:IsA("DepthOfFieldEffect") then
            effect.Enabled = false
        end
    end

    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("ForceField") or obj:IsA("Sparkles") or obj:IsA("SpotLight") or
           obj:IsA("Smoke") or obj:IsA("Fire") then
            obj:Destroy()
        end
    end
end

-- Функция для включения/отключения CPU Limiter
local function toggleCPULimiter(enable, liteMode)
    ENABLED = enable
    local runService = game:GetService("RunService")

    if enable then
        if not liteMode then
            disableEffects()
            settings().Rendering.QualityLevel = "Level01"
        end

        runService:Set3dRenderingEnabled(false)
        setfpscap(FPS_LIMIT)
        game:GetService("UserGameSettings").MasterVolume = 0
    else
        runService:Set3dRenderingEnabled(true)
        setfpscap(1000)
    end
end

-- Функция для изменения лимита FPS
local function setFPSCap(fps)
    FPS_LIMIT = fps
    if ENABLED then
        setfpscap(fps)
    end
end

-- Пример использования:
-- toggleCPULimiter(true, false)  -- Включить полный CPU Limiter
-- toggleCPULimiter(true, true)   -- Включить CPU Limiter Lite
-- toggleCPULimiter(false)        -- Отключить CPU Limiter
-- setFPSCap(10)                  -- Изменить лимит FPS на 10
