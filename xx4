-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- LocalPlayer
local player = Players.LocalPlayer

-- Function to get player data
local function getPlayerData()
    local success, clientData = pcall(require, ReplicatedStorage.ClientModules.Core.ClientData)
    if not success or not clientData then return nil end
    local success2, allData = pcall(clientData.get_data, clientData)
    return success2 and allData and allData[player.Name] or nil
end

-- Function to get equipped pet ID
local function getEquippedPetID()
    local playerData = getPlayerData()
    if not playerData or not playerData.equip_manager or not playerData.equip_manager.pets then
        return nil
    end
    for _, equippedPet in pairs(playerData.equip_manager.pets) do
        if equippedPet and equippedPet.unique then
            return equippedPet.unique
        end
    end
    return nil
end

-- Function to get pet model from workspace
local function getPetModel()
    local petsFolder = workspace:FindFirstChild("Pets")
    if not petsFolder then return nil end
    
    for _, pet in ipairs(petsFolder:GetChildren()) do
        if pet:IsA("Model") then
            local owner = pet:FindFirstChild("Owner")
            if owner and owner.Value == player then
                return pet
            end
        end
    end
    return nil
end

-- Mystery Ailment Handler (SIMPLE VERSION)
local function handleMysteryAilment()
    local petID = getEquippedPetID()
    if not petID then
        print("No pet equipped!")
        return false
    end
    
    local petModel = getPetModel()
    if not petModel then
        print("Pet model not found!")
        return false
    end
    
    print("Handling mystery for pet:", petID)
    
    -- Set pet animation
    local animName = "DogIdle"
    if string.find(petModel.Name:lower(), "cat") then
        animName = "CatIdle"
    end
    
    local argsAnim = {
        petModel,
        {
            local_anim_name = animName,
            local_anim_speed = 1,
            dont_allow_sit_states = true,
            dont_allow_remote_interaction = true,
            anim_fade_time = 0.2
        }
    }
    
    local api = ReplicatedStorage:WaitForChild("API")
    api:WaitForChild("PetAPI/ReplicatePerformanceModifiers"):FireServer(unpack(argsAnim))
    
    -- Try different resolutions
    local resolutions = {"walk", "ride", "play", "sleepy", "hungry", "thirsty", "dirty", "toilet", "bored", "sick", "pet_me"}
    
    for _, resolution in ipairs(resolutions) do
        print("Trying:", resolution)
        local ok = true
        
        for level = 1, 3 do
            local success, err = pcall(function()
                api:WaitForChild("AilmentsAPI/ChooseMysteryAilment"):FireServer(petID, "mystery", level, resolution)
            end)
            
            if not success then
                ok = false
                break
            end
            wait(1)
        end
        
        if ok then
            print("Resolved mystery as:", resolution)
            return true
        end
    end
    
    return false
end

-- Run it
handleMysteryAilment()
