-- Function to get current marshmallow count
local function getCurrentMarshmallows()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    local player = Players.LocalPlayer

    local success, clientData = pcall(require, ReplicatedStorage.ClientModules.Core.ClientData)
    if not success then
        return 0
    end

    local success2, allData = pcall(clientData.get_data, clientData)
    if not success2 or not allData[player.Name] then
        return 0
    end

    local playerData = allData[player.Name]
    local marshmallows = 0

    -- Try to find marshmallow currency (might be named differently in Sugarfest)
    if playerData.marshmallow_2026 then
        marshmallows = playerData.marshmallow_2026
    elseif playerData.inventory and playerData.inventory.currency then
        marshmallows = playerData.inventory.currency.marshmallow_2026 or 0
    else
        -- Search for any currency that might be marshmallows
        for key, value in pairs(playerData) do
            if type(key) == "string" and (string.find(key:lower(), "marshmallow") or string.find(key:lower(), "sugarfest")) then
                if key == "marshmallow_2026" or key == "marshmallows_2026" then
                    marshmallows = value
                end
            end
        end
    end

    return marshmallows
end

-- Function to call a single marshmallow ID
local function callMarshmallowId(marshmallowId)
    local args = {
        {
            interior_name = "MainMap!Sugarfest2026",
            marshmallow_ids = {
                marshmallowId
            }
        }
    }
    
    chocolateRiverEvent:FireServer(unpack(args))
end

-- Function to collect rewards
local function collectMarshmallows()
    print("🍬 Collecting marshmallows...")
    collectEvent:FireServer()
    print("✅ Collection complete!")
end

-- Main function to run the cycle
local function runCycle()
    print("=== 🌟 Starting new Sugarfest 2026 cycle ===")
    print("Calling " .. #marshmallowIds .. " marshmallow IDs...")
    
    -- Call all marshmallow IDs with 0.1 second delay
    for i, marshmallowId in ipairs(marshmallowIds) do
        callMarshmallowId(marshmallowId)
        print("[" .. i .. "/" .. #marshmallowIds .. "] Called ID: " .. string.sub(marshmallowId, 1, 8) .. "...")
        
        -- Wait 0.1 seconds before next call
        task.wait(0.1)
    end
    
    print("✅ All " .. #marshmallowIds .. " marshmallow IDs called!")
    
    -- Wait 10 minutes (600 seconds) for marshmallows to spawn
    print("⏳ Waiting 10 minutes for marshmallows to spawn...")
    
    -- Countdown timer
    local waitTime = 600  -- 10 minutes in seconds
    for i = waitTime, 1, -1 do
        if i % 60 == 0 then
            print("⏱️ " .. math.floor(i/60) .. " minutes remaining...")
        end
        task.wait(1)
    end
    
    -- Now collect
    collectMarshmallows()
    
    print("=== 🎉 Cycle complete! ===")
end

