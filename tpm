local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local function clickCashOutButton()
    local button = PlayerGui:FindFirstChild("PlaytimePayoutsApp")
        and PlayerGui.PlaytimePayoutsApp:FindFirstChild("Frame")
        and PlayerGui.PlaytimePayoutsApp.Frame:FindFirstChild("Container")
        and PlayerGui.PlaytimePayoutsApp.Frame.Container:FindFirstChild("CashOutContainer")
        and PlayerGui.PlaytimePayoutsApp.Frame.Container.CashOutContainer:FindFirstChild("CashOutButton")
        and PlayerGui.PlaytimePayoutsApp.Frame.Container.CashOutContainer.CashOutButton:FindFirstChild("DepthButton")

    if button then
        if button.Visible and button.Active and button:IsA("GuiButton") then

            if firesignal then
                firesignal(button.MouseButton1Down)
                task.wait(0.05)
                firesignal(button.MouseButton1Up)
                firesignal(button.MouseButton1Click)
                print(" Successfully clicked CashOutButton!")
            else
                button.MouseButton1Click:Fire()
                print(" Successfully clicked CashOutButton!")
            end

            task.wait(2)
        end
    end
end

while task.wait(0.5) do
    pcall(clickCashOutButton)
end
