local function ensurePetEquipped()
    if not PetID then return false end
    if isPetEquipped(PetID) then return true end
    debugPrint("Re-equipping pet...")
    safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", PetID, {use_sound_delay = true, equip_as_last = false})
    task.wait(3)
    return isPetEquipped(PetID)
end

local function monitorAilments()
    debugPrint("Starting ailment monitor...")
    
    while PetFarmMode do
        ensurePetEquipped()
        
        local playerData = getPlayerData()
        if playerData and playerData.ailments_manager and playerData.ailments_manager.ailments and PetID then
            local ailments = playerData.ailments_manager.ailments[PetID]
            if ailments then
                local currentTime = os.time()
                
                for ailmentType, handlerName in pairs(AILMENT_TASKS) do
                    if ailments[ailmentType] and type(ailments[ailmentType]) == "table" then
                        if not lastTaskTime[ailmentType] or (currentTime - lastTaskTime[ailmentType]) >= TASK_COOLDOWN then
                            local success = false
                            
                            -- Route to correct handler
                            if ailmentType == "pet_me" then
                                success = handlePetMeAilment()
                            elseif ailmentType == "play" then
                                success = handlePlayAilment()
                            elseif ailmentType == "walk" then
                                success = handleWalkAilment()
                            elseif ailmentType == "ride" then
                                success = handleRideAilment()
                            elseif ailmentType == "sick" then
                                success = handleSickAilment()
                            elseif ailmentType == "mystery" then
                                success = handleMysteryAilment(ailments[ailmentType].id or PetID)
                            else
                                -- Regular furniture ailments
                                success = useFurniture(handlerName)
                            end
                            
                            if success then
                                lastTaskTime[ailmentType] = currentTime
                                debugPrint("✅ Handled: " .. ailmentType)
                            else
                                debugPrint("❌ Failed: " .. ailmentType)
                            end
                            break -- Handle one ailment per cycle
                        end
                    end
                end
            end
        end
        
        task.wait(10)
    end
end

local function startPetFarm()
    debugPrint("Starting PetFarm...")
    if not PetID then PetFarmMode = false; return end
    
    ensureCharacterSpawned()
    ensurePetEquipped()
    ensureAllFurniture() -- Auto-buy missing furniture on start
    
    monitorAilments()
end

