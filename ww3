local function getAllValidPets()  
    local playerData = getPlayerData()  
    if not playerData or not playerData.inventory or not playerData.inventory.pets then return {} end  
    local validPets = {}  
    for uniqueId, petData in pairs(playerData.inventory.pets) do  
        if petData and petData.id and not string.find(petData.id:lower(), "practice_dog") then  
            table.insert(validPets, {  
                unique = uniqueId,  
                id = petData.id,  
                age = petData.properties.age or 0,  
                neon = petData.properties.neon or false  
            })  
        end  
    end  
    table.sort(validPets, function(a, b) return a.age > b.age end)  
    return validPets  
end

local function findBestPet()  
    local validPets = getAllValidPets()  
    for _, pet in ipairs(validPets) do  
        if string.find(pet.id:lower(), "dog") or string.find(pet.id:lower(), "cat") or string.find(pet.id:lower(), "starter_egg") then  
            return pet  
        end  
    end  
    return validPets[1]  
end

local function equipPet(petUniqueID)  
    if not petUniqueID then return false end  
    local success = safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", petUniqueID, {use_sound_delay = true, equip_as_last = false})  
    if success then task.wait(3) end  
    return success  
end

