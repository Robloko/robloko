-- AILMENT MONITORING
-- ==================================================================

local function ensurePetEquipped(petUniqueID)
    if isPetEquipped(petUniqueID) then return true end
    debugPrint("Re-equipping pet...")
    local success = safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", petUniqueID, {use_sound_delay = true, equip_as_last = false})
    if success then task.wait(3) end
    return success
end

local function monitorAndHandleAilments()
    debugPrint("Starting ailment monitoring...")
    checkAndBuyMissingFurniture()
    
    while PetFarmMode do
        local currentTime = os.time()
        
        -- Keep pet equipped
        if PetID and not isPetEquipped(PetID) then
            ensurePetEquipped(PetID)
        end
        
        local playerData = getPlayerData()
        if playerData and playerData.ailments_manager and playerData.ailments_manager.ailments then
            for ailmentId, ailmentData in pairs(playerData.ailments_manager.ailments) do
                if ailmentId == PetID then
                    for ailmentType, furnitureName in pairs(AILMENT_TASKS) do
                        if ailmentData[ailmentType] and type(ailmentData[ailmentType]) == "table" then
                            if not lastTaskTime[ailmentType] or (currentTime - lastTaskTime[ailmentType]) >= TASK_COOLDOWN then
                                local success = false
                                if ailmentType == "play" then success = handlePlayAilment()
                                elseif ailmentType == "walk" then success = handleWalkAilment()
                                elseif ailmentType == "ride" then success = handleRideAilment()
                                elseif ailmentType == "sick" then success = handleSickAilment()
                                elseif ailmentType == "pet_me" then success = handlePetMeAilment()
                                elseif ailmentType == "mystery" then success = resolveMysteryAilment(ailmentId)
                                else success = useFurnitureWithPet(furnitureName)
                                end
                                if success then lastTaskTime[ailmentType] = currentTime end
                                break
                            end
                        end
                    end
                end
            end
        end
        
        task.wait(10)
    end
end

local function togglePetFarmMode()
    PetFarmMode = not PetFarmMode
    if PetFarmMode then
        if not PetID then
            debugPrint("No pet selected!")
            PetFarmMode = false
            return
        end
        debugPrint("PetFarm: ENABLED")
        petFarmCoroutine = coroutine.wrap(monitorAndHandleAilments)()
    else
        debugPrint("PetFarm: DISABLED")
        petFarmCoroutine = nil
    end
end

-- ==================================================================
-- AUTO PETPEN FUNCTIONS
-- ==================================================================

local function getPetPenSnapshot()
    local playerData = getPlayerData()
    if not playerData or not playerData.idle_progression_manager or not playerData.idle_progression_manager.active_pets then
        return {}
    end
    
    local snapshot = {}
    for uniqueId, _ in pairs(playerData.idle_progression_manager.active_pets) do
        local pet = playerData.inventory.pets[uniqueId]
        if pet then
            table.insert(snapshot, {
                name = pet.id,
                age = pet.properties.age or 0,
                neon = pet.properties.neon or false,
                unique_id = uniqueId
            })
        end
    end
    return snapshot
end

local function purgeNonPriorityGarbage()
    local playerData = getPlayerData()
    if not playerData or not playerData.idle_progression_manager or not playerData.idle_progression_manager.active_pets then
        return 0
    end
    
    local removed = 0
    for uniqueId, _ in pairs(playerData.idle_progression_manager.active_pets) do
        local pet = playerData.inventory.pets[uniqueId]
        if pet and pet.id and pet.properties then
            local cleanName = string.lower(pet.id)
            if not pet.properties.neon and not prioritySet[cleanName] then
                safeRemoteCall({"IdleProgressionAPI/RemovePet"}, "FireServer", uniqueId)
                removed = removed + 1
                task.wait(0.7)
            end
        end
    end
    return removed
end

local function addPriorityPets(snapshot)
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return 0
    end
    
    local slotsOpen = 4 - #snapshot
    if slotsOpen <= 0 then return 0 end
    
    local added = 0
    local addedSet = {}
    
    -- Add NEON pets first
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData.properties.neon and added < slotsOpen and not addedSet[uniqueId] then
            safeRemoteCall({"IdleProgressionAPI/AddPet"}, "FireServer", uniqueId)
            added = added + 1
            addedSet[uniqueId] = true
            task.wait(0.6)
        end
    end
    
    -- Add priority eggs
    for _, eggName in ipairs(priorityEggs) do
        for uniqueId, petData in pairs(playerData.inventory.pets) do
            if petData.id == eggName and added < slotsOpen and not addedSet[uniqueId] then
                safeRemoteCall({"IdleProgressionAPI/AddPet"}, "FireServer", uniqueId)
                added = added + 1
                addedSet[uniqueId] = true
                task.wait(0.6)
            end
        end
    end
    
    return added
end

local function startAutoPetPen()
    while AutoPetPenMode do
        purgeNonPriorityGarbage()
        local snapshot = getPetPenSnapshot()
        
        -- Remove aged pets (age 6+)
        for _, pet in ipairs(snapshot) do
            if pet.age >= 6 then
                safeRemoteCall({"IdleProgressionAPI/RemovePet"}, "FireServer", pet.unique_id)
                task.wait(0.7)
            end
        end
        
        task.wait(2)
        snapshot = getPetPenSnapshot()
        addPriorityPets(snapshot)
        
        -- Commit rewards every 5 minutes
        if os.time() - lastPetPenCommitTime >= 300 then
            safeRemoteCall({"IdleProgressionAPI/CommitAllProgression"}, "FireServer")
            lastPetPenCommitTime = os.time()
        end
        
        task.wait(60)
    end
end

local function toggleAutoPetPenMode()
    AutoPetPenMode = not AutoPetPenMode
    if AutoPetPenMode then
        debugPrint("Auto PetPen: ENABLED")
        lastPetPenCommitTime = os.time()
        autoPetPenCoroutine = coroutine.wrap(startAutoPetPen)()
    else
        debugPrint("Auto PetPen: DISABLED")
        autoPetPenCoroutine = nil
    end
end

-- ==================================================================
-- PET SELECTION
-- ==================================================================

local function getAllValidPets()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return {}
    end
    
    local validPets = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and petData.properties then
            local petName = string.lower(petData.id)
            if not string.find(petName, "practice_dog") then
                table.insert(validPets, {
                    unique = uniqueId,
                    id = petData.id,
                    age = petData.properties.age or 0,
                    neon = petData.properties.neon or false
                })
            end
        end
    end
    
    -- Sort: Dog > Cat > Starter_Egg > Others, then by age
    table.sort(validPets, function(a, b)
        local aIsDog = string.find(string.lower(a.id), "dog") and true or false
        local bIsDog = string.find(string.lower(b.id), "dog") and true or false
        local aIsCat = string.find(string.lower(a.id), "cat") and true or false
        local bIsCat = string.find(string.lower(b.id), "cat") and true or false
        local aIsEgg = string.find(string.lower(a.id), "starter_egg") and true or false
        local bIsEgg = string.find(string.lower(b.id), "starter_egg") and true or false
        
        if aIsDog and not bIsDog then return true end
        if not aIsDog and bIsDog then return false end
        if aIsCat and not bIsCat and not bIsDog then return true end
        if not aIsCat and bIsCat and not aIsDog then return false end
        if aIsEgg and not bIsEgg and not bIsDog and not bIsCat then return true end
        if not aIsEgg and bIsEgg and not aIsDog and not aIsCat then return false end
        
        return a.age > b.age
    end)
    
    return validPets
end

