    -- Update pet dropdown
    local function updatePetList()
        for _, child in ipairs(dropdownList:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        
        local validPets = getAllValidPets()
        if #validPets == 0 then
            dropdownButton.Text = "No pets found"
            return
        end
        
        dropdownButton.Text = "Select a Pet (" .. #validPets .. ")"
        
        for i, pet in ipairs(validPets) do
            local option = Instance.new("TextButton")
            option.Size = UDim2.new(1, 0, 0, 20)
            option.Position = UDim2.new(0, 0, 0, (i - 1) * 20)
            option.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            option.TextColor3 = Color3.fromRGB(255, 255, 255)
            local neonText = pet.neon and " 🔥" or ""
            option.Text = pet.id .. " (Age: " .. pet.age .. ")" .. neonText
            option.Font = Enum.Font.SourceSans
            option.TextSize = 9
            option.Parent = dropdownList
            
            option.MouseButton1Click:Connect(function()
                dropdownButton.Text = option.Text
                dropdownList.Visible = false
                PetID = pet.unique
                selectedPetName = pet.id
                debugPrint("Selected: " .. pet.id)
                statusLabel.Text = "Status: Selected - " .. pet.id
            end)
        end
        
        dropdownList.CanvasSize = UDim2.new(0, 0, 0, #validPets * 20)
    end
    
    local dropdownOpen = false
    dropdownButton.MouseButton1Click:Connect(function()
        dropdownOpen = not dropdownOpen
        dropdownList.Visible = dropdownOpen
        if dropdownOpen then updatePetList() end
    end)
    
    -- Button connections
    petPenButton.MouseButton1Click:Connect(function()
        toggleAutoPetPenMode()
        petPenButton.Text = AutoPetPenMode and "📦 Auto PetPen [ON]" or "📦 Auto PetPen [OFF]"
        petPenButton.BackgroundColor3 = AutoPetPenMode and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
    end)
    
    farmButton.MouseButton1Click:Connect(function()
        if not PetID and not PetFarmMode then
            statusLabel.Text = "⚠️ Select a pet first!"
            return
        end
        togglePetFarmMode()
        farmButton.Text = PetFarmMode and "🛑 STOP PETFARM" or "🐕 START PETFARM"
        farmButton.BackgroundColor3 = PetFarmMode and Color3.fromRGB(170, 0, 0) or Color3.fromRGB(0, 170, 0)
        statusLabel.Text = PetFarmMode and ("Status: ✅ Running - " .. (selectedPetName or "Pet")) or "Status: Stopped"
        statusLabel.TextColor3 = PetFarmMode and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 200, 100)
    end)
    
    return {
        sessionLabel = sessionLabel,
        statusLabel = statusLabel
    }
end

