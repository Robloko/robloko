local function getPetPenSnapshot()  
    local playerData = getPlayerData()  
    if not playerData or not playerData.idle_progression_manager then return {} end  
    local snapshot = {}  
    for uniqueId, _ in pairs(playerData.idle_progression_manager.active_pets or {}) do  
        local pet = playerData.inventory.pets[uniqueId]  
        if pet then  
            table.insert(snapshot, {name = pet.id, age = pet.properties.age or 0, unique_id = uniqueId})  
        end  
    end  
    return snapshot  
end

local function purgeNonPriorityPets()  
    local playerData = getPlayerData()  
    if not playerData or not playerData.idle_progression_manager then return 0 end  
    local removed = 0  
    for uniqueId, _ in pairs(playerData.idle_progression_manager.active_pets or {}) do  
        local pet = playerData.inventory.pets[uniqueId]  
        if pet and not pet.properties.neon then  
            local isPriority = false  
            for _, eggName in ipairs(PRIORITY_EGGS) do  
                if pet.id == eggName then isPriority = true break end  
            end  
            if not isPriority then  
                safeRemoteCall({"IdleProgressionAPI/RemovePet"}, "FireServer", uniqueId)  
                removed = removed + 1  
                task.wait(0.5)  
            end  
        end  
    end  
    return removed  
end

local function addPriorityPets()  
    local playerData = getPlayerData()  
    if not playerData or not playerData.inventory then return 0 end  
    local snapshot = getPetPenSnapshot()  
    local slotsOpen = 4 - #snapshot  
    if slotsOpen <= 0 then return 0 end

