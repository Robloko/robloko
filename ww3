            dropdownButton.Text = button.Text
            dropdownList.Visible = false
            PetID = pet.unique
            selectedPetName = pet.id
            equipPet(PetID)
        end)
    end
    dropdownList.CanvasSize = UDim2.new(0, 0, 0, #validPets * 20)
end

dropdownButton.MouseButton1Click:Connect(function()
