local function getAllValidPets()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then
        return {}
    end
    
    local validPets = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and petData.properties then
            local petName = string.lower(petData.id)
            if not string.find(petName, "practice_dog") then
                table.insert(validPets, {
                    unique = uniqueId,
                    id = petData.id,
                    age = petData.properties.age or 0,
                    neon = petData.properties.neon or false
                })
            end
        end
    end
    
    -- Sort by priority: Dog > Cat > Starter_Egg > Others
    table.sort(validPets, function(a, b)
        local aIsDog = string.find(string.lower(a.id), "dog")
        local bIsDog = string.find(string.lower(b.id), "dog")
        local aIsCat = string.find(string.lower(a.id), "cat")
        local bIsCat = string.find(string.lower(b.id), "cat")
        local aIsEgg = string.find(string.lower(a.id), "starter_egg")
        local bIsEgg = string.find(string.lower(b.id), "starter_egg")
        
        if aIsDog and not bIsDog then return true end
        if not aIsDog and bIsDog then return false end
        if aIsCat and not bIsCat and not bIsDog then return true end
        if not aIsCat and bIsCat and not aIsDog then return false end
        if aIsEgg and not bIsEgg and not bIsDog and not bIsCat then return true end
        return a.age > b.age
    end)
    
    return validPets
end

