local function handleMysteryAilment(ailmentId)
    debugPrint("❓ Resolving mystery ailment...")
    local tasks = {"bored", "sick", "pet_me", "sleepy", "dirty", "toilet", "hungry", "thirsty", "walk", "ride"}
    
    for _, chosenAilment in ipairs(tasks) do
        local allLevelsSuccess = true
        for level = 1, 3 do
            local success = safeRemoteCall({"AilmentsAPI/ChooseMysteryAilment"}, "FireServer", ailmentId, "mystery", level, chosenAilment)
            if not success then
                allLevelsSuccess = false
                break
            end
            task.wait(1)
        end
        if allLevelsSuccess then
            debugPrint("✅ Mystery resolved as: " .. chosenAilment)
            return true
        end
    end
    return false
end

