local function handlePetMeAilment()
    debugPrint("Pet Me ailment detected!")
    local petModel = findPlayerPetInWorkspace()
    if not petModel then return false end
    
    -- Focus pet
    safeRemoteCall({"AdoptAPI/FocusPet"}, "FireServer", petModel)
