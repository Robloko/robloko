            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            local neonText = pet.neon and " 🔥NEON" or ""
            btn.Text = pet.id .. " (Age: " .. pet.age .. ")" .. neonText
            btn.Font = Enum.Font.SourceSans
            btn.TextSize = 10
            btn.Parent = dropdownList
            
            btn.MouseButton1Click:Connect(function()
                PetID = pet.unique
                selectedPetName = pet.id
                dropdownButton.Text = pet.id .. " (Age: " .. pet.age .. ")"
                dropdownList.Visible = false
                debugPrint("Selected: " .. pet.id)
                
                -- Auto-equip
                ensurePetEquipped(PetID)
                
                if ui and ui.statusLabel then
                    ui.statusLabel.Text = "Pet: " .. pet.id
                end
            end)
        end
        
        dropdownList.CanvasSize = UDim2.new(0, 0, 0, #pets * 25)
    end
    
    local dropdownOpen = false
    dropdownButton.MouseButton1Click:Connect(function()
        dropdownOpen = not dropdownOpen
        dropdownList.Visible = dropdownOpen
        if dropdownOpen then updateDropdown() end
    end)
    
    -- Auto PetPen Button
    local petPenButton = Instance.new("TextButton")
    petPenButton.Size = UDim2.new(0, 200, 0, 30)
    petPenButton.Position = UDim2.new(0, 10, 0, 75)
    petPenButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    petPenButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    petPenButton.Text = "Auto PetPen [ON]"
    petPenButton.Font = Enum.Font.SourceSansBold
    petPenButton.TextSize = 12
    petPenButton.Parent = frame
    
    local petPenCorner = Instance.new("UICorner")
    petPenCorner.CornerRadius = UDim.new(0, 4)
    petPenCorner.Parent = petPenButton
    
    -- PetFarm Button
    local petFarmButton = Instance.new("TextButton")
    petFarmButton.Size = UDim2.new(0, 200, 0, 30)
    petFarmButton.Position = UDim2.new(0, 10, 0, 115)
    petFarmButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    petFarmButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    petFarmButton.Text = "Start PetFarm"
    petFarmButton.Font = Enum.Font.SourceSansBold
    petFarmButton.TextSize = 12
    petFarmButton.Parent = frame
    
    local petFarmCorner = Instance.new("UICorner")
    petFarmCorner.CornerRadius = UDim.new(0, 4)
    petFarmCorner.Parent = petFarmButton
    
    -- Status Label
    local statusLabel = Instance.new("TextLabel")
    statusLabel.Size = UDim2.new(1, 0, 0, 20)
    statusLabel.Position = UDim2.new(0, 0, 0, 155)
    statusLabel.BackgroundTransparency = 1
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    statusLabel.Text = "Status: Ready"
    statusLabel.Font = Enum.Font.SourceSans
    statusLabel.TextSize = 10
    statusLabel.TextXAlignment = Enum.TextXAlignment.Left
    statusLabel.Parent = frame
    
    -- Session Money Label
    local moneyLabel = Instance.new("TextLabel")
    moneyLabel.Size = UDim2.new(1, 0, 0, 20)
    moneyLabel.Position = UDim2.new(0, 0, 0, 175)
    moneyLabel.BackgroundTransparency = 1
    moneyLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
    moneyLabel.Text = "💵 Bucks: 0 (+0)"
    moneyLabel.Font = Enum.Font.SourceSans
    moneyLabel.TextSize = 10
    moneyLabel.TextXAlignment = Enum.TextXAlignment.Left
    moneyLabel.Parent = frame
    
    -- Button connections
    petPenButton.MouseButton1Click:Connect(function()
        toggleAutoPetPenMode()
        petPenButton.Text = AutoPetPenMode and "Auto PetPen [ON]" or "Auto PetPen [OFF]"
        petPenButton.BackgroundColor3 = AutoPetPenMode and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
    end)
    
    petFarmButton.MouseButton1Click:Connect(function()
        if not PetID then
            statusLabel.Text = "Status: Select a pet first!"
            return
        end
        togglePetFarmMode()
        petFarmButton.Text = PetFarmMode and "Stop PetFarm" or "Start PetFarm"
        petFarmButton.BackgroundColor3 = PetFarmMode and Color3.fromRGB(170, 0, 0) or Color3.fromRGB(0, 170, 0)
        statusLabel.Text = PetFarmMode and "Status: Running - " .. (selectedPetName or "Pet") or "Status: Stopped"
    end)
    
    -- Update money display
    coroutine.wrap(function()
        while true do
            local currentMoney = getCurrentMoney()
            if lastMoneyAmount == 0 then lastMoneyAmount = currentMoney end
            sessionBucksEarned = currentMoney - lastMoneyAmount
            moneyLabel.Text = string.format("💵 Bucks: %d (+%d)", currentMoney, sessionBucksEarned)
            task.wait(1)
        end
    end)()
    
    return {
        statusLabel = statusLabel,
        petFarmButton = petFarmButton,
        petPenButton = petPenButton
    }
end

-- ==================================================================
-- AUTO START
-- ==================================================================

local function autoStart()
    debugPrint("Auto-starting...")
    task.wait(3)
    
    -- Auto-select best pet
    local pets = getAllValidPets()
    if #pets > 0 then
        local bestPet = pets[1]
        PetID = bestPet.unique
        selectedPetName = bestPet.id
        debugPrint("Auto-selected: " .. bestPet.id .. " (Age: " .. bestPet.age .. ")")
        ensurePetEquipped(PetID)
        if ui and ui.statusLabel then
            ui.statusLabel.Text = "Status: Auto-selected " .. bestPet.id
        end
    else
        debugPrint("No pets found!")
        if ui then ui.statusLabel.Text = "Status: No pets found!" end
    end
    
    -- Start Auto PetPen
    if not AutoPetPenMode then
        toggleAutoPetPenMode()
        if ui and ui.petPenButton then
            ui.petPenButton.Text = "Auto PetPen [ON]"
            ui.petPenButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        end
    end
    
    -- Start PetFarm if pet selected
    if PetID and not PetFarmMode then
        togglePetFarmMode()
        if ui and ui.petFarmButton then
            ui.petFarmButton.Text = "Stop PetFarm"
            ui.petFarmButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
        end
        if ui and ui.statusLabel then
            ui.statusLabel.Text = "Status: Running - " .. selectedPetName
        end
    end
end

