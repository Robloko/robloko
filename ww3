-- ==================================================================

local function resolveMysteryAilment(ailmentId)
    debugPrint("Mystery ailment detected!")
    local tasks = {"bored", "sick", "pet me", "sleepy", "dirty", "toilet", "hungry", "thirsty"}
    
    for _, chosenAilment in ipairs(tasks) do
        local allGood = true
        for level = 1, 3 do
            local success = safeRemoteCall({"AilmentsAPI/ChooseMysteryAilment"}, "FireServer", ailmentId, "mystery", level, chosenAilment)
            if not success then allGood = false end
            task.wait(1)
        end
        if allGood then return true end
    end
    return false
end

