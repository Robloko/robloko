local function handlePetMeAilment()
    debugPrint("✋ Petting pet...")
    local pet = findPlayerPetInWorkspace()
    if not pet then return false end
    
    -- Focus pet
    safeRemoteCall({"AdoptAPI/FocusPet"}, "FireServer", pet)
    task.wait(0.5)
    
    -- Set pet sitting
    local sitAnim = string.find(pet.Name:lower(), "dog") and "DogSit" or "CatSit"
    safeRemoteCall({"PetAPI/ReplicatePerformanceModifiers"}, "FireServer", pet, {
        local_anim_name = sitAnim,
        local_anim_speed = 1,
        dont_allow_sit_states = true,
        dont_allow_remote_interaction = true,
        anim_fade_time = 0.2
    })
    task.wait(1)
    
    -- Try multiple endpoints to progress ailment
    local endpoints = {"AilmentsAPI/ProgressPetMeAilment", "PetAPI/ProgressPetMeAilment", "AdoptAPI/ProgressPetMeAilment"}
    for _, endpoint in ipairs(endpoints) do
        local success = safeRemoteCall({endpoint}, "FireServer", PetID)
        if success then break end
    end
    task.wait(2)
    
    -- Unfocus
    safeRemoteCall({"AdoptAPI/UnfocusPet"}, "FireServer", pet)
    return true
end

local function handlePlayAilment()
    debugPrint("🎾 Playing with squeaky bone...")
    -- Find squeaky bone
    local playerData = getPlayerData()
    local toyID = nil
    if playerData and playerData.inventory.toys then
        for id, data in pairs(playerData.inventory.toys) do
            if data.id == "squeaky_bone_default" then
                toyID = id
                break
            end
        end
    end
    if not toyID then 
        debugPrint("No squeaky bone found")
        return false 
    end
    
    -- Throw toy 3 times
    for i = 1, 3 do
        safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", toyID, {use_sound_delay = true, equip_as_last = false})
        task.wait(1)
        safeRemoteCall({"ToolAPI/ServerUseTool"}, "FireServer", toyID, "START")
        task.wait(1)
        safeRemoteCall({"PetObjectAPI/CreatePetObject"}, "InvokeServer", "__Enum_PetObjectCreatorType_1", {reaction_name = "ThrowToyReaction", unique_id = toyID})
        task.wait(1)
        safeRemoteCall({"ToolAPI/ServerUseTool"}, "FireServer", toyID, "END")
