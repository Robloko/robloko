local function safeRemoteCall(remotePath, method, ...)
    local args = {...}
    local remote = ReplicatedStorage:FindFirstChild("API")
    if not remote then return false, "API not found" end
    for _, path in ipairs(remotePath) do
        remote = remote:FindFirstChild(path)
        if not remote then return false, "Remote not found: " .. path end
    end
    if method == "InvokeServer" then
        local success, result = pcall(function() return remote:InvokeServer(unpack(args)) end)
        return success, result
    elseif method == "FireServer" then
        local success, result = pcall(function() remote:FireServer(unpack(args)) end)
        return success, result
    end
    return false, "Invalid method"
end

local function getPlayerData()
    local success, clientData = pcall(require, ReplicatedStorage.ClientModules.Core.ClientData)
    if not success or not clientData then return nil end
    local success2, allData = pcall(clientData.get_data, clientData)
    if not success2 or not allData or not allData[player.Name] then return nil end
    return allData[player.Name]
end

local function getCurrentMoneyAndPotions()
    local playerData = getPlayerData()
    if not playerData then return 0, 0 end
    local money = playerData.money or 0
    local potions = 0
    if playerData.inventory and playerData.inventory.food then
        for _, foodData in pairs(playerData.inventory.food) do
            if foodData.id and string.find(string.lower(foodData.id), "potion") then
                potions = potions + (foodData.amount or 1)
            end
        end
    end
    return money, potions
end

local function updateSessionEarnings()
    local currentMoney, currentPotions = getCurrentMoneyAndPotions()
    if lastMoneyAmount == 0 then lastMoneyAmount = currentMoney end
    if lastPotionAmount == 0 then lastPotionAmount = currentPotions end
    sessionBucksEarned = currentMoney - lastMoneyAmount
    sessionPotionsEarned = currentPotions - lastPotionAmount
    return currentMoney, currentPotions
end

local function isPetEquipped(petUniqueID)
    local data = getPlayerData()
    if not data or not data.equip_manager or not data.equip_manager.pets then return false end
    for _, equippedPet in pairs(data.equip_manager.pets) do
        if equippedPet and equippedPet.unique == petUniqueID then return true end
    end
    return false
end

local function findPlayerPetInWorkspace()
    local petsFolder = workspace:FindFirstChild("Pets")
    if not petsFolder then return nil end
    for _, pet in ipairs(petsFolder:GetChildren()) do
        if pet:IsA("Model") then
            local owner = pet:FindFirstChild("Owner")
            if owner and owner.Value == player then return pet end
            local petName = pet.Name
            if petName == "Dog" or petName == "Cat" or petName == "Starter Egg" or string.find(petName:lower(), "egg") then
                return pet
            end
        end
    end
    return nil
end

