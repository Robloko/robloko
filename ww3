-- Extract furniture data
local function extractFurnitureData(model, folderName)
    local folderId = string.match(folderName, "f%-%d+") or folderName
    for _, part in ipairs(model:GetDescendants()) do
        if part:IsA("BasePart") then
            return {
                folderId = folderId,
                partName = part.Name,
                position = part.Position,
                cframe = part.CFrame,
                model = model
            }
        end
    end
    return nil
end

-- Find furniture by name
local function findFurnitureByName(name)
    local hi = workspace:FindFirstChild("HouseInteriors")
    if hi then
        for _, folder in ipairs(hi:GetChildren()) do
            if string.find(folder.Name, player.Name) or string.find(folder.Name, "f%-%d+") then
                local model = folder:FindFirstChild(name)
                if model and model:IsA("Model") then
                    return extractFurnitureData(model, folder.Name)
                end
            end
        end
    end
    return nil
end

-- Auto-buy missing furniture
local function checkAndBuyMissingFurniture()
    debugPrint("Checking for missing furniture...")
    local missingFurniture = {}
    
    local furnitureToCheck = {
        {name = "BasicBed", kind = "basic_bed"},
        {name = "PetFoodBowl", kind = "pet_food_bowl"},
        {name = "PetWaterBowl", kind = "pet_water_bowl"},
        {name = "CheapPetBathtub", kind = "cheap_pet_bathtub"},
        {name = "Piano", kind = "piano"},
        {name = "AilmentsRefresh2024LitterBox", kind = "ailments_refresh_2024_litter_box"}
    }
    
    for _, item in ipairs(furnitureToCheck) do
        local found = findFurnitureByName(item.name)
        if not found then
            debugPrint("Missing: " .. item.name .. " - will buy")
            table.insert(missingFurniture, {
                kind = item.kind,
                properties = {cframe = CFrame.new(10, 0, -15)}
            })
        end
    end
    
    if #missingFurniture > 0 then
        debugPrint("Buying " .. #missingFurniture .. " furniture items...")
        safeRemoteCall({"HousingAPI/BuyFurnitures"}, "InvokeServer", missingFurniture)
        task.wait(3)
    else
        debugPrint("All furniture found!")
    end
end

-- Activate furniture
local function activateFurniture(furnitureName, pet)
    local furnitureData = findFurnitureByName(furnitureName)
    if not furnitureData then
        debugPrint("Furniture not found: " .. furnitureName)
        return false
    end

    local args = {
        player,
        furnitureData.folderId,
        furnitureData.partName,
        {cframe = furnitureData.cframe},
        pet
    }

    local success = safeRemoteCall({"HousingAPI/ActivateFurniture"}, "InvokeServer", unpack(args))
    if success then
        debugPrint("Activated: " .. furnitureName)
        return true
    end
    return false
end

-- Use furniture with pet
local function useFurnitureWithPet(furnitureName)
    task.wait(1)

    local petObject = nil
    for attempt = 1, 5 do
        petObject = findPlayerPetInWorkspace()
        if petObject then break end
        task.wait(2)
    end

    if petObject then
        local success = activateFurniture(furnitureName, petObject)
        if success then
            task.wait(20)
            return true
        end
    end
    return false
end

