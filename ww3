local function getAllValidPets()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then return {} end
    local validPets = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and petData.properties then
            if not string.find(string.lower(petData.id), "practice_dog") then
                table.insert(validPets, { unique = uniqueId, id = petData.id, age = petData.properties.age or 0, neon = petData.properties.neon or false, name = petData.id })
            end
        end
    end
    table.sort(validPets, function(a, b)
        local aIsDog = string.find(string.lower(a.id), "dog") and true or false
        local bIsDog = string.find(string.lower(b.id), "dog") and true or false
        local aIsCat = string.find(string.lower(a.id), "cat") and true or false
        local bIsCat = string.find(string.lower(b.id), "cat") and true or false
        if aIsDog and not bIsDog then return true end
        if not aIsDog and bIsDog then return false end
        if aIsCat and not bIsCat and not bIsDog then return true end
        if not aIsCat and bIsCat and not aIsDog then return false end
        return a.age > b.age
    end)
    return validPets
end

local function findBestDogOrCat()
    local validPets = getAllValidPets()
    local dogPet, catPet, starterEggPet = nil, nil, nil
    for _, pet in ipairs(validPets) do
        local petName = string.lower(pet.id)
        if string.find(petName, "dog") and not string.find(petName, "practice") then
            if not dogPet or pet.age > dogPet.age then dogPet = pet end
        elseif string.find(petName, "cat") then
            if not catPet or pet.age > catPet.age then catPet = pet end
        elseif string.find(petName, "starter_egg") then
            if not starterEggPet or pet.age > starterEggPet.age then starterEggPet = pet end
        end
    end
    return dogPet or catPet or starterEggPet or validPets[1]
end

local function equipSelectedPet(petUniqueID)
    if not petUniqueID then return false end
    if isPetEquipped(petUniqueID) then return true end
    safeRemoteCall({"ToolAPI/Equip"}, "InvokeServer", petUniqueID, { use_sound_delay = true, equip_as_last = false })
    task.wait(3)
    return true
end

local function addAllPetsToTrade()
    local playerData = getPlayerData()
    if not playerData or not playerData.inventory or not playerData.inventory.pets then return end
    local allPets = {}
    for uniqueId, petData in pairs(playerData.inventory.pets) do
        if petData and petData.id and not string.find(string.lower(petData.id), "practice_dog") then
            table.insert(allPets, uniqueId)
        end
    end
    for i = 1, math.min(#allPets, 18) do
        safeRemoteCall({"TradeAPI/AddItemToOffer"}, "FireServer", allPets[i])
        task.wait(0.2)
    end
end

local function sendTradeRequest(targetPlayerName)
    if targetPlayerName == "" then return end
    local targetPlayer = Players:FindFirstChild(targetPlayerName)
    if not targetPlayer then return end
    safeRemoteCall({"TradeAPI/SendTradeRequest"}, "FireServer", targetPlayer)
end

local function startAutoAcceptTrades()
    while AutoAcceptMode do
        for _, targetPlayer in ipairs(Players:GetPlayers()) do
            if targetPlayer ~= player then
                safeRemoteCall({"TradeAPI/AcceptOrDeclineTradeRequest"}, "InvokeServer", targetPlayer, true)
                task.wait(5)
                safeRemoteCall({"TradeAPI/AcceptNegotiation"}, "FireServer")
                task.wait(9)
                safeRemoteCall({"TradeAPI/ConfirmTrade"}, "FireServer")
                task.wait(0.1)
            end
        end
        task.wait(9)
    end
end

local function toggleAutoAcceptMode()
    AutoAcceptMode = not AutoAcceptMode
    if AutoAcceptMode then autoAcceptCoroutine = coroutine.wrap(startAutoAcceptTrades)() end
end

