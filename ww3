local function findFurnitureByName(name)
    local hi = workspace:FindFirstChild("HouseInteriors")
    if hi then
        for _, folder in ipairs(hi:GetChildren()) do
            if string.find(folder.Name, player.Name) or string.find(folder.Name, "f%-%d+") then
                local model = folder:FindFirstChild(name)
                if model and model:IsA("Model") then return true end
            end
        end
    end
    return false
end

local function buyFurniture(furnitureName, itemId)
    debugPrint("🛒 Buying: " .. furnitureName)
    local success, result = safeRemoteCall({"ShopAPI/BuyItem"}, "InvokeServer", "furniture", itemId, {buy_count = 1})
    if success then
        debugPrint("✅ Bought: " .. furnitureName)
        task.wait(2)
        return true
    end
    debugPrint("❌ Failed to buy: " .. furnitureName)
    return false
end

local function ensureAllFurniture()
    for furnitureName, furnitureData in pairs(REQUIRED_FURNITURE) do
        if not findFurnitureByName(furnitureName) then
            buyFurniture(furnitureName, furnitureData.id)
        end
    end
end

-- ==================================================================
-- FURNITURE ACTIVATION
-- ==================================================================

local function getFurnitureData(furnitureName)
    local hi = workspace:FindFirstChild("HouseInteriors")
    if not hi then return nil end
    
    for _, folder in ipairs(hi:GetChildren()) do
        if string.find(folder.Name, player.Name) or string.find(folder.Name, "f%-%d+") then
            local model = folder:FindFirstChild(furnitureName)
            if model and model:IsA("Model") then
                local useBlock = model:FindFirstChild("UseBlocks")
                local part = nil
                if useBlock then part = useBlock:FindFirstChild("UseBlock") end
                if not part then part = model:FindFirstChild("UseBlock") end
                if not part then part = model:FindFirstChildWhichIsA("BasePart") end
                if part then
                    return {
                        folderId = string.match(folder.Name, "f%-%d+") or folder.Name,
                        partName = part.Name,
                        cframe = part.CFrame
                    }
                end
            end
        end
    end
    return nil
end

local function useFurniture(furnitureName)
    -- Check and buy if missing
    if not findFurnitureByName(furnitureName) then
        for name, data in pairs(REQUIRED_FURNITURE) do
            if name == furnitureName then
                buyFurniture(furnitureName, data.id)
                task.wait(2)
                break
            end
        end
    end
    
    local furnitureData = getFurnitureData(furnitureName)
    if not furnitureData then
        debugPrint("⚠️ Still missing: " .. furnitureName)
        return false
    end
    
    local pet = findPlayerPetInWorkspace()
    if not pet then return false end
    
    local char = ensureCharacterSpawned()
    if not char then return false end
    
    local args = {player, furnitureData.folderId, furnitureData.partName, {cframe = furnitureData.cframe}, pet}
    local success = safeRemoteCall({"HousingAPI/ActivateFurniture"}, "InvokeServer", unpack(args))
    
    if success then
        debugPrint("✅ Used: " .. furnitureName)
        task.wait(20)
        return true
    end
    return false
end

