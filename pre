-- Create a ScreenGui to hold the UI
local player = game:GetService("Players").LocalPlayer
local gui = Instance.new("ScreenGui")
gui.Name = "SugarfestDiceUI"
gui.Parent = player:WaitForChild("PlayerGui")

-- Create a Frame for the UI
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 200, 0, 100)
frame.Position = UDim2.new(0.5, -100, 0.9, -50)
frame.AnchorPoint = Vector2.new(0.5, 0.5)
frame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
frame.BorderSizePixel = 0
frame.Parent = gui

-- Create a TextLabel to display the dice count
local diceCountLabel = Instance.new("TextLabel")
diceCountLabel.Name = "DiceCountLabel"
diceCountLabel.Size = UDim2.new(1, 0, 0.5, 0)
diceCountLabel.Position = UDim2.new(0, 0, 0, 0)
diceCountLabel.BackgroundTransparency = 1
diceCountLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
diceCountLabel.Text = "Dice: 0"
diceCountLabel.TextScaled = true
diceCountLabel.Parent = frame

-- Create a TextButton to start the dice game
local startButton = Instance.new("TextButton")
startButton.Name = "StartButton"
startButton.Size = UDim2.new(1, 0, 0.5, 0)
startButton.Position = UDim2.new(0, 0, 0.5, 0)
startButton.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
startButton.TextColor3 = Color3.fromRGB(255, 255, 255)
startButton.Text = "START"
startButton.TextScaled = true
startButton.Parent = frame

-- Function to check the inventory for sugarfest_2026_dice
local function checkDiceInventory()
    local backpack = player:WaitForChild("Backpack")
    local diceCount = 0

    for _, item in ipairs(backpack:GetChildren()) do
        if item.Name == "sugarfest_2026_dice" then
            diceCount = diceCount + 1
        end
    end

    diceCountLabel.Text = "Dice: " .. diceCount
    return diceCount > 0
end

-- Function to start the dice game sequence
local function startDiceGame()
    if not checkDiceInventory() then
        warn("No sugarfest_2026_dice found in inventory!")
        return
    end

    -- Disable the button during the sequence
    startButton.Text = "RUNNING..."
    startButton.BackgroundColor3 = Color3.fromRGB(120, 120, 120)

    -- Call the dice game sequence
    local args = {
        {
            dice_item_unique = "2_0ae496b5f4d946eb935b15dbae1ba620"
        }
    }
    game:GetService("ReplicatedStorage"):WaitForChild("adoptme_new_net"):WaitForChild("adoptme_legacy_shared.ContentPacks.Sugarfest2026.Game.BoardGame.BoardGameNetService:10"):FireServer(unpack(args))

    local args = {
        "2_0ae496b5f4d946eb935b15dbae1ba620",
        "START"
    }
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("ToolAPI/ServerUseTool"):FireServer(unpack(args))

    local args = {
        true
    }
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("InteractablesAPI/DisableInteractionWithMe"):FireServer(unpack(args))

    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("AdoptAPI/EjectAllHeldBabies"):FireServer()

    local args = {
        "2_0ae496b5f4d946eb935b15dbae1ba620",
        "END"
    }
    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("ToolAPI/ServerUseTool"):FireServer(unpack(args))

    -- Re-enable the button after the sequence
    startButton.Text = "START"
    startButton.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
end

-- Connect the button click event
startButton.MouseButton1Click:Connect(startDiceGame)

-- Initial check for dice
checkDiceInventory()
