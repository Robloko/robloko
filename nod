-- Services
local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local player = Players.LocalPlayer

-- Wait for PlayerGui to load
repeat task.wait() until player:FindFirstChild("PlayerGui")

-- Function to simulate a click on a GUI button
local function clickButton(button)
    if button and button.Visible and button.Active and (button:IsA("GuiButton") or button:IsA("TextButton") or button:IsA("ImageButton")) then
        firesignal(button.MouseButton1Down)
        task.wait(0.05)
        firesignal(button.MouseButton1Up)
        firesignal(button.MouseButton1Click)
        print("✅ Clicked button: " .. button:GetFullName())
        return true
    end
    return false
end

-- Function to click all buttons in a dialog
local function clickDialogButtons(dialog)
    -- Check for ButtonTemplate
    local buttonTemplate = dialog:FindFirstChild("Buttons", true) and dialog.Buttons:FindFirstChild("ButtonTemplate", true)
    if buttonTemplate then
        -- Click the main button
        clickButton(buttonTemplate)

        -- Click Face.Colors if it exists
        local faceColors = buttonTemplate:FindFirstChild("Face", true) and buttonTemplate.Face:FindFirstChild("Colors", true)
        if faceColors then
            clickButton(faceColors)
        end

        -- Click Shadow.Colors.Left if it exists
        local shadowColorsLeft = buttonTemplate:FindFirstChild("Shadow", true) and
                                  buttonTemplate.Shadow:FindFirstChild("Colors", true) and
                                  buttonTemplate.Shadow.Colors:FindFirstChild("Left", true)
        if shadowColorsLeft then
            clickButton(shadowColorsLeft)
        end
    end
end

-- Monitor for DialogApp
local function monitorDialogs()
    -- Check if DialogApp already exists
    local dialogApp = player.PlayerGui:FindFirstChild("DialogApp")
    if dialogApp then
        setupDialogMonitor(dialogApp)
    end

    -- Listen for new DialogApp
    player.PlayerGui.ChildAdded:Connect(function(child)
        if child.Name == "DialogApp" then
            setupDialogMonitor(child)
        end
    end)
end

-- Setup monitoring for a specific DialogApp
local function setupDialogMonitor(dialogApp)
    print("🔍 Monitoring DialogApp for dialogs...")

    -- Check for existing NormalDialog
    local normalDialog = dialogApp:FindFirstChild("Dialog", true) and dialogApp.Dialog:FindFirstChild("NormalDialog", true)
    if normalDialog then
        clickDialogButtons(normalDialog)
    end

    -- Listen for new NormalDialogs
    dialogApp.DescendantAdded:Connect(function(descendant)
        if descendant.Name == "NormalDialog" then
            print("💬 New NormalDialog detected!")
            clickDialogButtons(descendant)
        end
    end)
end

-- Start monitoring
monitorDialogs()
print("🚀 Auto-clicker for dialog buttons is running!")
