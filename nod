local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Run this in a background loop so it doesn't stop your other scripts
task.spawn(function()
    print("Dialog Auto-Clicker started. Waiting for pop-up...")
    
    while true do
        -- Safely check if the exact UI path exists
        local dialogApp = playerGui:FindFirstChild("DialogApp")
        local dialog = dialogApp and dialogApp:FindFirstChild("Dialog", true)
        local normalDialog = dialog and dialog:FindFirstChild("NormalDialog", true)
        local buttonsFolder = normalDialog and normalDialog:FindFirstChild("Buttons", true)
        local buttonTemplate = buttonsFolder and buttonsFolder:FindFirstChild("ButtonTemplate", true)

        -- If the button exists and is visible, click it
        if buttonTemplate and buttonTemplate.Visible then
            print("Dialog pop-up detected! Clicking ButtonTemplate...")
            
            -- Method 1: Fire the GUI click signals (works for most UI buttons)
            if buttonTemplate:IsA("GuiButton") then
                firesignal(buttonTemplate.MouseButton1Down)
                task.wait(0.05)
                firesignal(buttonTemplate.MouseButton1Up)
                firesignal(buttonTemplate.MouseButton1Click)
            end
            
            -- Method 2: Fallback coordinate click (uses VirtualInputManager exactly like your other clicks)
            local pos = buttonTemplate.AbsolutePosition
            local size = buttonTemplate.AbsoluteSize
            local clickX = pos.X + (size.X / 2)
            local clickY = pos.Y + (size.Y / 2)
            
            VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, true, game, 1)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, false, game, 1)
            
            -- Wait 1 second to allow the dialog to close before searching again
            task.wait(1) 
        end
        
        -- Check for the dialog every 0.5 seconds
        task.wait(0.5)
    end
end)
