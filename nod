wait(5)
local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

-- Wait for player GUI to load
repeat task.wait() until localPlayer.PlayerGui

-- ==================================================================
-- BACKGROUND DIALOG AUTO-CLICKER (Strictly for your 2 paths)
-- ==================================================================
task.spawn(function()
    print("Dialog monitor started...")
    
    while true do
        local pGui = localPlayer.PlayerGui
        
        -- Function to safely traverse the exact paths you provided
        local function getTarget(pathList)
            local current = pGui
            for _, name in ipairs(pathList) do
                current = current:FindFirstChild(name)
                if not current then return nil end
            end
            return current
        end

        -- 1. Target: DialogApp.Dialog.NormalDialog.Buttons.ButtonTemplate.Face.Colors
        local target1 = getTarget({"DialogApp", "Dialog", "NormalDialog", "Buttons", "ButtonTemplate", "Face", "Colors"})
        
        -- 2. Target: DialogApp.Dialog.NormalDialog.Buttons.ButtonTemplate.Shadow.Colors.Left
        local target2 = getTarget({"DialogApp", "Dialog", "NormalDialog", "Buttons", "ButtonTemplate", "Shadow", "Colors", "Left"})

        local clicked = false

        -- Check Target 1
        if target1 and target1.Visible then
            -- Find the actual GuiButton to fire the signal on (prevents errors if Colors is a Frame)
            local btn = target1:IsA("GuiButton") and target1 or target1:FindFirstAncestorWhichIsA("GuiButton")
            if btn and btn.Active then
                print("Dialog 1 detected! Clicking...")
                firesignal(btn.MouseButton1Down)
                task.wait(0.05)
                firesignal(btn.MouseButton1Up)
                firesignal(btn.MouseButton1Click)
                clicked = true
            end
        end

        -- Check Target 2
        if target2 and target2.Visible then
            local btn = target2:IsA("GuiButton") and target2 or target2:FindFirstAncestorWhichIsA("GuiButton")
            if btn and btn.Active then
                print("Dialog 2 detected! Clicking...")
                firesignal(btn.MouseButton1Down)
                task.wait(0.05)
                firesignal(btn.MouseButton1Up)
                firesignal(btn.MouseButton1Click)
                clicked = true
            end
        end

        -- Wait 1 second if we clicked something to let the dialog close
        if clicked then
            task.wait(1)
        end
        
        -- Check every 0.5 seconds
        task.wait(0.5)
    end
end)
