local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Function to click the center of any specific UI element
local function clickUiElement(guiObj)
    if not guiObj then return false end
    if not guiObj.Visible then return false end
    
    local pos = guiObj.AbsolutePosition
    local size = guiObj.AbsoluteSize
    
    -- Make sure the element actually has a size on screen
    if size.X > 0 and size.Y > 0 then
        local clickX = pos.X + (size.X / 2)
        local clickY = pos.Y + (size.Y / 2)
        
        print("Clicking element at:", clickX, clickY)
        VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, true, game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, false, game, 1)
        return true
    end
    
    return false
end

-- Background loop to constantly monitor for the dialogs
task.spawn(function()
    print("Dialog monitor started...")
    
    while true do
        -- 1. Safely navigate down the hierarchy
        local dialogApp = playerGui:FindFirstChild("DialogApp")
        local dialog = dialogApp and dialogApp:FindFirstChild("Dialog", true)
        local normalDialog = dialog and dialog:FindFirstChild("NormalDialog", true)
        local buttons = normalDialog and normalDialog:FindFirstChild("Buttons", true)
        local buttonTemplate = buttons and buttons:FindFirstChild("ButtonTemplate", true)
        
        local clickedSomething = false
        
        -- 2. If ButtonTemplate exists, look for our specific elements
        if buttonTemplate then
            -- Check for Face.Colors
            local face = buttonTemplate:FindFirstChild("Face", true)
            if face then
                local faceColors = face:FindFirstChild("Colors", true)
                if clickUiElement(faceColors) then
                    print("Clicked Face.Colors")
                    clickedSomething = true
                end
            end
            
            -- Check for Shadow.Colors.Left
            local shadow = buttonTemplate:FindFirstChild("Shadow", true)
            if shadow then
                local shadowColors = shadow:FindFirstChild("Colors", true)
                if shadowColors then
                    local leftColor = shadowColors:FindFirstChild("Left", true)
                    if clickUiElement(leftColor) then
                        print("Clicked Shadow.Colors.Left")
                        clickedSomething = true
                    end
                end
            end
        end
        
        -- Wait 1 second if we clicked something to let the dialog close
        if clickedSomething then
            task.wait(1)
        end
        
        -- Check every 0.5 seconds
        task.wait(0.5)
    end
end)
