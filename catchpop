-- Services
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Function to recursively print the path of a GUI object
local function printPath(obj)
    local path = {}
    local current = obj
    while current and current ~= player.PlayerGui do
        table.insert(path, 1, current.Name)
        current = current.Parent
    end
    table.insert(path, 1, "PlayerGui")
    print("Dialog Path: " .. table.concat(path, "."))
end

-- Function to monitor for new dialogs
local function monitorDialogs()
    -- Check for existing DialogApp
    local dialogApp = player.PlayerGui:FindFirstChild("DialogApp")
    if dialogApp then
        print("Found DialogApp!")
        printPath(dialogApp)

        -- Monitor for new dialogs inside DialogApp
        dialogApp.DescendantAdded:Connect(function(descendant)
            if descendant:IsA("Frame") or descendant:IsA("TextButton") or descendant:IsA("ImageButton") then
                print("New dialog element detected:")
                printPath(descendant)
            end
        end)
    else
        -- Wait for DialogApp to appear
        player.PlayerGui.ChildAdded:Connect(function(child)
            if child.Name == "DialogApp" then
                print("DialogApp appeared!")
                printPath(child)

                -- Monitor for new dialogs inside DialogApp
                child.DescendantAdded:Connect(function(descendant)
                    if descendant:IsA("Frame") or descendant:IsA("TextButton") or descendant:IsA("ImageButton") then
                        print("New dialog element detected:")
                        printPath(descendant)
                    end
                end)
            end
        end)
    end
end

-- Start monitoring
monitorDialogs()
print("Dialog path tracker is running. Watch the output for new dialogs!")
