-- Список всех задач
local tasks = {"bored", "sick", "hungry", "thirsty", "dirty", "toilet", "play", "walk", "ride", "pet_me"}

-- Получаем модель питомца
local petModel = workspace:WaitForChild("Pets"):WaitForChild("Cat")

-- Определяем анимацию в зависимости от типа питомца
local animName = "CatIdle"  -- или "DogIdle", если используется собака

-- Обрабатываем все слоты (1, 2, 3)
for slot = 1, 3 do
    for _, task in ipairs(tasks) do
        -- 1. Активация состояния FocusPet
        local args = {
            petModel,
            {
                FocusPet = true
            }
        }
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicateActivePerformances"):FireServer(unpack(args))

        -- 2. Установка анимации
        local args = {
            petModel,
            {
                local_anim_name = animName,
                local_anim_speed = 1,
                dont_allow_sit_states = true,
                dont_allow_remote_interaction = true,
                anim_fade_time = 0.2
            }
        }
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetAPI/ReplicatePerformanceModifiers"):FireServer(unpack(args))

        -- 3. Разгадка mystery ailment
        local args = {
            "2_865e4c0726244ceb899048213fd44f3a",  -- Уникальный ID питомца
            "mystery",
            slot,  -- Текущий слот (1, 2 или 3)
            task   -- Текущая задача
        }
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("AilmentsAPI/ChooseMysteryAilment"):FireServer(unpack(args))

        -- Задержка между задачами
        task.wait(1)
    end
end
