local tasks = {"bored", "sick", "hungry", "thirsty", "dirty", "toilet", "play", "walk", "ride", "pet_me"}

-- Получаем модель питомца
local petModel = workspace:FindFirstChild("Pets") and workspace.Pets:FindFirstChild("Cat")
if not petModel then
    petModel = workspace:FindFirstChild("Pets") and workspace.Pets:FindFirstChild("Dog")
end

if not petModel then
    warn("No pet found!")
    return
end

-- Определяем анимацию в зависимости от типа питомца
local animName = petModel.Name == "Cat" and "CatIdle" or "DogIdle"

-- Обрабатываем все слоты (1, 2, 3)
for slot = 1, 3 do
    for _, task in ipairs(tasks) do
        -- Фокусировка и анимация питомца
        safeFireRemote({"PetAPI", "ReplicateActivePerformances"}, petModel, { FocusPet = true })
        safeFireRemote({"PetAPI", "ReplicatePerformanceModifiers"}, petModel, {
            local_anim_name = animName,
            local_anim_speed = 1,
            dont_allow_sit_states = true,
            dont_allow_remote_interaction = true,
            anim_fade_time = 0.2
        })

        -- Разгадка mystery ailment
        safeFireRemote({"AilmentsAPI", "ChooseMysteryAilment"}, "2_865e4c0726244ceb899048213fd44f3a", "mystery", slot, task)

        -- Дополнительный вызов ReplicateActivePerformances
        safeFireRemote({"PetAPI", "ReplicateActivePerformances"}, Instance.new("Model"), {})

        -- Задержка между задачами
        task.wait(1)
    end
end
